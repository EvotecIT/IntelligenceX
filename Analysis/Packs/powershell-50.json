{
  "id": "powershell-50",
  "label": "PowerShell Essentials (50)",
  "description": "PowerShell baseline pack for small-to-medium repositories. Includes the default security/correctness set plus additional high-signal rules.",
  "includes": ["powershell-default"],
  "rules": [
    "PSAvoidAssignmentToAutomaticVariable",
    "PSAvoidDefaultValueForMandatoryParameter",
    "PSAvoidDefaultValueSwitchParameter",
    "PSAvoidGlobalAliases",
    "PSAvoidGlobalFunctions",
    "PSAvoidGlobalVars",
    "PSAvoidInvokingEmptyMembers",
    "PSAvoidMultipleTypeAttributes",
    "PSAvoidNullOrEmptyHelpMessageAttribute",
    "PSAvoidShouldContinueWithoutForce",
    "PSAvoidUsingComputerNameHardcoded",
    "PSAvoidUsingDeprecatedManifestFields",
    "PSAvoidUsingPositionalParameters",
    "PSAvoidUsingWMICmdlet",
    "PSMisleadingBacktick",
    "PSMissingModuleManifestField",
    "PSProvideCommentHelp",
    "PSReservedCmdletChar",
    "PSReservedParams",
    "PSShouldProcess",
    "PSUseApprovedVerbs",
    "PSUseCmdletCorrectly",
    "PSUseCompatibleCmdlets",
    "PSUseCompatibleCommands",
    "PSUseCompatibleSyntax",
    "PSUseCompatibleTypes",
    "PSUseCorrectCasing",
    "PSUseDeclaredVarsMoreThanAssignments",
    "PSUseLiteralInitializerForHashtable",
    "PSUseOutputTypeCorrectly",
    "PSUseProcessBlockForPipelineCommand",
    "PSUseShouldProcessForStateChangingFunctions",
    "PSUseSupportsShouldProcess",
    "PSUseToExportFieldsInManifest",
    "PSUseUsingScopeModifierInNewRunspaces"
  ]
}
