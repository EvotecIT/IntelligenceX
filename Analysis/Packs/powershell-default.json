{
  "id": "powershell-default",
  "label": "PowerShell Default",
  "description": "High-signal security and correctness rules for PowerShell scripts (PSScriptAnalyzer).",
  "includes": ["powershell-security-default"],
  "rules": [
    "PSAvoidOverwritingBuiltInCmdlets",
    "PSAvoidUsingCmdletAliases",
