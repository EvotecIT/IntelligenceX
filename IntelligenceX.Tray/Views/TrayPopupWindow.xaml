<Window x:Class="IntelligenceX.Tray.Views.TrayPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:IntelligenceX.Tray.ViewModels"
        xmlns:conv="clr-namespace:IntelligenceX.Tray.Converters"
        Title="IntelligenceX Usage"
        Width="520" Height="720"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeChanged="OnWindowSizeChanged"
        Deactivated="OnDeactivated"
        Closing="OnWindowClosing">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
        <conv:ProportionToWidthConverter x:Key="PropToWidth" />
        <conv:ProportionAndWidthToWidthConverter x:Key="PropToActualWidth" />
    </Window.Resources>

    <Border Background="{StaticResource BackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="14"
            Margin="6">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.6" Color="{StaticResource PopupShadowColor}" />
        </Border.Effect>

        <!-- Clip content to rounded corners -->
        <Border.Clip>
            <RectangleGeometry x:Name="PopupClipGeometry" RadiusX="14" RadiusY="14">
                <RectangleGeometry.Rect>
                    <Rect X="0" Y="0" Width="508" Height="708" />
                </RectangleGeometry.Rect>
            </RectangleGeometry>
        </Border.Clip>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ═══ HEADER ═══ -->
            <Border Grid.Row="0"
                    Padding="16,12,16,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="Transparent"
                            Cursor="SizeAll"
                            MouseLeftButtonDown="OnHeaderMouseLeftButtonDown">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="26" Height="26" CornerRadius="7" Margin="0,0,10,0"
                                    ToolTip="{Binding AccentToolTip}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="{StaticResource BrandStartColor}" Offset="0" />
                                        <GradientStop Color="{StaticResource BrandEndColor}" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="IX" FontFamily="{StaticResource AppFont}"
                                           FontSize="11" FontWeight="ExtraBold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <TextBlock FontFamily="{StaticResource AppFont}"
                                       FontSize="15" FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       Text="{Binding HeaderTitle}" />
                        </StackPanel>
                    </Border>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource RefreshButtonStyle}"
                                Command="{Binding ToggleSelectedProviderFavoriteCommand}"
                                IsEnabled="{Binding CanToggleFavoriteSelectedProvider}"
                                VerticalAlignment="Center"
                                Margin="0,0,6,0">
                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="11"
                                       Text="{Binding FavoriteSelectedProviderLabel}" />
                        </Button>
                        <Button Style="{StaticResource RefreshButtonStyle}"
                                Command="{Binding OpenOpenAiCacheCommand}"
                                VerticalAlignment="Center"
                                Margin="0,0,6,0">
                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="11"
                                       Text="Cache" />
                        </Button>
                        <Button Style="{StaticResource RefreshButtonStyle}"
                                Command="{Binding CycleThemeModeCommand}"
                                ToolTip="{Binding ThemeToolTip}"
                                VerticalAlignment="Center"
                                Margin="0,0,6,0">
                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="11"
                                       Text="{Binding ThemeButtonLabel}" />
                        </Button>
                        <Button Style="{StaticResource RefreshButtonStyle}"
                                Command="{Binding HeaderRefreshCommand}"
                                VerticalAlignment="Center">
                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="11"
                                       Text="{Binding HeaderRefreshLabel}" />
                        </Button>
                        <Button Style="{StaticResource RefreshButtonStyle}"
                                Click="OnMinimizeButtonClick"
                                ToolTip="Hide to tray"
                                VerticalAlignment="Center"
                                Margin="6,0,0,0">
                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="14"
                                       Text="−" />
                        </Button>
                        <Button Style="{StaticResource RefreshButtonStyle}"
                                Click="OnCloseButtonClick"
                                ToolTip="Close tray app"
                                VerticalAlignment="Center"
                                Margin="6,0,0,0">
                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="13"
                                       Text="×" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ PROVIDER TABS ═══ -->
            <Border Grid.Row="1"
                    Background="{StaticResource SectionStripBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,1"
                    Padding="6,2">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Providers}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ProviderViewModel}">
                                <RadioButton Style="{StaticResource ProviderTabStyle}"
                                             GroupName="ProviderTabs"
                                             IsChecked="{Binding IsSelected, RelativeSource={RelativeSource Self}}"
                                             Click="OnProviderTabClick"
                                             Tag="{Binding}">
                                    <StackPanel Orientation="Horizontal">
                                        <Viewbox Width="14" Height="14"
                                                 Margin="0,0,5,0"
                                                 VerticalAlignment="Center">
                                            <Path Data="{Binding IconGeometry}"
                                                  Fill="{Binding AccentBrush}"
                                                  Stretch="Uniform" />
                                        </Viewbox>
                                        <TextBlock Text="{Binding ShortName}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="★"
                                                   Margin="5,0,0,0"
                                                   FontSize="10"
                                                   Foreground="{StaticResource FavoriteBadgeBrush}"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVis}}" />
                                        <Border Margin="6,0,0,0"
                                                Padding="5,1"
                                                CornerRadius="8"
                                                Background="{StaticResource SuccessBadgeBrush}"
                                                VerticalAlignment="Center"
                                                ToolTip="{Binding RefreshBadgeToolTip}"
                                                Visibility="{Binding HasRefreshBadge, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="{Binding RefreshBadgeText}"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="9.5"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource SuccessBadgeTextBrush}"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </StackPanel>
                                </RadioButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- ═══ MAIN CONTENT ═══ -->
            <Grid Grid.Row="2">
                <!-- ── USAGE CONTENT (provider tab selected) ── -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding ShowUsageContent, Converter={StaticResource BoolToVis}}">
                    <StackPanel x:Name="ProviderContentPanel"
                                DataContext="{Binding SelectedProvider}"
                                Margin="16,12,16,8">

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <StackPanel Margin="0,0,0,8">
                                    <TextBlock Text="EXPLORER RANGE" Style="{StaticResource SectionHeaderStyle}" Margin="0" />
                                    <WrapPanel Margin="0,6,0,0">
                                        <Button Style="{StaticResource LinkButtonStyle}"
                                                Command="{Binding OpenDetailedReportCommand}"
                                                Margin="0,0,6,6">
                                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10.5" Text="Report" />
                                        </Button>
                                        <Button Style="{StaticResource LinkButtonStyle}"
                                                Command="{Binding ExportCsvCommand}"
                                                Margin="0,0,6,6">
                                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10.5" Text="CSV" />
                                        </Button>
                                        <Button Style="{StaticResource LinkButtonStyle}"
                                                Command="{Binding ExportJsonCommand}"
                                                Margin="0,0,6,6">
                                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10.5" Text="JSON" />
                                        </Button>
                                        <Button Style="{StaticResource LinkButtonStyle}"
                                                Click="OnSavePngButtonClick"
                                                Margin="0,0,6,6">
                                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10.5" Text="PNG" />
                                        </Button>
                                        <Button Style="{StaticResource LinkButtonStyle}"
                                                Command="{Binding ClearFiltersCommand}"
                                                Margin="0,0,6,6">
                                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10.5" Text="Clear" />
                                        </Button>
                                        <Button Style="{StaticResource LinkButtonStyle}"
                                                Command="{Binding CopySummaryCommand}"
                                                Margin="0,0,0,6">
                                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10.5" Text="Copy" />
                                        </Button>
                                    </WrapPanel>
                                </StackPanel>
                                <WrapPanel>
                                    <ToggleButton Style="{StaticResource RangeChipStyle}"
                                                  IsChecked="{Binding IsTodayRangeSelected, Mode=OneWay}"
                                                  Click="OnRangeChipClick"
                                                  Tag="Today">
                                        <TextBlock Text="Today" />
                                    </ToggleButton>
                                    <ToggleButton Style="{StaticResource RangeChipStyle}"
                                                  IsChecked="{Binding IsLast7DaysRangeSelected, Mode=OneWay}"
                                                  Click="OnRangeChipClick"
                                                  Tag="Last7Days">
                                        <TextBlock Text="7 days" />
                                    </ToggleButton>
                                    <ToggleButton Style="{StaticResource RangeChipStyle}"
                                                  IsChecked="{Binding IsLast30DaysRangeSelected, Mode=OneWay}"
                                                  Click="OnRangeChipClick"
                                                  Tag="Last30Days">
                                        <TextBlock Text="30 days" />
                                    </ToggleButton>
                                    <ToggleButton Style="{StaticResource RangeChipStyle}"
                                                  IsChecked="{Binding IsAllTimeRangeSelected, Mode=OneWay}"
                                                  Click="OnRangeChipClick"
                                                  Tag="AllTime"
                                                  Margin="0">
                                        <TextBlock Text="All time" />
                                    </ToggleButton>
                                </WrapPanel>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="Account"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TertiaryTextBrush}"
                                                   Margin="0,0,0,4" />
                                        <ComboBox Style="{StaticResource FilterComboBoxStyle}"
                                                  ItemsSource="{Binding AccountFilterOptions}"
                                                  SelectedItem="{Binding SelectedAccountFilter, Mode=TwoWay}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                        <TextBlock Text="Model"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TertiaryTextBrush}"
                                                   Margin="0,0,0,4" />
                                        <ComboBox Style="{StaticResource FilterComboBoxStyle}"
                                                  ItemsSource="{Binding ModelFilterOptions}"
                                                  SelectedItem="{Binding SelectedModelFilter, Mode=TwoWay}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Surface"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TertiaryTextBrush}"
                                                   Margin="0,0,0,4" />
                                        <ComboBox Style="{StaticResource FilterComboBoxStyle}"
                                                  ItemsSource="{Binding SurfaceFilterOptions}"
                                                  SelectedItem="{Binding SelectedSurfaceFilter, Mode=TwoWay}" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="Usage sections below react to the selected range. Rollups are daily quick-scan rows; live limits stay current."
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="10"
                                           Foreground="{StaticResource TertiaryTextBrush}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding FilteredEventCountLabel}"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="10"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Margin="0,6,0,0" />
                                <TextBlock Text="{Binding ActionStatusMessage}"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="10"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Margin="0,6,0,0"
                                           Visibility="{Binding HasActionStatusMessage, Converter={StaticResource BoolToVis}}" />
                                <Border Margin="0,10,0,0"
                                        Padding="10,8"
                                        CornerRadius="8"
                                        Background="{StaticResource InsetPanelBrush}"
                                        Visibility="{Binding HasUsageHealthSection, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="DATA HEALTH"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TertiaryTextBrush}" />
                                        <TextBlock Text="{Binding UsageHealthSummary}"
                                                   Margin="0,4,0,0"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="10.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding HasUsageHealthSummary, Converter={StaticResource BoolToVis}}" />
                                        <TextBlock Text="{Binding UsageHealthDetail}"
                                                   Margin="0,4,0,0"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding HasUsageHealthDetail, Converter={StaticResource BoolToVis}}" />
                                        <TextBlock Text="{Binding UsageHealthAccountsText}"
                                                   Margin="0,4,0,0"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding HasUsageHealthAccounts, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,10,0,0"
                                        Padding="10,8"
                                        CornerRadius="8"
                                        Background="{StaticResource InsetPanelBrush}"
                                        Visibility="{Binding HasDataScopeSection, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="DATA SCOPE"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TertiaryTextBrush}" />
                                        <TextBlock Text="{Binding ScopeLocalText}"
                                                   Margin="0,4,0,0"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding HasScopeLocalText, Converter={StaticResource BoolToVis}}" />
                                        <TextBlock Text="{Binding ScopeOnlineText}"
                                                   Margin="0,4,0,0"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding HasScopeOnlineText, Converter={StaticResource BoolToVis}}" />
                                        <TextBlock Text="{Binding ScopeDifferenceText}"
                                                   Margin="0,4,0,0"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding HasScopeDifferenceText, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}"
                                Visibility="{Binding HasCombinedOverviewCards, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="OVERVIEW"
                                           Style="{StaticResource SectionHeaderStyle}"
                                           Margin="0,0,0,8" />
                                <ItemsControl ItemsSource="{Binding CombinedOverviewCards}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="2" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:ProviderOverviewCardViewModel}">
                                            <Border Background="{StaticResource SubtleSurfaceMutedBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Margin="0,0,8,8"
                                                    Padding="10,9">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="9.5"
                                                               Foreground="{StaticResource TertiaryTextBrush}" />
                                                    <TextBlock Text="{Binding MetricText}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding AccentBrush}"
                                                               Margin="0,4,0,0" />
                                                    <TextBlock Text="{Binding DetailText}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="10"
                                                               Foreground="{StaticResource SecondaryTextBrush}"
                                                               Margin="0,4,0,0"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}"
                                Visibility="{Binding HasCodeChurn, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="CODE CHURN"
                                               Style="{StaticResource SectionHeaderStyle}"
                                               Margin="0" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding CodeChurnRepositoryText}"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="10"
                                               Foreground="{StaticResource TertiaryTextBrush}" />
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Style="{StaticResource LabelTextStyle}" Text="Added" />
                                        <TextBlock Text="{Binding CodeChurnAddedText}"
                                                   Style="{StaticResource StatValueStyle}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                        <TextBlock Style="{StaticResource LabelTextStyle}" Text="Deleted" />
                                        <TextBlock Text="{Binding CodeChurnDeletedText}"
                                                   Style="{StaticResource StatValueStyle}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                        <TextBlock Style="{StaticResource LabelTextStyle}" Text="Files" />
                                        <TextBlock Text="{Binding CodeChurnFilesText}"
                                                   Style="{StaticResource StatValueStyle}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="3">
                                        <TextBlock Style="{StaticResource LabelTextStyle}" Text="Commits" />
                                        <TextBlock Text="{Binding CodeChurnCommitsText}"
                                                   Style="{StaticResource StatValueStyle}" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="{Binding CodeChurnSummaryText}"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="10"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding CodeChurnPeakDayText}"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="9.5"
                                           Foreground="{StaticResource TertiaryTextBrush}"
                                           Margin="0,4,0,8"
                                           TextWrapping="Wrap" />

                                <ItemsControl ItemsSource="{Binding CodeChurnBars}"
                                              Visibility="{Binding HasCodeChurnBars, Converter={StaticResource BoolToVis}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="7" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:CodeChurnBarViewModel}">
                                            <StackPanel HorizontalAlignment="Center" Margin="2,0">
                                                <Grid Height="50" VerticalAlignment="Bottom">
                                                    <Border CornerRadius="3"
                                                            Background="{StaticResource SubtleSurfaceMutedBrush}"
                                                            VerticalAlignment="Stretch" />
                                                    <Border CornerRadius="3"
                                                            Background="{Binding BarBrush}"
                                                            Opacity="0.75"
                                                            VerticalAlignment="Bottom"
                                                            Height="{Binding BarHeight}" />
                                                </Grid>
                                                <TextBlock Text="{Binding DayLabel}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="9"
                                                           Foreground="{StaticResource TertiaryTextBrush}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,4,0,0" />
                                                <TextBlock Text="{Binding SummaryText}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="8"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}"
                                Visibility="{Binding HasCodeUsageCorrelation, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="CHURN x USAGE"
                                           Style="{StaticResource SectionHeaderStyle}"
                                           Margin="0,0,0,8" />
                                <TextBlock Text="{Binding CodeUsageCorrelationHeadlineText}"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding CodeUsageCorrelationSummaryText}"
                                           Margin="0,6,0,8"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="10"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           TextWrapping="Wrap" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Margin="0,0,6,0"
                                            Padding="10,9"
                                            Background="{StaticResource SubtleSurfaceMutedBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Visibility="{Binding HasPositiveCodeUsageCorrelation, Converter={StaticResource BoolToVis}}">
                                        <StackPanel>
                                            <TextBlock Text="ALIGNED"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="9.5"
                                                       Foreground="{StaticResource TertiaryTextBrush}" />
                                            <TextBlock Text="{Binding CodeUsagePositiveProviderText}"
                                                       Margin="0,4,0,0"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource SuccessBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding CodeUsagePositiveSummaryText}"
                                                       Margin="0,4,0,0"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="9.5"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1"
                                            Margin="6,0,0,0"
                                            Padding="10,9"
                                            Background="{StaticResource SubtleSurfaceMutedBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Visibility="{Binding HasNegativeCodeUsageCorrelation, Converter={StaticResource BoolToVis}}">
                                        <StackPanel>
                                            <TextBlock Text="DIVERGING"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="9.5"
                                                       Foreground="{StaticResource TertiaryTextBrush}" />
                                            <TextBlock Text="{Binding CodeUsageNegativeProviderText}"
                                                       Margin="0,4,0,0"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource WarningBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding CodeUsageNegativeSummaryText}"
                                                       Margin="0,4,0,0"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="9.5"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ── TODAY'S USAGE ── -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="{Binding TodayLabel}"
                                               Style="{StaticResource SectionHeaderStyle}"
                                               Margin="0" />
                                    <TextBlock HorizontalAlignment="Right"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="10"
                                               Foreground="{StaticResource TertiaryTextBrush}">
                                        <Run Text="{Binding TodayRollupCountText, Mode=OneWay}" />
                                    </TextBlock>
                                </Grid>

                                <!-- Total Tokens - Hero Number -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                    <TextBlock Text="{Binding TodayTotalTokensFormatted}"
                                               Style="{StaticResource ValueTextStyle}" />
                                    <TextBlock Text=" tokens"
                                               Style="{StaticResource LabelTextStyle}"
                                               VerticalAlignment="Bottom"
                                               Margin="4,0,0,4" />
                                </StackPanel>

                                <!-- Token Bars (stacked Input + Output) -->
