                                            <TextBlock Text="DIVERGENCE"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="9.5"
                                                       Foreground="{StaticResource TertiaryTextBrush}" />
                                            <TextBlock Text="{Binding NegativeCorrelationPairText}"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       Margin="0,4,0,0"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding NegativeCorrelationSummaryText}"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="9.5"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       Margin="0,4,0,0"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <TextBlock Text="{Binding LocalAlignmentHeadlineText}"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="10"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Margin="0,0,0,8"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding HasLocalAlignmentSignals, Converter={StaticResource BoolToVis}}" />
                                <Grid Margin="0,0,0,8"
                                      Visibility="{Binding HasLocalAlignmentSignals, Converter={StaticResource BoolToVis}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Background="{StaticResource InsetPanelBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="10,8"
                                            Margin="0,0,6,0"
                                            Visibility="{Binding HasPositiveLocalAlignment, Converter={StaticResource BoolToVis}}">
                                        <StackPanel>
                                            <TextBlock Text="LOCAL SYNC"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="9.5"
                                                       Foreground="{StaticResource TertiaryTextBrush}" />
                                            <TextBlock Text="{Binding PositiveLocalAlignmentRepositoryText}"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       Margin="0,4,0,0"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding PositiveLocalAlignmentSummaryText}"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="9.5"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       Margin="0,4,0,0"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1"
                                            Background="{StaticResource InsetPanelBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="10,8"
                                            Margin="6,0,0,0"
                                            Visibility="{Binding HasNegativeLocalAlignment, Converter={StaticResource BoolToVis}}">
                                        <StackPanel>
                                            <TextBlock Text="LOCAL DIVERGENCE"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="9.5"
                                                       Foreground="{StaticResource TertiaryTextBrush}" />
                                            <TextBlock Text="{Binding NegativeLocalAlignmentRepositoryText}"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       Margin="0,4,0,0"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding NegativeLocalAlignmentSummaryText}"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="9.5"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       Margin="0,4,0,0"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <TextBlock Text="{Binding StargazerAudienceHeadlineText}"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="10"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Margin="0,0,0,8"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding HasStargazerAudienceInsight, Converter={StaticResource BoolToVis}}" />
                                <Border Margin="0,0,0,8"
                                        Background="{StaticResource InsetPanelBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="10,8"
                                        Visibility="{Binding HasStargazerAudienceInsight, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="SHARED STARGAZERS"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="9.5"
                                                   Foreground="{StaticResource TertiaryTextBrush}" />
                                        <TextBlock Text="{Binding StargazerAudiencePairText}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding StargazerAudienceSummaryText}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="9.5"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="{Binding ForkNetworkHeadlineText}"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="10"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Margin="0,0,0,8"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding HasForkNetworkInsight, Converter={StaticResource BoolToVis}}" />
                                <Border Margin="0,0,0,8"
                                        Background="{StaticResource InsetPanelBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="10,8"
                                        Visibility="{Binding HasForkNetworkInsight, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding ForkNetworkCardLabelText}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="9.5"
                                                   Foreground="{StaticResource TertiaryTextBrush}" />
                                        <TextBlock Text="{Binding ForkNetworkPairText}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding ForkNetworkSummaryText}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="9.5"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="{Binding ForkMomentumHeadlineText}"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="10"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Margin="0,0,0,8"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding HasForkMomentum, Converter={StaticResource BoolToVis}}" />
                                <Border Margin="0,0,0,8"
                                        Background="{StaticResource InsetPanelBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="10,8"
                                        Visibility="{Binding HasForkMomentum, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="RISING FORKS"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="9.5"
                                                   Foreground="{StaticResource TertiaryTextBrush}" />
                                        <TextBlock Text="{Binding ForkMomentumPrimaryText}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding ForkMomentumSummaryText}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="9.5"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="{Binding RepositoryClusterHeadlineText}"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="10"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Margin="0,0,0,8"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding HasRepositoryCluster, Converter={StaticResource BoolToVis}}" />
                                <Border Margin="0,0,0,8"
                                        Background="{StaticResource InsetPanelBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="10,8"
                                        Visibility="{Binding HasRepositoryCluster, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="RELATED REPOS"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="9.5"
                                                   Foreground="{StaticResource TertiaryTextBrush}" />
                                        <TextBlock Text="{Binding RepositoryClusterPairText}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding RepositoryClusterSummaryText}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="9.5"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <ItemsControl ItemsSource="{Binding WatchedRepositories}"
                                              Visibility="{Binding HasWatchedRepositories, Converter={StaticResource BoolToVis}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:GitHubWatchedRepositoryViewModel}">
                                            <Border Background="{StaticResource SubtleSurfaceMutedBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Margin="0,0,0,8"
                                                    Padding="10">
