                                                   FontSize="9.5"
                                                   Foreground="{StaticResource SecondaryTextBrush}" />
                                    </Border>
                                    <Border Background="{StaticResource InsetPanelBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="6,2"
                                            Margin="0,0,6,6">
                                        <TextBlock Text="{Binding PositiveForkDeltaFormatted, StringFormat={}{0} forks}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="9.5"
                                                   Foreground="{StaticResource SecondaryTextBrush}" />
                                    </Border>
                                    <Border Background="{StaticResource InsetPanelBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="6,2"
                                            Margin="0,0,6,6">
                                        <TextBlock Text="{Binding PositiveWatcherDeltaFormatted, StringFormat={}{0} watchers}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="9.5"
                                                   Foreground="{StaticResource SecondaryTextBrush}" />
                                    </Border>
                                    <Border Background="{StaticResource InsetPanelBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="6,2"
                                            Margin="0,0,0,6">
                                        <TextBlock Text="{Binding ChangedTrackedRepositoryCountFormatted, StringFormat={}{0} repos moved}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="9.5"
                                                   Foreground="{StaticResource SecondaryTextBrush}" />
                                    </Border>
                                </WrapPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Background="{StaticResource InsetPanelBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="10,8"
                                            Margin="0,0,6,0"
                                            Visibility="{Binding HasPositiveCorrelation, Converter={StaticResource BoolToVis}}">
                                        <StackPanel>
                                            <TextBlock Text="LINKED MOVERS"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="9.5"
                                                       Foreground="{StaticResource TertiaryTextBrush}" />
                                            <TextBlock Text="{Binding PositiveCorrelationPairText}"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       Margin="0,4,0,0"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding PositiveCorrelationSummaryText}"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="9.5"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       Margin="0,4,0,0"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1"
                                            Background="{StaticResource InsetPanelBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="10,8"
                                            Margin="6,0,0,0"
                                            Visibility="{Binding HasNegativeCorrelation, Converter={StaticResource BoolToVis}}">
