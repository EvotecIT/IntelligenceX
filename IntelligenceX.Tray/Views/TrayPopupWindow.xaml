                                                       Margin="0,4,0,0"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource SuccessBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding CodeUsagePositiveSummaryText}"
                                                       Margin="0,4,0,0"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="9.5"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       TextWrapping="Wrap" />
