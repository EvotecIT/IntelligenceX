<Window x:Class="IntelligenceX.Tray.Views.TrayPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:IntelligenceX.Tray.ViewModels"
        xmlns:conv="clr-namespace:IntelligenceX.Tray.Converters"
        Title="IntelligenceX Usage"
        Width="720" Height="760"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="False"
        ResizeMode="NoResize"
        SizeChanged="OnWindowSizeChanged"
        Closing="OnWindowClosing">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
        <conv:ProportionToWidthConverter x:Key="PropToWidth" />
        <conv:ProportionAndWidthToWidthConverter x:Key="PropToActualWidth" />
        <Style x:Key="ProviderRailButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border x:Name="Bd"
                                Background="{StaticResource SubtleSurfaceMutedBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="8"
                                Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SubtleSurfaceEmphasisBrush}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource CardBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35" />
                                <Setter TargetName="Bd" Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="14"
            Margin="6">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.6" Color="{StaticResource PopupShadowColor}" />
        </Border.Effect>

        <!-- Clip content to rounded corners -->
        <Border.Clip>
            <RectangleGeometry x:Name="PopupClipGeometry" RadiusX="14" RadiusY="14">
                <RectangleGeometry.Rect>
                    <Rect X="0" Y="0" Width="508" Height="708" />
                </RectangleGeometry.Rect>
            </RectangleGeometry>
        </Border.Clip>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ═══ HEADER ═══ -->
            <Border Grid.Row="0"
                    Padding="16,12,16,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="Transparent"
                            Cursor="SizeAll"
                            Margin="0,0,10,0"
                            MouseLeftButtonDown="OnHeaderMouseLeftButtonDown">
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="34" Height="34" CornerRadius="9" Margin="0,0,12,0"
                                    ToolTip="{Binding AccentToolTip}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="{StaticResource BrandStartColor}" Offset="0" />
                                        <GradientStop Color="{StaticResource BrandEndColor}" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="IX" FontFamily="{StaticResource AppFont}"
                                           FontSize="14" FontWeight="ExtraBold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock FontFamily="{StaticResource AppFont}"
                                           FontSize="19" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           Text="Usage Pulse"
                                           TextTrimming="CharacterEllipsis" />
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock FontFamily="{StaticResource AppFont}"
                                               FontSize="11"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="{Binding LastRefreshedFormatted, StringFormat=Updated {0}}"
                                               TextTrimming="CharacterEllipsis" />
                                    <Ellipse Width="7" Height="7"
                                             Margin="8,0,0,0"
                                             VerticalAlignment="Center"
                                             Fill="{StaticResource SuccessBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource RefreshButtonStyle}"
                                Command="{Binding ToggleSelectedProviderFavoriteCommand}"
                                IsEnabled="{Binding CanToggleFavoriteSelectedProvider}"
                                ToolTip="{Binding FavoriteSelectedProviderActionLabel}"
                                AutomationProperties.Name="{Binding FavoriteSelectedProviderActionLabel}"
                                VerticalAlignment="Center"
                                Margin="0,0,6,0">
                            <Viewbox Width="15" Height="15">
                                <Path Data="{StaticResource IconPin}" Fill="{StaticResource PrimaryTextBrush}" Stretch="Uniform" />
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource RefreshButtonStyle}"
                                Command="{Binding HeaderRefreshCommand}"
                                ToolTip="{Binding HeaderRefreshLabel}"
                                AutomationProperties.Name="{Binding HeaderRefreshLabel}"
                                VerticalAlignment="Center"
                                Margin="0,0,6,0">
                            <Viewbox Width="16" Height="16">
                                <Path Data="{StaticResource IconRefresh}" Fill="{StaticResource PrimaryTextBrush}" Stretch="Uniform" />
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource RefreshButtonStyle}"
                                Command="{Binding CycleThemeModeCommand}"
                                ToolTip="{Binding ThemeToolTip}"
                                AutomationProperties.Name="{Binding ThemeActionLabel}"
                                VerticalAlignment="Center"
                                Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Viewbox Width="14" Height="14" Margin="0,0,5,0">
                                    <Path Data="{Binding ThemeButtonIcon}" Fill="{StaticResource PrimaryTextBrush}" Stretch="Uniform" />
                                </Viewbox>
                                <TextBlock Text="{Binding ThemeButtonNextLabel}"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="10.5"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryTextBrush}" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource RefreshButtonStyle}"
                                Click="OnMinimizeButtonClick"
                                ToolTip="Minimize to tray"
                                AutomationProperties.Name="Minimize to tray"
                                VerticalAlignment="Center"
                                Margin="0,0,6,0">
                            <Viewbox Width="15" Height="15">
                                <Path Data="{StaticResource IconMinimize}" Fill="{StaticResource PrimaryTextBrush}" Stretch="Uniform" />
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource RefreshButtonStyle}"
                                Click="OnCloseButtonClick"
                                ToolTip="Close"
                                AutomationProperties.Name="Close"
                                VerticalAlignment="Center">
                            <Viewbox Width="15" Height="15">
                                <Path Data="{StaticResource IconClose}" Fill="{StaticResource PrimaryTextBrush}" Stretch="Uniform" />
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ PROVIDER TABS ═══ -->
            <Border Grid.Row="1"
                    Background="{StaticResource SectionStripBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,1"
                    Padding="10,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <RepeatButton x:Name="ProviderTabsScrollLeftButton"
                                  Style="{StaticResource ProviderRailButtonStyle}"
                                  Click="OnProviderTabsScrollLeftClick"
                                  Delay="260"
                                  Interval="70"
                                  ToolTip="Scroll providers left"
                                  AutomationProperties.Name="Scroll providers left"
                                  VerticalAlignment="Stretch"
                                  Margin="0,0,8,0">
                        <Viewbox Width="13" Height="13">
                            <Path Data="{StaticResource IconChevronRight}"
                                  Fill="{StaticResource SecondaryTextBrush}"
                                  Stretch="Uniform"
                                  RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <RotateTransform Angle="180" />
                                </Path.RenderTransform>
                            </Path>
                        </Viewbox>
                    </RepeatButton>
                    <ScrollViewer x:Name="ProviderTabsScrollViewer"
                                  Grid.Column="1"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  Loaded="OnProviderTabsLoaded"
                                  SizeChanged="OnProviderTabsSizeChanged"
                                  ScrollChanged="OnProviderTabsScrollChanged"
                                  PreviewMouseWheel="OnProviderTabsPreviewMouseWheel">
                        <ItemsControl x:Name="ProviderTabsItemsControl"
                                      ItemsSource="{Binding Providers}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:ProviderViewModel}">
                                    <RadioButton Style="{StaticResource ProviderTabStyle}"
                                                 GroupName="ProviderTabs"
                                                 IsChecked="{Binding IsSelected, Mode=OneWay}"
                                                 Click="OnProviderTabClick"
                                                 Tag="{Binding}">
                                        <Grid Width="106" Height="60">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Viewbox Width="15" Height="15"
                                                         Margin="0,0,7,0"
                                                         VerticalAlignment="Center">
                                                    <Path Data="{Binding IconGeometry}"
                                                          Fill="{Binding AccentBrush}"
                                                          Stretch="Uniform" />
                                                </Viewbox>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding ShortName}"
                                                           TextTrimming="CharacterEllipsis"
                                                           FontSize="13"
                                                           VerticalAlignment="Center" />
                                                <Ellipse Grid.Column="2"
                                                         Width="7" Height="7"
                                                         Fill="{Binding PulseStatusBrush}"
                                                         VerticalAlignment="Center" />
                                            </Grid>
                                            <StackPanel Grid.Row="1"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Bottom"
                                                        Margin="0,6,0,0">
                                                <TextBlock Text="{Binding PulseProviderMetricText}"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource PrimaryTextBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="96" />
                                                <TextBlock Text="★"
                                                           Margin="5,0,0,2"
                                                           FontSize="8"
                                                           Foreground="{StaticResource FavoriteBadgeBrush}"
                                                           VerticalAlignment="Bottom"
                                                           Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVis}}" />
                                            </StackPanel>
                                        </Grid>
                                    </RadioButton>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <RepeatButton x:Name="ProviderTabsScrollRightButton"
                                  Grid.Column="2"
                                  Style="{StaticResource ProviderRailButtonStyle}"
                                  Click="OnProviderTabsScrollRightClick"
                                  Delay="260"
                                  Interval="70"
                                  ToolTip="Scroll providers right"
                                  AutomationProperties.Name="Scroll providers right"
                                  VerticalAlignment="Stretch"
                                  Margin="8,0,0,0">
                        <Viewbox Width="13" Height="13">
                            <Path Data="{StaticResource IconChevronRight}"
                                  Fill="{StaticResource SecondaryTextBrush}"
                                  Stretch="Uniform" />
                        </Viewbox>
                    </RepeatButton>
                </Grid>
            </Border>

            <!-- ═══ CODEX STATE ═══ -->
            <Border Grid.Row="2"
                    Background="{StaticResource SectionStripBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="14,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                        <Ellipse Width="9"
                                 Height="9"
                                 Fill="{Binding CodexDiagnosticsStatusBrush}"
                                 VerticalAlignment="Center"
                                 Margin="0,0,9,0" />
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding CodexDiagnosticsStatusText}"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="300" />
                                <TextBlock Text="{Binding CodexDiagnosticsIssueText}"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="10"
                                           Foreground="{StaticResource TertiaryTextBrush}"
                                           Margin="8,1,0,0" />
                                <TextBlock Text="{Binding CodexDiagnosticsDatabaseText}"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="10"
                                           Foreground="{StaticResource TertiaryTextBrush}"
                                           Margin="8,1,0,0" />
                            </StackPanel>
                            <TextBlock Text="{Binding CodexDiagnosticsDetailText}"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="10"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="500" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Style="{StaticResource RefreshButtonStyle}"
                                Command="{Binding ToggleCodexDiagnosticsDetailsCommand}"
                                ToolTip="Show or hide Codex local-state details"
                                AutomationProperties.Name="Toggle Codex local-state details">
                            <TextBlock Text="{Binding CodexDiagnosticsDetailsActionLabel}"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="10.5"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryTextBrush}" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ MAIN CONTENT ═══ -->
            <Grid Grid.Row="3">
                <!-- ── USAGE CONTENT (provider tab selected) ── -->
                <ScrollViewer x:Name="UsageContentScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding ShowUsageContent, Converter={StaticResource BoolToVis}}">
                    <StackPanel x:Name="ProviderContentPanel"
                                DataContext="{Binding SelectedProvider}"
                                Margin="16,12,16,8">

                        <Border Style="{StaticResource CardStyle}"
                                Padding="16"
                                Background="{StaticResource PulseHeroBrush}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0"
                                      Margin="0,0,0,12"
                                      Visibility="{Binding ShowProviderPulseHeader, Converter={StaticResource BoolToVis}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="34" Height="34"
                                                CornerRadius="10"
                                                Background="{StaticResource PulseGlassBrush}"
                                                Margin="0,0,10,0">
                                            <Viewbox Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Path Data="{Binding IconGeometry}" Fill="{Binding AccentBrush}" Stretch="Uniform" />
                                            </Viewbox>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}" />
                                            <TextBlock Text="{Binding LimitSummary}"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource TertiaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="320"
                                                       Visibility="{Binding HasLimitSummary, Converter={StaticResource BoolToVis}}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            Padding="10,5"
                                            CornerRadius="14"
                                            Background="{Binding PulseStatusPanelBrush}"
                                            VerticalAlignment="Top">
                                        <StackPanel Orientation="Horizontal">
                                            <Viewbox Width="13" Height="13" Margin="0,0,6,0">
                                                <Path Data="{StaticResource IconCheckCircle}" Fill="{Binding PulseStatusBrush}" Stretch="Uniform" />
                                            </Viewbox>
                                            <TextBlock Text="{Binding PulseStatusText}"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="230" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding PulsePrimaryLabel}"
                                               Style="{StaticResource SectionHeaderStyle}"
                                               Margin="0,0,0,4" />
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding PulsePrimaryValue}"
                                                   Style="{StaticResource ValueTextStyle}"
                                                   FontSize="42" />
                                        <TextBlock Text=" tokens"
                                                   Style="{StaticResource LabelTextStyle}"
                                                   FontSize="13"
                                                   VerticalAlignment="Bottom"
                                                   Margin="7,0,0,9" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding PulseSecondaryLabel}"
                                               Style="{StaticResource LabelTextStyle}"
                                               Margin="0,8,0,2" />
                                    <TextBlock Text="{Binding PulseSecondaryValue}"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="24"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryTextBrush}" />
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="{Binding PulseTrendText}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding PulseTrendBrush}" />
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1"
                                            Visibility="{Binding IsCombinedProvider, Converter={StaticResource BoolToVis}}">
                                    <Border Padding="10,5"
                                            CornerRadius="14"
                                            Background="{Binding PulseStatusPanelBrush}"
                                            HorizontalAlignment="Right"
                                            Margin="0,0,0,12">
                                        <StackPanel Orientation="Horizontal">
                                            <Viewbox Width="13" Height="13" Margin="0,0,7,0">
                                                <Path Data="{StaticResource IconCheckCircle}" Fill="{Binding PulseStatusBrush}" Stretch="Uniform" />
                                            </Viewbox>
                                            <TextBlock Text="{Binding PulseStatusText}"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}" />
                                        </StackPanel>
                                    </Border>
                                    <ItemsControl ItemsSource="{Binding DailyBars}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="7" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:DailyBarViewModel}">
                                                <StackPanel HorizontalAlignment="Center" Margin="2,0">
                                                    <Grid Height="70" VerticalAlignment="Bottom">
                                                        <Border CornerRadius="4"
                                                                Width="13"
                                                                Background="{StaticResource SubtleSurfaceStrongBrush}" />
                                                        <Border CornerRadius="4"
                                                                Width="13"
                                                                Background="{Binding BarBrush}"
                                                                VerticalAlignment="Bottom"
                                                                Height="{Binding BarHeight}" />
                                                    </Grid>
                                                    <TextBlock Text="{Binding DayLabel}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="8.5"
                                                               Foreground="{StaticResource TertiaryTextBrush}"
                                                               HorizontalAlignment="Center"
                                                               Margin="0,5,0,0" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                <Grid Grid.Column="1"
                                      Visibility="{Binding ShowProviderPulseHeader, Converter={StaticResource BoolToVis}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Padding="12,10"
                                            Margin="0,0,8,0"
                                            CornerRadius="10"
                                            Background="{StaticResource PulseSuccessPanelBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <Viewbox Width="18" Height="18" Margin="0,0,8,0">
                                                    <Path Data="{StaticResource IconSparkle}" Fill="{StaticResource SuccessBrush}" Stretch="Uniform" />
                                                </Viewbox>
                                                <TextBlock Text="Cached input"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource SecondaryTextBrush}" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding PulseCachedSavingsValue}"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="20"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       Margin="0,8,0,0" />
                                            <TextBlock Text="{Binding PulseCachedSavingsDetail}"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1"
                                            Padding="12,10"
                                            CornerRadius="10"
                                            Background="{StaticResource SubtleSurfaceMutedBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Top model"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource SecondaryTextBrush}" />
                                            <TextBlock Text="{Binding PulseTopModelName}"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="17"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,8,0,0" />
                                            <TextBlock Text="{Binding PulseTopModelDetailText}"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource SecondaryTextBrush}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                </Grid>
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
                                    <Viewbox Width="18" Height="18" Margin="0,0,10,0">
                                        <Path Data="{StaticResource IconSparkle}" Fill="{StaticResource CyanBrush}" Stretch="Uniform" />
                                    </Viewbox>
                                    <TextBlock Text="{Binding PulseInsightText}"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               TextWrapping="Wrap"
                                               Width="450" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <UniformGrid Columns="3" Margin="0,0,0,10">
                            <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="13,10" Margin="0,0,7,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="38" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="30" Height="30" CornerRadius="8" Background="{StaticResource PulseGlassBrush}" VerticalAlignment="Center">
                                        <Viewbox Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path Data="{StaticResource IconChartBars}" Fill="{StaticResource InfoBrush}" Stretch="Uniform" />
                                        </Viewbox>
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="7d" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding WeeklyTotalTokensFormatted}" Style="{StaticResource StatValueStyle}" FontSize="18" />
                                        <TextBlock Text="{Binding WeeklyAvgPerDayFormatted}" Style="{StaticResource LabelTextStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="13,10" Margin="3,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="38" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="30" Height="30" CornerRadius="8" Background="{StaticResource SubtleSurfaceEmphasisBrush}" VerticalAlignment="Center">
                                        <Viewbox Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path Data="{StaticResource IconCalendar}" Fill="{StaticResource PurpleBrush}" Stretch="Uniform" />
                                        </Viewbox>
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="30d" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding MonthlyTotalTokensFormatted}" Style="{StaticResource StatValueStyle}" FontSize="18" />
                                        <TextBlock Text="{Binding MonthlyAvgPerDayFormatted}" Style="{StaticResource LabelTextStyle}" />
