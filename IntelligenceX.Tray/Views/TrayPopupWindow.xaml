                                            CornerRadius="8"
                                            Background="{StaticResource InsetPanelBrush}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding UsageHealthDetail}"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       TextWrapping="Wrap"
                                                       Visibility="{Binding HasUsageHealthDetail, Converter={StaticResource BoolToVis}}" />
                                            <TextBlock Text="{Binding UsageHealthAccountsText}"
                                                       Margin="0,4,0,0"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       TextWrapping="Wrap"
                                                       Visibility="{Binding HasUsageHealthAccounts, Converter={StaticResource BoolToVis}}" />
                                            <TextBlock Text="{Binding ScopeLocalText}"
