                                        Background="{StaticResource InsetPanelBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="10,8"
                                        Visibility="{Binding HasForkNetworkInsight, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding ForkNetworkCardLabelText}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="9.5"
                                                   Foreground="{StaticResource TertiaryTextBrush}" />
                                        <TextBlock Text="{Binding ForkNetworkPairText}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding ForkNetworkSummaryText}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="9.5"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="{Binding ForkMomentumHeadlineText}"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="10"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding HasForkMomentum, Converter={StaticResource BoolToVis}}" />
                                <Border Margin="0,8,0,0"
                                        Background="{StaticResource InsetPanelBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="10,8"
                                        Visibility="{Binding HasForkMomentum, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="RISING FORKS"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="9.5"
                                                   Foreground="{StaticResource TertiaryTextBrush}" />
                                        <TextBlock Text="{Binding ForkMomentumPrimaryText}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding ForkMomentumSummaryText}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="9.5"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="{Binding RepositoryClusterHeadlineText}"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="10"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding HasRepositoryCluster, Converter={StaticResource BoolToVis}}" />
                                <Border Margin="0,8,0,0"
                                        Background="{StaticResource InsetPanelBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="10,8"
                                        Visibility="{Binding HasRepositoryCluster, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="RELATED REPOS"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="9.5"
                                                   Foreground="{StaticResource TertiaryTextBrush}" />
                                        <TextBlock Text="{Binding RepositoryClusterPairText}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding RepositoryClusterSummaryText}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="9.5"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- ── LIVE LIMITS ── -->
                        <Border Style="{StaticResource CardStyle}"
                                Visibility="{Binding HasLimitSection, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="LIVE LIMITS"
                                               Style="{StaticResource SectionHeaderStyle}"
                                               Margin="0" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding LimitSourceLabel}"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="10"
                                               Foreground="{StaticResource TertiaryTextBrush}" />
                                </Grid>

                                <TextBlock Text="{Binding LimitPlanLabel}"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="17"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryTextBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LimitPlanLabel}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding LimitPlanLabel}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <TextBlock Text="{Binding LimitAccountLabel}"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="11"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Margin="0,2,0,8">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LimitAccountLabel}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding LimitAccountLabel}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <Border Margin="0,0,0,8"
                                        Padding="10,8"
                                        CornerRadius="10"
                                        Background="{StaticResource InsetPanelBrush}"
                                        Visibility="{Binding HasMultipleLimitAccounts, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock FontFamily="{StaticResource AppFont}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TertiaryTextBrush}"
                                                   Text="ACCOUNT RUNWAY" />
                                        <TextBlock Margin="0,4,0,0"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding LimitAccountsOverviewText}"
                                                   Visibility="{Binding HasLimitAccountsOverview, Converter={StaticResource BoolToVis}}" />
                                        <TextBlock Margin="0,4,0,8"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding HasRecommendedLimitAccount, Converter={StaticResource BoolToVis}}">
                                            <Run Text="{Binding RecommendedLimitAccountLabel}" />
                                            <Run Text=" • " />
                                            <Run Text="{Binding RecommendedLimitAccountSummary}" />
                                        </TextBlock>

                                        <ItemsControl ItemsSource="{Binding LimitAccounts}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:ProviderLimitAccountViewModel}">
                                                    <Border Margin="0,0,0,6"
                                                            Padding="10,8"
                                                            CornerRadius="8"
                                                            Background="{StaticResource InsetPanelStrongBrush}">
                                                        <StackPanel>
                                                            <ToggleButton IsChecked="{Binding IsExpanded}"
                                                                          Background="Transparent"
                                                                          BorderBrush="{x:Null}"
                                                                          BorderThickness="0"
                                                                          Padding="0"
                                                                          HorizontalContentAlignment="Stretch"
                                                                          FocusVisualStyle="{x:Null}">
                                                                <ToggleButton.Template>
                                                                    <ControlTemplate TargetType="ToggleButton">
                                                                        <ContentPresenter />
                                                                    </ControlTemplate>
                                                                </ToggleButton.Template>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel Grid.Column="0">
                                                                        <TextBlock Text="{Binding Label}"
                                                                                   FontFamily="{StaticResource AppFont}"
                                                                                   FontSize="11"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="{StaticResource PrimaryTextBrush}" />
                                                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                                            <Border Padding="6,1"
                                                                                    CornerRadius="7"
                                                                                    Background="{StaticResource SubtleSurfaceEmphasisBrush}"
                                                                                    Margin="0,0,6,0">
                                                                                <Border.Style>
                                                                                    <Style TargetType="Border">
                                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding HasStatusLabel}" Value="True">
                                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </Border.Style>
                                                                                <TextBlock Text="{Binding StatusLabel}"
                                                                                           FontFamily="{StaticResource AppFont}"
                                                                                           FontSize="9.5"
                                                                                           FontWeight="SemiBold"
                                                                                           Foreground="{StaticResource SecondaryTextBrush}" />
                                                                            </Border>
                                                                            <TextBlock Text="{Binding PlanLabel}"
                                                                                       FontFamily="{StaticResource AppFont}"
                                                                                       FontSize="9.5"
                                                                                       Foreground="{StaticResource TertiaryTextBrush}">
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="TextBlock">
                                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding HasPlanLabel}" Value="True">
                                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                        </StackPanel>
                                                                        <TextBlock Text="{Binding Summary}"
                                                                                   FontFamily="{StaticResource AppFont}"
                                                                                   FontSize="10"
                                                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                                                   TextWrapping="Wrap"
                                                                                   Margin="0,4,0,0" />
                                                                        <TextBlock Text="{Binding DetailText}"
                                                                                   FontFamily="{StaticResource AppFont}"
                                                                                   FontSize="9.5"
                                                                                   Foreground="{StaticResource TertiaryTextBrush}"
                                                                                   TextWrapping="Wrap"
                                                                                   Margin="0,4,0,0"
                                                                                   Visibility="{Binding HasDetailText, Converter={StaticResource BoolToVis}}" />
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="1"
                                                                                Margin="10,0,0,0"
                                                                                HorizontalAlignment="Right">
                                                                        <Border Padding="8,2"
                                                                                CornerRadius="8"
                                                                                Background="{StaticResource SubtleSurfaceEmphasisBrush}"
                                                                                HorizontalAlignment="Right">
                                                                            <Border.Style>
                                                                                <Style TargetType="Border">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasBadge}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                            <TextBlock Text="{Binding BadgeText}"
                                                                                       FontFamily="{StaticResource AppFont}"
                                                                                       FontSize="9.5"
                                                                                       FontWeight="SemiBold"
                                                                                       Foreground="{StaticResource SecondaryTextBrush}" />
                                                                        </Border>
                                                                        <TextBlock Text="{Binding WindowSummaryText}"
                                                                                   Margin="0,6,0,0"
                                                                                   TextAlignment="Right"
                                                                                   FontFamily="{StaticResource AppFont}"
                                                                                   FontSize="9.5"
                                                                                   Foreground="{StaticResource TertiaryTextBrush}">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasWindowSummary}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                        <TextBlock Margin="0,6,0,0"
                                                                                   TextAlignment="Right"
                                                                                   FontFamily="{StaticResource AppFont}"
                                                                                   FontSize="9.5"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="{StaticResource SecondaryTextBrush}">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Text" Value="Show windows" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                                            <Setter Property="Text" Value="Hide windows" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </ToggleButton>

                                                            <Border Margin="0,8,0,0"
                                                                    Padding="10,8"
                                                                    CornerRadius="8"
                                                                    Background="{StaticResource SubtleSurfaceMutedBrush}"
                                                                    Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                                                <ItemsControl ItemsSource="{Binding Windows}"
                                                                              Visibility="{Binding HasWindows, Converter={StaticResource BoolToVis}}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate DataType="{x:Type vm:ProviderLimitWindowViewModel}">
                                                                            <StackPanel Margin="0,0,0,10">
                                                                                <Grid Margin="0,0,0,4">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="*" />
                                                                                        <ColumnDefinition Width="Auto" />
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <TextBlock Grid.Column="0"
                                                                                               Text="{Binding Label}"
                                                                                               FontFamily="{StaticResource AppFont}"
                                                                                               FontSize="11"
                                                                                               FontWeight="SemiBold"
                                                                                               Foreground="{StaticResource PrimaryTextBrush}" />
                                                                                    <TextBlock Grid.Column="1"
                                                                                               Text="{Binding UsedPercentFormatted}"
                                                                                               FontFamily="{StaticResource AppFont}"
                                                                                               FontSize="11"
                                                                                               FontWeight="SemiBold"
                                                                                               Foreground="{StaticResource SecondaryTextBrush}" />
                                                                                </Grid>

                                                                                <Grid Height="6" Margin="0,0,0,4">
                                                                                    <Border CornerRadius="3" Background="{StaticResource SubtleSurfaceStrongBrush}" />
                                                                                    <Border CornerRadius="3"
                                                                                            Background="{Binding BarBrush}"
                                                                                            Opacity="0.8"
                                                                                            HorizontalAlignment="Left">
                                                                                        <Border.Width>
                                                                                            <MultiBinding Converter="{StaticResource PropToActualWidth}">
                                                                                                <Binding Path="Proportion" />
                                                                                                <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth" />
                                                                                            </MultiBinding>
                                                                                        </Border.Width>
                                                                                    </Border>
                                                                                </Grid>

                                                                                <Grid>
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="*" />
                                                                                        <ColumnDefinition Width="Auto" />
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <TextBlock Grid.Column="0"
                                                                                               Text="{Binding ResetText}"
                                                                                               FontFamily="{StaticResource AppFont}"
                                                                                               FontSize="10"
                                                                                               Foreground="{StaticResource TertiaryTextBrush}" />
                                                                                    <TextBlock Grid.Column="1"
                                                                                               Text="{Binding Detail}"
                                                                                               FontFamily="{StaticResource AppFont}"
                                                                                               FontSize="10"
                                                                                               Foreground="{StaticResource SecondaryTextBrush}">
                                                                                        <TextBlock.Style>
                                                                                            <Style TargetType="TextBlock">
                                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                                <Style.Triggers>
                                                                                                    <DataTrigger Binding="{Binding HasDetail}" Value="True">
                                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                                    </DataTrigger>
                                                                                                </Style.Triggers>
                                                                                            </Style>
                                                                                        </TextBlock.Style>
                                                                                    </TextBlock>
                                                                                </Grid>
                                                                            </StackPanel>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </Border>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <ItemsControl ItemsSource="{Binding LimitWindows}"
                                              Visibility="{Binding ShowSharedLimitWindows, Converter={StaticResource BoolToVis}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:ProviderLimitWindowViewModel}">
                                            <StackPanel Margin="0,0,0,10">
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Label}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource PrimaryTextBrush}" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding UsedPercentFormatted}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource SecondaryTextBrush}" />
                                                </Grid>

                                                <Grid Height="6" Margin="0,0,0,4">
                                                    <Border CornerRadius="3" Background="{StaticResource SubtleSurfaceStrongBrush}" />
                                                    <Border CornerRadius="3"
                                                            Background="{Binding BarBrush}"
                                                            Opacity="0.8"
                                                            HorizontalAlignment="Left">
                                                        <Border.Width>
                                                            <MultiBinding Converter="{StaticResource PropToActualWidth}">
                                                                <Binding Path="Proportion" />
                                                                <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth" />
                                                            </MultiBinding>
                                                        </Border.Width>
                                                    </Border>
                                                </Grid>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding ResetText}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="10"
                                                               Foreground="{StaticResource TertiaryTextBrush}" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Detail}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="10"
                                                               Foreground="{StaticResource SecondaryTextBrush}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasDetail}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="{Binding LimitSummary}"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="11"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,6"
                                           Visibility="{Binding HasLimitSummary, Converter={StaticResource BoolToVis}}" />

                                <TextBlock Text="{Binding LimitStatusMessage}"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="11"
                                           Foreground="{StaticResource TertiaryTextBrush}"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding HasLimitStatusMessage, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                        </Border>

                        <!-- ── 7-DAY + 30-DAY side-by-side ── -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0">
                                <StackPanel>
                                    <TextBlock Text="{Binding WeeklyLabel}" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Text="{Binding WeeklyTotalTokensFormatted}"
                                               Style="{StaticResource ValueTextStyle}" FontSize="18" />
                                    <TextBlock Text="tokens" Style="{StaticResource LabelTextStyle}" Margin="0,0,0,6" />
                                    <TextBlock Text="{Binding WeeklyAvgPerDayFormatted}"
                                               Style="{StaticResource StatValueStyle}" FontSize="12" />
                                    <TextBlock Style="{StaticResource LabelTextStyle}" Margin="0,0,0,4">
                                        <Run Text="{Binding WeeklyCostFormatted, Mode=OneWay}" />
                                        <Run Text=" API equiv." />
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="0">
                                <StackPanel>
                                    <TextBlock Text="{Binding MonthlyLabel}" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Text="{Binding MonthlyTotalTokensFormatted}"
                                               Style="{StaticResource ValueTextStyle}" FontSize="18" />
                                    <TextBlock Text="tokens" Style="{StaticResource LabelTextStyle}" Margin="0,0,0,6" />
                                    <TextBlock Text="{Binding MonthlyAvgPerDayFormatted}"
                                               Style="{StaticResource StatValueStyle}" FontSize="12" />
                                    <TextBlock Style="{StaticResource LabelTextStyle}" Margin="0,0,0,4">
                                        <Run Text="{Binding MonthlyCostFormatted, Mode=OneWay}" />
                                        <Run Text=" API equiv." />
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- ── LOCAL DAILY ACTIVITY (7-day bars) ── -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="LOCAL DAILY ACTIVITY" Style="{StaticResource SectionHeaderStyle}" />
                                <ItemsControl ItemsSource="{Binding DailyBars}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="7" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:DailyBarViewModel}">
                                            <StackPanel HorizontalAlignment="Center" Margin="2,0">
                                                <Grid Height="50" VerticalAlignment="Bottom">
                                                    <Border CornerRadius="3"
                                                            Background="{StaticResource SubtleSurfaceMutedBrush}"
                                                            VerticalAlignment="Stretch" />
                                                    <Border CornerRadius="3"
                                                            Background="{Binding BarBrush}"
                                                            Opacity="0.75"
                                                            VerticalAlignment="Bottom"
                                                            Height="{Binding BarHeight}" />
                                                </Grid>
                                                <TextBlock Text="{Binding DayLabel}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="9"
                                                           Foreground="{StaticResource TertiaryTextBrush}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,4,0,0" />
                                                <TextBlock Text="{Binding TokensFormatted}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="8"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- ── LOCAL MODEL BREAKDOWN ── -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="LOCAL MODELS" Style="{StaticResource SectionHeaderStyle}" />
                                <ItemsControl ItemsSource="{Binding ModelBreakdown}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:ModelUsageViewModel}">
                                            <Grid Margin="0,0,0,8">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid Grid.Row="0" Margin="0,0,0,3">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding ModelName}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="11"
                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding TotalTokensFormatted}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource SecondaryTextBrush}" />
                                                </Grid>
                                                <Grid Grid.Row="1">
                                                    <Border CornerRadius="3" Height="5"
                                                            Background="{StaticResource SubtleSurfaceStrongBrush}" />
                                                    <Border CornerRadius="3" Height="5"
                                                            Background="{Binding BarBrush}"
                                                            Opacity="0.7"
                                                            HorizontalAlignment="Left"
                                                            Width="{Binding Proportion, Converter={StaticResource PropToWidth}, ConverterParameter=310}" />
                                                </Grid>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="No model data"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="11"
                                           Foreground="{StaticResource TertiaryTextBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,4">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ModelBreakdown.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0">
                                <StackPanel>
                                    <TextBlock Text="SURFACES" Style="{StaticResource SectionHeaderStyle}" />
                                    <ItemsControl ItemsSource="{Binding SurfaceBreakdown}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:UsageBreakdownEntryViewModel}">
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid Grid.Row="0" Margin="0,0,0,3">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding Label}"
                                                                   FontFamily="{StaticResource AppFont}"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding ValueText}"
                                                                   FontFamily="{StaticResource AppFont}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource SecondaryTextBrush}" />
                                                    </Grid>
                                                    <Grid Grid.Row="1">
                                                        <Border CornerRadius="3" Height="5"
                                                                Background="{StaticResource SubtleSurfaceStrongBrush}" />
                                                        <Border CornerRadius="3" Height="5"
                                                                Background="{Binding BarBrush}"
                                                                Opacity="0.7"
                                                                HorizontalAlignment="Left"
                                                                Width="{Binding Proportion, Converter={StaticResource PropToWidth}, ConverterParameter=145}" />
                                                    </Grid>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="No surface data"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="11"
                                               Foreground="{StaticResource TertiaryTextBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,4"
                                               Visibility="{Binding HasSurfaceBreakdown, Converter={StaticResource InverseBoolToVis}}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="0">
                                <StackPanel>
                                    <TextBlock Text="ACCOUNTS" Style="{StaticResource SectionHeaderStyle}" />
                                    <ItemsControl ItemsSource="{Binding AccountBreakdown}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:UsageBreakdownEntryViewModel}">
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid Grid.Row="0" Margin="0,0,0,3">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding Label}"
                                                                   FontFamily="{StaticResource AppFont}"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding ValueText}"
                                                                   FontFamily="{StaticResource AppFont}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource SecondaryTextBrush}" />
                                                    </Grid>
                                                    <Grid Grid.Row="1">
                                                        <Border CornerRadius="3" Height="5"
                                                                Background="{StaticResource SubtleSurfaceStrongBrush}" />
                                                        <Border CornerRadius="3" Height="5"
                                                                Background="{Binding BarBrush}"
                                                                Opacity="0.7"
                                                                HorizontalAlignment="Left"
                                                                Width="{Binding Proportion, Converter={StaticResource PropToWidth}, ConverterParameter=145}" />
                                                    </Grid>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="No account data"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="11"
                                               Foreground="{StaticResource TertiaryTextBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,4"
                                               Visibility="{Binding HasAccountBreakdown, Converter={StaticResource InverseBoolToVis}}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="CONVERSATIONS" Style="{StaticResource SectionHeaderStyle}" Margin="0" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ConversationStatsSummaryText}"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="10.5"
                                               Foreground="{StaticResource TertiaryTextBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="300" />
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="88" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="86" />
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="74" />
                                        <ColumnDefinition Width="56" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Started" FontFamily="{StaticResource AppFont}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TertiaryTextBrush}" />
                                    <TextBlock Grid.Column="1" Text="Session / context" FontFamily="{StaticResource AppFont}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TertiaryTextBrush}" />
                                    <TextBlock Grid.Column="2" Text="Span / active" FontFamily="{StaticResource AppFont}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TertiaryTextBrush}" />
                                    <TextBlock Grid.Column="3" Text="Turns" FontFamily="{StaticResource AppFont}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TertiaryTextBrush}" />
                                    <TextBlock Grid.Column="4" Text="Tokens" FontFamily="{StaticResource AppFont}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TertiaryTextBrush}" HorizontalAlignment="Right" />
                                    <TextBlock Grid.Column="5" Text="Compacts" FontFamily="{StaticResource AppFont}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TertiaryTextBrush}" HorizontalAlignment="Right" />
                                </Grid>
                                <ItemsControl ItemsSource="{Binding Conversations}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:ConversationUsageViewModel}">
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="88" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="86" />
                                                    <ColumnDefinition Width="72" />
                                                    <ColumnDefinition Width="74" />
                                                    <ColumnDefinition Width="56" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding StartedText}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="10.5"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           Margin="0,0,8,0" />
                                                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding TitleText}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding SessionText}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="9.5"
                                                               Foreground="{StaticResource TertiaryTextBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding RepositoryText}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="10"
                                                               Foreground="{StaticResource SecondaryTextBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding ModelsText}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="10"
                                                               Foreground="{StaticResource TertiaryTextBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding DurationText}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="10.5"
                                                               Foreground="{StaticResource SecondaryTextBrush}" />
                                                    <TextBlock Text="{Binding ActiveDurationText}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="9.5"
                                                               Foreground="{StaticResource TertiaryTextBrush}" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding TurnsText}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="10.5"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           Margin="0,0,8,0" />
                                                <TextBlock Grid.Column="4"
                                                           Text="{Binding TokensText}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="10.5"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           HorizontalAlignment="Right"
                                                           Margin="0,0,8,0" />
                                                <TextBlock Grid.Column="5"
                                                           Text="{Binding CompactCountText}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="10.5"
                                                           Foreground="{StaticResource TertiaryTextBrush}"
                                                           HorizontalAlignment="Right" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="No conversations in the selected range"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="11"
                                           Foreground="{StaticResource TertiaryTextBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,4"
                                           Visibility="{Binding HasConversationStats, Converter={StaticResource InverseBoolToVis}}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="ROLLUPS" Style="{StaticResource SectionHeaderStyle}" Margin="0" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Style="{StaticResource LinkButtonStyle}"
                                                Command="{Binding CopySelectedEventJsonCommand}"
                                                Margin="0,0,6,0">
                                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10.5" Text="Copy JSON" />
                                        </Button>
                                        <Button Style="{StaticResource LinkButtonStyle}"
                                                Command="{Binding CopySelectedEventCommand}"
                                                Margin="0,0,6,0">
                                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10.5" Text="Copy row" />
                                        </Button>
                                        <WrapPanel>
                                        <ToggleButton Style="{StaticResource RangeChipStyle}"
                                                      IsChecked="{Binding IsMostRecentSortSelected, Mode=OneWay}"
                                                      Click="OnEventSortChipClick"
                                                      Tag="MostRecent">
                                            <TextBlock Text="Recent" />
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource RangeChipStyle}"
                                                      IsChecked="{Binding IsMostTokensSortSelected, Mode=OneWay}"
                                                      Click="OnEventSortChipClick"
                                                      Tag="MostTokens">
                                            <TextBlock Text="Tokens" />
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource RangeChipStyle}"
                                                      IsChecked="{Binding IsHighestCostSortSelected, Mode=OneWay}"
                                                      Click="OnEventSortChipClick"
                                                      Tag="HighestCost">
                                            <TextBlock Text="API equiv." />
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource RangeChipStyle}"
                                                      IsChecked="{Binding IsModelSortSelected, Mode=OneWay}"
                                                      Click="OnEventSortChipClick"
                                                      Tag="Model"
                                                      Margin="0">
                                            <TextBlock Text="Model" />
                                        </ToggleButton>
                                        </WrapPanel>
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="76" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="94" />
                                        <ColumnDefinition Width="94" />
                                        <ColumnDefinition Width="68" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Time"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TertiaryTextBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Text="Model"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TertiaryTextBrush}" />
                                    <TextBlock Grid.Column="2"
                                               Text="Surface"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TertiaryTextBrush}" />
                                    <TextBlock Grid.Column="3"
                                               Text="Account"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TertiaryTextBrush}" />
                                    <TextBlock Grid.Column="4"
                                               Text="Tokens"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TertiaryTextBrush}"
                                               HorizontalAlignment="Right" />
                                    <TextBlock Grid.Column="5"
                                               Text="API equiv."
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TertiaryTextBrush}"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <ListBox ItemsSource="{Binding RecentActivity}"
                                         SelectedItem="{Binding SelectedEvent, Mode=TwoWay}"
                                         Style="{StaticResource EventTableListBoxStyle}"
                                         ItemContainerStyle="{StaticResource EventTableItemStyle}"
                                         BorderThickness="0"
                                         MaxHeight="220">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:RecentUsageItemViewModel}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="76" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="94" />
                                                    <ColumnDefinition Width="94" />
                                                    <ColumnDefinition Width="68" />
                                                    <ColumnDefinition Width="60" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding TimestampText}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource TertiaryTextBrush}"
                                                           Margin="0,0,8,0"
                                                           VerticalAlignment="Top" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Title}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource PrimaryTextBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,0,8,0" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding SurfaceText}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,0,8,0" />
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding AccountText}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,0,8,0" />
                                                <TextBlock Grid.Column="4"
                                                           Text="{Binding TokensText}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="10.5"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           HorizontalAlignment="Right"
                                                           Margin="0,0,8,0"
                                                           VerticalAlignment="Top" />
                                                <TextBlock Grid.Column="5"
                                                           Text="{Binding CostText}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="10.5"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Top" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock Text="No rollups in the selected range"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="11"
                                           Foreground="{StaticResource TertiaryTextBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,4"
                                           Visibility="{Binding HasRecentActivity, Converter={StaticResource InverseBoolToVis}}" />
                                <Border Background="{StaticResource SubtleSurfaceMutedBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12"
                                        Margin="0,8,0,0"
                                        Visibility="{Binding HasSelectedEvent, Converter={StaticResource BoolToVis}}">
                                    <StackPanel DataContext="{Binding SelectedEvent}">
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Selected Rollup"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="10"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource TertiaryTextBrush}" />
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Button Style="{StaticResource LinkButtonStyle}"
                                                        Command="{Binding DataContext.CopySelectedEventJsonCommand, RelativeSource={RelativeSource AncestorType=Border}}"
                                                        Margin="0,0,6,0">
                                                    <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10.5" Text="JSON" />
                                                </Button>
                                                <TextBlock Text="{Binding MetricText}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="10.5"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Text="{Binding ModelText}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryTextBrush}" />
                                        <TextBlock Text="{Binding TimestampLocalText}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   Margin="0,2,0,0" />
                                        <TextBlock Text="{Binding TimestampUtcText}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TertiaryTextBrush}"
                                                   Margin="0,1,0,0" />
                                        <WrapPanel Margin="0,10,0,0">
                                            <Button Style="{StaticResource LinkButtonStyle}"
                                                    Command="{Binding DataContext.FilterToSelectedModelCommand, RelativeSource={RelativeSource AncestorType=Border}}"
                                                    Margin="0,0,6,6">
                                                <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10.5" Text="Use Model" />
                                            </Button>
                                            <Button Style="{StaticResource LinkButtonStyle}"
                                                    Command="{Binding DataContext.FilterToSelectedSurfaceCommand, RelativeSource={RelativeSource AncestorType=Border}}"
                                                    Margin="0,0,6,6">
                                                <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10.5" Text="Use Surface" />
                                            </Button>
                                            <Button Style="{StaticResource LinkButtonStyle}"
                                                    Command="{Binding DataContext.FilterToSelectedAccountCommand, RelativeSource={RelativeSource AncestorType=Border}}"
                                                    Margin="0,0,0,6">
                                                <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10.5" Text="Use Account" />
                                            </Button>
                                        </WrapPanel>
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock Text="Surface"
                                                           Style="{StaticResource LabelTextStyle}" />
                                                <TextBlock Text="{Binding SurfaceText}"
                                                           Style="{StaticResource StatValueStyle}"
                                                           FontSize="12" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Account"
                                                           Style="{StaticResource LabelTextStyle}" />
                                                <TextBlock Text="{Binding AccountText}"
                                                           Style="{StaticResource StatValueStyle}"
                                                           FontSize="12" />
                                            </StackPanel>
                                        </Grid>
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                                                <TextBlock Text="Tokens" Style="{StaticResource LabelTextStyle}" />
                                                <TextBlock Text="{Binding TokensText}" Style="{StaticResource StatValueStyle}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                                                <TextBlock Text="Input" Style="{StaticResource LabelTextStyle}" />
                                                <TextBlock Text="{Binding InputText}" Style="{StaticResource StatValueStyle}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,8">
                                                <TextBlock Text="Output" Style="{StaticResource LabelTextStyle}" />
                                                <TextBlock Text="{Binding OutputText}" Style="{StaticResource StatValueStyle}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="0">
                                                <TextBlock Text="Cached" Style="{StaticResource LabelTextStyle}" />
                                                <TextBlock Text="{Binding CachedText}" Style="{StaticResource StatValueStyle}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="1">
                                                <TextBlock Text="Reasoning" Style="{StaticResource LabelTextStyle}" />
                                                <TextBlock Text="{Binding ReasoningText}" Style="{StaticResource StatValueStyle}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="2">
                                                <TextBlock Text="API equiv." Style="{StaticResource LabelTextStyle}" />
                                                <TextBlock Text="{Binding CostText}" Style="{StaticResource StatValueStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- ── GITHUB CONTENT (GitHub tab selected) ── -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              DataContext="{Binding GitHub}"
                              Visibility="{Binding DataContext.ShowGitHubContent, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                    <StackPanel Margin="16,12,16,8">

                        <!-- Loading state -->
                        <TextBlock Text="Loading GitHub data..."
                                   FontFamily="{StaticResource AppFont}"
                                   FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,20"
                                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

                        <Border Background="{StaticResource CardBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12,10"
                                Margin="0,0,0,10"
                                Visibility="{Binding ShowCompactIdentityBar, Converter={StaticResource BoolToVis}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="ACTIVE PROFILE"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="10.5"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource SecondaryTextBrush}" />
                                    <TextBlock Text="{Binding CompactIdentityText}"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="11.5"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Style="{StaticResource RefreshButtonStyle}"
                                        Click="OnShowGitHubAccountEditorClick"
                                        Margin="8,0,0,0">
                                    <TextBlock FontFamily="{StaticResource AppFont}"
                                               FontSize="10.5"
                                               Text="Change" />
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Username input + profile chooser -->
                        <Border Background="{StaticResource CardBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="12" Padding="16"
                                Margin="0,0,0,10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowUsernameInput}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="{Binding UsernameEditorTitle}"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Margin="0,0,0,6" />
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
