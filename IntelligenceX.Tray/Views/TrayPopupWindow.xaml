                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                        <TextBlock Style="{StaticResource LabelTextStyle}" Text="Stars" />
                                        <TextBlock Text="{Binding TrackedStarsFormatted}"
                                                   Style="{StaticResource StatValueStyle}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                        <TextBlock Style="{StaticResource LabelTextStyle}" Text="Forks" />
                                        <TextBlock Text="{Binding TrackedForksFormatted}"
