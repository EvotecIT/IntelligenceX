                                                Margin="0,0,6,0">
                                            <TextBlock Text="{Binding DataContext.CodexDiagnosticsActionLabel, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
                                        </Button>
                                        <Button Style="{StaticResource LinkButtonStyle}"
                                                Command="{Binding DataContext.RepairCodexPathsCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                ToolTip="Back up and repair active Codex thread paths"
                                                AutomationProperties.Name="Repair Codex thread paths"
                                                Margin="0,0,6,0">
                                            <TextBlock Text="{Binding DataContext.CodexDiagnosticsRepairActionLabel, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
                                        </Button>
                                        <Button Style="{StaticResource LinkButtonStyle}"
                                                Command="{Binding DataContext.CleanUpCodexStateCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                ToolTip="Back up, repair paths, archive stale sessions, and rotate old logs"
                                                AutomationProperties.Name="Clean up Codex local state"
                                                Margin="0,0,6,0">
                                            <TextBlock Text="{Binding DataContext.CodexDiagnosticsCleanupActionLabel, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
                                        </Button>
                                        <Button Style="{StaticResource LinkButtonStyle}"
                                                Command="{Binding DataContext.OpenCodexHomeCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                ToolTip="Open Codex home"
                                                AutomationProperties.Name="Open Codex home">
                                            <TextBlock Text="Open home" />
                                        </Button>
                                    </WrapPanel>
                                </Grid>

                                <UniformGrid Columns="4" Margin="0,0,0,10">
                                    <Border CornerRadius="10"
                                            Background="{StaticResource SubtleSurfaceMutedBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            Padding="10,8"
                                            Margin="0,0,6,0">
                                        <StackPanel>
                                            <TextBlock Text="Threads" Style="{StaticResource LabelTextStyle}" />
                                            <TextBlock Text="{Binding DataContext.CodexDiagnosticsThreadMetricText, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                       Style="{StaticResource StatValueStyle}"
                                                       FontSize="18" />
                                        </StackPanel>
                                    </Border>
                                    <Border CornerRadius="10"
                                            Background="{StaticResource SubtleSurfaceMutedBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            Padding="10,8"
                                            Margin="2,0,4,0">
                                        <StackPanel>
                                            <TextBlock Text="Paths" Style="{StaticResource LabelTextStyle}" />
                                            <TextBlock Text="{Binding DataContext.CodexDiagnosticsPathMetricText, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>
                                    <Border CornerRadius="10"
                                            Background="{StaticResource SubtleSurfaceMutedBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            Padding="10,8"
                                            Margin="4,0,2,0">
                                        <StackPanel>
                                            <TextBlock Text="Metadata" Style="{StaticResource LabelTextStyle}" />
                                            <TextBlock Text="{Binding DataContext.CodexDiagnosticsMetadataMetricText, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                       Style="{StaticResource StatValueStyle}"
                                                       FontSize="18" />
                                        </StackPanel>
                                    </Border>
                                    <Border CornerRadius="10"
                                            Background="{StaticResource SubtleSurfaceMutedBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            Padding="10,8"
                                            Margin="6,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="SQLite" Style="{StaticResource LabelTextStyle}" />
                                            <TextBlock Text="{Binding DataContext.CodexDiagnosticsIntegrityText, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <Border CornerRadius="10"
                                        Background="{StaticResource InsetPanelBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        Padding="10,8"
                                        Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Padding="8,4"
                                                CornerRadius="10"
                                                Background="{StaticResource SubtleSurfaceEmphasisBrush}"
                                                Margin="0,0,10,0"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="{Binding DataContext.CodexDiagnosticsPrimaryFindingLabel, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="10.5"
                                                       FontWeight="SemiBold"
                                                       Foreground="{Binding DataContext.CodexDiagnosticsPrimaryFindingBrush, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DataContext.CodexDiagnosticsPrimaryFindingText, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap" />
                                    </Grid>
                                </Border>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            CornerRadius="10"
                                            Background="{StaticResource SubtleSurfaceMutedBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            Padding="10,8"
                                            Margin="0,0,5,0">
                                        <StackPanel>
                                            <TextBlock Text="STORAGE"
                                                       Style="{StaticResource SectionHeaderStyle}"
                                                       Margin="0,0,0,6" />
                                            <ItemsControl ItemsSource="{Binding DataContext.CodexDiagnosticsAreas, RelativeSource={RelativeSource AncestorType={x:Type Window}}}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,7">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Label}"
                                                                           FontFamily="{StaticResource AppFont}"
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{StaticResource PrimaryTextBrush}" />
                                                                <TextBlock Text="{Binding Recommendation}"
                                                                           FontFamily="{StaticResource AppFont}"
                                                                           FontSize="10"
                                                                           Foreground="{StaticResource TertiaryTextBrush}"
                                                                           TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1"
                                                                        HorizontalAlignment="Right"
                                                                        Margin="8,0,0,0">
                                                                <TextBlock Text="{Binding SizeText}"
                                                                           FontFamily="{StaticResource AppFont}"
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{StaticResource PrimaryTextBrush}"
                                                                           HorizontalAlignment="Right" />
                                                                <TextBlock Text="{Binding FileCountText}"
                                                                           FontFamily="{StaticResource AppFont}"
                                                                           FontSize="10"
                                                                           Foreground="{StaticResource TertiaryTextBrush}"
                                                                           HorizontalAlignment="Right" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1"
                                            CornerRadius="10"
                                            Background="{StaticResource SubtleSurfaceMutedBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            Padding="10,8"
                                            Margin="5,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="FINDINGS"
                                                       Style="{StaticResource SectionHeaderStyle}"
                                                       Margin="0,0,0,6" />
                                            <ItemsControl ItemsSource="{Binding DataContext.CodexDiagnosticsFindings, RelativeSource={RelativeSource AncestorType={x:Type Window}}}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,7">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Border Padding="6,3"
                                                                    CornerRadius="8"
                                                                    Background="{StaticResource InsetPanelBrush}"
                                                                    Margin="0,0,8,0"
                                                                    VerticalAlignment="Top">
                                                                <TextBlock Text="{Binding SeverityLabel}"
                                                                           FontFamily="{StaticResource AppFont}"
                                                                           FontSize="9.5"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{Binding SeverityBrush}" />
                                                            </Border>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding Message}"
                                                                       FontFamily="{StaticResource AppFont}"
                                                                       FontSize="10.5"
                                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                                       TextWrapping="Wrap" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}" Padding="14,12">
                            <StackPanel>
                                <Grid Margin="0,0,0,9">
                                    <TextBlock Text="TOKEN MIX"
                                               Style="{StaticResource SectionHeaderStyle}"
                                               Margin="0" />
                                    <TextBlock Text="{Binding PulseTokenMixText}"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="10.5"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               HorizontalAlignment="Right"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="330" />
                                </Grid>
                                <Grid x:Name="TokenMixTrack" Height="16" Margin="0,0,0,10">
                                    <Border CornerRadius="7" Background="{StaticResource SubtleSurfaceStrongBrush}" />
                                    <StackPanel Orientation="Horizontal" ClipToBounds="True">
                                        <Border Height="16" CornerRadius="8,0,0,8" Background="{StaticResource PulseFreshBrush}">
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource PropToActualWidth}">
                                                    <Binding Path="PulseFreshInputProportion" />
                                                    <Binding ElementName="TokenMixTrack" Path="ActualWidth" />
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                        <Border Height="16" Background="{StaticResource PulseCachedBrush}">
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource PropToActualWidth}">
                                                    <Binding Path="PulseCachedInputProportion" />
                                                    <Binding ElementName="TokenMixTrack" Path="ActualWidth" />
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                        <Border Height="16" Background="{StaticResource PulseOutputBrush}">
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource PropToActualWidth}">
                                                    <Binding Path="PulseOutputProportion" />
                                                    <Binding ElementName="TokenMixTrack" Path="ActualWidth" />
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                        <Border Height="16" CornerRadius="0,8,8,0" Background="{StaticResource PulseReasoningBrush}">
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource PropToActualWidth}">
                                                    <Binding Path="PulseReasoningProportion" />
                                                    <Binding ElementName="TokenMixTrack" Path="ActualWidth" />
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                                <UniformGrid Columns="4">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Fill="{StaticResource PulseFreshBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <TextBlock Text="{Binding PulseFreshInputPercentText, StringFormat=Fresh {0}}" Style="{StaticResource LabelTextStyle}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Fill="{StaticResource PulseCachedBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <TextBlock Text="{Binding PulseCachedInputPercentText, StringFormat=Cached {0}}" Style="{StaticResource LabelTextStyle}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Fill="{StaticResource PulseOutputBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <TextBlock Text="{Binding PulseOutputPercentText, StringFormat=Output {0}}" Style="{StaticResource LabelTextStyle}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Fill="{StaticResource PulseReasoningBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <TextBlock Text="{Binding PulseReasoningPercentText, StringFormat=Reasoning {0}}" Style="{StaticResource LabelTextStyle}" />
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}" Padding="14,12">
                            <StackPanel>
                                <TextBlock Text="TOP MODELS"
                                           Style="{StaticResource SectionHeaderStyle}"
                                           Margin="0,0,0,8" />
                                <ItemsControl ItemsSource="{Binding PulseTopModels}"
                                              AlternationCount="4">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:ModelUsageViewModel}">
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="20" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="52" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding RankText}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource SecondaryTextBrush}" />
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding ModelName}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <Grid Height="6" Margin="0,4,14,0">
                                                        <Border CornerRadius="3" Background="{StaticResource SubtleSurfaceStrongBrush}" />
                                                        <Border CornerRadius="3"
                                                                HorizontalAlignment="Left"
                                                                Background="{Binding BarBrush}">
                                                            <Border.Width>
                                                                <Binding Path="Proportion" Converter="{StaticResource PropToWidth}" ConverterParameter="310" />
                                                            </Border.Width>
                                                        </Border>
                                                    </Grid>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding TotalTokensFormatted}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           Margin="8,0,0,0" />
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding SharePercentText}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           TextAlignment="Right"
                                                           HorizontalAlignment="Right"
                                                           Margin="12,0,0,0" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="No model activity in the selected pulse window."
                                           Style="{StaticResource LabelTextStyle}"
                                           Visibility="{Binding HasPulseTopModels, Converter={StaticResource InverseBoolToVis}}" />
                            </StackPanel>
                        </Border>

                        <UniformGrid Columns="3" Margin="0,0,0,10">
                            <Button Style="{StaticResource RefreshButtonStyle}"
                                    Command="{Binding OpenDetailedReportCommand}"
                                    Margin="0,0,7,0"
                                    Padding="14,10">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Viewbox Width="16" Height="16" Margin="0,0,8,0">
                                        <Path Data="{StaticResource IconDocument}" Fill="{StaticResource InfoBrush}" Stretch="Uniform" />
                                    </Viewbox>
                                    <TextBlock Text="Open report" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RefreshButtonStyle}"
                                    Command="{Binding ExportJsonCommand}"
                                    Margin="3,0"
                                    Padding="14,10">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Viewbox Width="16" Height="16" Margin="0,0,8,0">
                                        <Path Data="{StaticResource IconDownload}" Fill="{StaticResource CyanBrush}" Stretch="Uniform" />
                                    </Viewbox>
                                    <TextBlock Text="Export" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RefreshButtonStyle}"
                                    Click="OnDetailsToggleClick"
                                    AutomationProperties.Name="{Binding DetailsButtonText}"
                                    Margin="7,0,0,0"
                                    Padding="14,10">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Viewbox Width="16" Height="16" Margin="0,0,8,0">
                                        <Path Data="{StaticResource IconList}" Fill="{StaticResource PurpleBrush}" Stretch="Uniform" />
                                    </Viewbox>
                                    <TextBlock Text="{Binding DetailsButtonText}" />
                                </StackPanel>
                            </Button>
                        </UniformGrid>

                        <Border x:Name="ProviderDetailsCard"
                                Style="{StaticResource CardStyle}"
                                Padding="12"
                                Visibility="{Binding IsDetailsOpen, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <WrapPanel>
                                        <ToggleButton Style="{StaticResource RangeChipStyle}"
                                                      IsChecked="{Binding IsDetailsActivitySelected, Mode=OneWay}"
                                                      Click="OnDetailsModeClick"
                                                      Tag="Activity">
                                            <TextBlock Text="Activity" />
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource RangeChipStyle}"
                                                      IsChecked="{Binding IsDetailsLimitsSelected, Mode=OneWay}"
                                                      Click="OnDetailsModeClick"
                                                      Tag="Limits">
                                            <TextBlock Text="Limits" />
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource RangeChipStyle}"
                                                      IsChecked="{Binding IsDetailsModelsSelected, Mode=OneWay}"
                                                      Click="OnDetailsModeClick"
                                                      Tag="Models">
                                            <TextBlock Text="Models" />
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource RangeChipStyle}"
                                                      IsChecked="{Binding IsDetailsEventsSelected, Mode=OneWay}"
                                                      Click="OnDetailsModeClick"
                                                      Tag="Events">
                                            <TextBlock Text="Events" />
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource RangeChipStyle}"
                                                      IsChecked="{Binding IsDetailsScopeSelected, Mode=OneWay}"
                                                      Click="OnDetailsModeClick"
                                                      Tag="Scope"
                                                      Margin="0">
                                            <TextBlock Text="Scope" />
                                        </ToggleButton>
                                    </WrapPanel>
                                    <Button Grid.Column="1"
                                            Style="{StaticResource LinkButtonStyle}"
                                            Click="OnDetailsToggleClick"
                                            AutomationProperties.Name="Collapse details"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Top">
                                        <TextBlock Text="Collapse" />
                                    </Button>
                                </Grid>

                                <StackPanel Visibility="{Binding IsDetailsActivitySelected, Converter={StaticResource BoolToVis}}">
                                    <ItemsControl ItemsSource="{Binding DailyBars}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="7" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:DailyBarViewModel}">
                                                <StackPanel HorizontalAlignment="Center" Margin="2,0">
                                                    <Grid Height="46" VerticalAlignment="Bottom">
                                                        <Border CornerRadius="4"
                                                                Width="20"
                                                                Background="{StaticResource SubtleSurfaceMutedBrush}" />
                                                        <Border CornerRadius="4"
                                                                Width="20"
                                                                Background="{Binding BarBrush}"
                                                                VerticalAlignment="Bottom"
                                                                Height="{Binding BarHeight}" />
                                                    </Grid>
                                                    <TextBlock Text="{Binding DayLabel}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="9"
                                                               Foreground="{StaticResource TertiaryTextBrush}"
                                                               HorizontalAlignment="Center"
                                                               Margin="0,4,0,0" />
                                                    <TextBlock Text="{Binding TokensFormatted}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="8.5"
                                                               Foreground="{StaticResource SecondaryTextBrush}"
                                                               HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <StackPanel Visibility="{Binding IsDetailsLimitsSelected, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding LimitStatusDisplayText}"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="11"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding HasLimitStatusDisplayText, Converter={StaticResource BoolToVis}}" />
                                    <TextBlock Text="{Binding LimitSummary}"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="11"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding HasLimitSummary, Converter={StaticResource BoolToVis}}" />
                                    <TextBlock Text="{Binding LimitAccountsOverviewText}"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="10"
                                               Foreground="{StaticResource TertiaryTextBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,5,0,0"
                                               Visibility="{Binding HasLimitAccountsOverview, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>

                                <ItemsControl ItemsSource="{Binding ModelBreakdown}"
                                              Visibility="{Binding IsDetailsModelsSelected, Converter={StaticResource BoolToVis}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:ModelUsageViewModel}">
                                            <Grid Margin="0,0,0,7">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding ModelName}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource PrimaryTextBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding TotalTokensFormatted}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="10.5"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource SecondaryTextBrush}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <ItemsControl ItemsSource="{Binding RecentActivity}"
                                              Visibility="{Binding IsDetailsEventsSelected, Converter={StaticResource BoolToVis}}">
