                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding ObservabilityLatestCaptureText}"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="10"
                                           Foreground="{StaticResource TertiaryTextBrush}"
                                           Margin="0,4,0,10"
