                                </Grid>
                            </Border>
                            <Border Background="{StaticResource CardBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="13,10"
                                    Margin="7,0,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="38" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="30" Height="30" CornerRadius="8" Background="{Binding PulseStatusPanelBrush}" VerticalAlignment="Center">
