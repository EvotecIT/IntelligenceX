                                            <Path Data="{StaticResource IconShield}" Fill="{Binding PulseStatusBrush}" Stretch="Uniform" />
                                        </Viewbox>
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Health" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Text="{Binding PulseHealthChipText}"
                                                   Style="{StaticResource StatValueStyle}"
                                                   FontSize="16"
                                                   Foreground="{Binding PulseStatusBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding PulseHealthDetailText}" Style="{StaticResource LabelTextStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
