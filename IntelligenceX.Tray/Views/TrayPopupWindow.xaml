<Window x:Class="IntelligenceX.Tray.Views.TrayPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:IntelligenceX.Tray.ViewModels"
        xmlns:conv="clr-namespace:IntelligenceX.Tray.Converters"
        Title="IntelligenceX Usage"
        Width="400" Height="640"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Deactivated="OnDeactivated">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
        <conv:ProportionToWidthConverter x:Key="PropToWidth" />
    </Window.Resources>

    <Border Background="{StaticResource BackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="14"
            Margin="6">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.6" Color="#000000" />
        </Border.Effect>

        <!-- Clip content to rounded corners -->
        <Border.Clip>
            <RectangleGeometry RadiusX="14" RadiusY="14">
                <RectangleGeometry.Rect>
                    <Rect X="0" Y="0" Width="388" Height="628" />
                </RectangleGeometry.Rect>
            </RectangleGeometry>
        </Border.Clip>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ═══ HEADER ═══ -->
            <Border Grid.Row="0" Padding="16,12,16,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="26" Height="26" CornerRadius="7" Margin="0,0,10,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#7c6ff5" Offset="0" />
                                    <GradientStop Color="#50d880" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="IX" FontFamily="{StaticResource AppFont}"
                                       FontSize="11" FontWeight="ExtraBold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <TextBlock FontFamily="{StaticResource AppFont}"
                                   FontSize="15" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   Text="{Binding HeaderTitle}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource RefreshButtonStyle}"
                                Command="{Binding ToggleSelectedProviderFavoriteCommand}"
                                IsEnabled="{Binding CanToggleFavoriteSelectedProvider}"
                                VerticalAlignment="Center"
                                Margin="0,0,6,0">
                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="11"
                                       Text="{Binding FavoriteSelectedProviderLabel}" />
                        </Button>
                        <Button Style="{StaticResource RefreshButtonStyle}"
                                Command="{Binding OpenOpenAiCacheCommand}"
                                VerticalAlignment="Center"
                                Margin="0,0,6,0">
                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="11"
                                       Text="Cache" />
                        </Button>
                        <Button Style="{StaticResource RefreshButtonStyle}"
                                Command="{Binding RefreshCommand}"
                                VerticalAlignment="Center">
                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="11"
                                       Text="Refresh" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ PROVIDER TABS ═══ -->
            <Border Grid.Row="1"
                    Background="#08ffffff"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,1"
                    Padding="6,2">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Providers}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ProviderViewModel}">
                                <RadioButton Style="{StaticResource ProviderTabStyle}"
                                             GroupName="ProviderTabs"
                                             IsChecked="{Binding IsSelected, RelativeSource={RelativeSource Self}}"
                                             Click="OnProviderTabClick"
                                             Tag="{Binding}">
                                    <StackPanel Orientation="Horizontal">
                                        <Viewbox Width="14" Height="14"
                                                 Margin="0,0,5,0"
                                                 VerticalAlignment="Center">
                                            <Path Data="{Binding IconGeometry}"
                                                  Fill="{Binding AccentBrush}"
                                                  Stretch="Uniform" />
                                        </Viewbox>
                                        <TextBlock Text="{Binding ShortName}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="★"
                                                   Margin="5,0,0,0"
                                                   FontSize="10"
                                                   Foreground="#f0c040"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVis}}" />
                                        <Border Margin="6,0,0,0"
                                                Padding="5,1"
                                                CornerRadius="8"
                                                Background="#2050d880"
                                                VerticalAlignment="Center"
                                                ToolTip="{Binding RefreshBadgeToolTip}"
                                                Visibility="{Binding HasRefreshBadge, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="{Binding RefreshBadgeText}"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="9.5"
                                                       FontWeight="Bold"
                                                       Foreground="#f3fff6"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </StackPanel>
                                </RadioButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- ═══ MAIN CONTENT ═══ -->
            <Grid Grid.Row="2">
                <!-- Loading overlay (centered, above scroll content) -->
                <TextBlock Text="Scanning providers..."
                           Foreground="{StaticResource SecondaryTextBrush}"
                           FontFamily="{StaticResource AppFont}"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

                <!-- ── USAGE CONTENT (provider tab selected) ── -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding ShowUsageContent, Converter={StaticResource BoolToVis}}">
                    <StackPanel DataContext="{Binding SelectedProvider}"
                                Margin="16,12,16,8">

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="EXPLORER RANGE" Style="{StaticResource SectionHeaderStyle}" Margin="0" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Style="{StaticResource LinkButtonStyle}"
                                                Command="{Binding OpenDetailedReportCommand}"
                                                Margin="0,0,6,0">
                                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10.5" Text="Report" />
                                        </Button>
                                        <Button Style="{StaticResource LinkButtonStyle}"
                                                Command="{Binding ExportCsvCommand}"
                                                Margin="0,0,6,0">
                                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10.5" Text="CSV" />
                                        </Button>
                                        <Button Style="{StaticResource LinkButtonStyle}"
                                                Command="{Binding ExportJsonCommand}"
                                                Margin="0,0,6,0">
                                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10.5" Text="JSON" />
                                        </Button>
                                        <Button Style="{StaticResource LinkButtonStyle}"
                                                Command="{Binding ClearFiltersCommand}"
                                                Margin="0,0,6,0">
                                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10.5" Text="Clear" />
                                        </Button>
                                        <Button Style="{StaticResource LinkButtonStyle}"
                                                Command="{Binding CopySummaryCommand}">
                                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10.5" Text="Copy" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                                <WrapPanel>
                                    <ToggleButton Style="{StaticResource RangeChipStyle}"
                                                  IsChecked="{Binding IsTodayRangeSelected, Mode=OneWay}"
                                                  Click="OnRangeChipClick"
                                                  Tag="Today">
                                        <TextBlock Text="Today" />
                                    </ToggleButton>
                                    <ToggleButton Style="{StaticResource RangeChipStyle}"
                                                  IsChecked="{Binding IsLast7DaysRangeSelected, Mode=OneWay}"
                                                  Click="OnRangeChipClick"
                                                  Tag="Last7Days">
                                        <TextBlock Text="7 days" />
                                    </ToggleButton>
                                    <ToggleButton Style="{StaticResource RangeChipStyle}"
                                                  IsChecked="{Binding IsLast30DaysRangeSelected, Mode=OneWay}"
                                                  Click="OnRangeChipClick"
                                                  Tag="Last30Days">
                                        <TextBlock Text="30 days" />
                                    </ToggleButton>
                                    <ToggleButton Style="{StaticResource RangeChipStyle}"
                                                  IsChecked="{Binding IsAllTimeRangeSelected, Mode=OneWay}"
                                                  Click="OnRangeChipClick"
                                                  Tag="AllTime"
                                                  Margin="0">
                                        <TextBlock Text="All time" />
                                    </ToggleButton>
                                </WrapPanel>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="Account"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TertiaryTextBrush}"
                                                   Margin="0,0,0,4" />
                                        <ComboBox Style="{StaticResource FilterComboBoxStyle}"
                                                  ItemsSource="{Binding AccountFilterOptions}"
                                                  SelectedItem="{Binding SelectedAccountFilter, Mode=TwoWay}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                        <TextBlock Text="Model"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TertiaryTextBrush}"
                                                   Margin="0,0,0,4" />
                                        <ComboBox Style="{StaticResource FilterComboBoxStyle}"
                                                  ItemsSource="{Binding ModelFilterOptions}"
                                                  SelectedItem="{Binding SelectedModelFilter, Mode=TwoWay}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Surface"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TertiaryTextBrush}"
                                                   Margin="0,0,0,4" />
                                        <ComboBox Style="{StaticResource FilterComboBoxStyle}"
                                                  ItemsSource="{Binding SurfaceFilterOptions}"
                                                  SelectedItem="{Binding SelectedSurfaceFilter, Mode=TwoWay}" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="Usage sections below react to the selected range, while live limits stay current."
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="10"
                                           Foreground="{StaticResource TertiaryTextBrush}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding FilteredEventCountLabel}"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="10"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Margin="0,6,0,0" />
                                <TextBlock Text="{Binding ActionStatusMessage}"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="10"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Margin="0,6,0,0"
                                           Visibility="{Binding HasActionStatusMessage, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                        </Border>

                        <!-- ── TODAY'S USAGE ── -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="{Binding TodayLabel}"
                                               Style="{StaticResource SectionHeaderStyle}"
                                               Margin="0" />
                                    <TextBlock HorizontalAlignment="Right"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="10"
                                               Foreground="{StaticResource TertiaryTextBrush}">
                                        <Run Text="{Binding TodayEventCount, Mode=OneWay}" />
                                        <Run Text=" events" />
                                    </TextBlock>
                                </Grid>

                                <!-- Total Tokens - Hero Number -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                    <TextBlock Text="{Binding TodayTotalTokensFormatted}"
                                               Style="{StaticResource ValueTextStyle}" />
                                    <TextBlock Text=" tokens"
                                               Style="{StaticResource LabelTextStyle}"
                                               VerticalAlignment="Bottom"
                                               Margin="4,0,0,4" />
                                </StackPanel>

                                <!-- Token Bars (stacked Input + Output) -->
                                <Grid Height="10" Margin="0,6,0,12">
                                    <Border CornerRadius="5" Background="#15ffffff" />
                                    <StackPanel Orientation="Horizontal">
                                        <Border CornerRadius="5,0,0,5"
                                                Height="10"
                                                MinWidth="2"
                                                Width="{Binding InputBarWidth}">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding InputColor}" Opacity="0.85" />
                                            </Border.Background>
                                        </Border>
                                        <Border CornerRadius="0,5,5,0"
                                                Height="10"
                                                MinWidth="2"
                                                Width="{Binding OutputBarWidth}">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding OutputColor}" Opacity="0.85" />
                                            </Border.Background>
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <!-- Token Breakdown Grid -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                                        <TextBlock Style="{StaticResource LabelTextStyle}" Text="Input" />
                                        <TextBlock Text="{Binding TodayInputTokensFormatted}"
                                                   Style="{StaticResource StatValueStyle}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                                        <TextBlock Style="{StaticResource LabelTextStyle}" Text="Output" />
                                        <TextBlock Text="{Binding TodayOutputTokensFormatted}"
                                                   Style="{StaticResource StatValueStyle}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,8">
                                        <TextBlock Style="{StaticResource LabelTextStyle}" Text="Cost" />
                                        <TextBlock Text="{Binding TodayCostFormatted}"
                                                   Style="{StaticResource StatValueStyle}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="0">
                                        <TextBlock Style="{StaticResource LabelTextStyle}" Text="Cached" />
                                        <TextBlock Text="{Binding TodayCachedTokensFormatted}"
                                                   Style="{StaticResource StatValueStyle}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="1">
                                        <TextBlock Style="{StaticResource LabelTextStyle}" Text="Reasoning" />
                                        <TextBlock Text="{Binding TodayReasoningTokensFormatted}"
                                                   Style="{StaticResource StatValueStyle}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}"
                                Visibility="{Binding HasProviderComparison, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="PROVIDER MIX"
                                               Style="{StaticResource SectionHeaderStyle}"
                                               Margin="0" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <ToggleButton Style="{StaticResource RangeChipStyle}"
                                                      IsChecked="{Binding IsProviderComparisonTokensSortSelected, Mode=OneWay}"
                                                      Click="OnProviderComparisonSortChipClick"
                                                      Tag="Tokens">
                                            <TextBlock Text="Tokens" />
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource RangeChipStyle}"
                                                      IsChecked="{Binding IsProviderComparisonCostSortSelected, Mode=OneWay}"
                                                      Click="OnProviderComparisonSortChipClick"
                                                      Tag="Cost">
                                            <TextBlock Text="Cost" />
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource RangeChipStyle}"
                                                      IsChecked="{Binding IsProviderComparisonEventsSortSelected, Mode=OneWay}"
                                                      Click="OnProviderComparisonSortChipClick"
                                                      Tag="Events"
                                                      Margin="0">
                                            <TextBlock Text="Events" />
                                        </ToggleButton>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="Jump into a provider from the current filtered range."
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="10"
                                           Foreground="{StaticResource TertiaryTextBrush}"
                                           Margin="0,0,0,8" />
                                <TextBlock Text="Each row now includes live limit health and movement since the last refresh."
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="10"
                                           Foreground="{StaticResource TertiaryTextBrush}"
                                           Margin="0,0,0,8" />
                                <TextBlock Text="Recent adds show the last few refresh deltas so activity stays visible across scans."
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="10"
                                           Foreground="{StaticResource TertiaryTextBrush}"
                                           Margin="0,0,0,8" />
                                <ItemsControl ItemsSource="{Binding ProviderComparison}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:ProviderComparisonEntryViewModel}">
                                            <Border Background="#10ffffff"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Margin="0,0,0,8"
                                                    Padding="10">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid Grid.Row="0" Margin="0,0,0,6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       FontFamily="{StaticResource AppFont}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource PrimaryTextBrush}" />
                                                            <TextBlock Text="{Binding EventCountText}"
                                                                       FontFamily="{StaticResource AppFont}"
                                                                       FontSize="10"
                                                                       Foreground="{StaticResource SecondaryTextBrush}" />
                                                            <TextBlock Text="{Binding HealthText}"
                                                                       FontFamily="{StaticResource AppFont}"
                                                                       FontSize="10"
                                                                       Foreground="{Binding HealthBrush}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Margin="0,2,0,0"
                                                                       MaxWidth="180" />
                                                            <TextBlock Text="{Binding DeltaText}"
                                                                       FontFamily="{StaticResource AppFont}"
                                                                       FontSize="10"
                                                                       Foreground="{Binding DeltaBrush}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Margin="0,2,0,0"
                                                                       MaxWidth="180" />
                                                            <TextBlock Text="{Binding HistoryText}"
                                                                       FontFamily="{StaticResource AppFont}"
                                                                       FontSize="10"
                                                                       Foreground="{Binding HistoryBrush}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Margin="0,2,0,0"
                                                                       MaxWidth="180" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1"
                                                                    Orientation="Horizontal"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding TokensText}"
                                                                       FontFamily="{StaticResource AppFont}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                                       Margin="0,0,10,0" />
                                                            <TextBlock Text="{Binding CostText}"
                                                                       FontFamily="{StaticResource AppFont}"
                                                                       FontSize="10.5"
                                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                                       Margin="0,0,10,0" />
                                                            <Button Style="{StaticResource LinkButtonStyle}"
                                                                    Click="OnToggleFavoriteProviderClick"
                                                                    Tag="{Binding ProviderId}"
                                                                    Margin="0,0,6,0">
                                                                <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10.5" Text="{Binding FavoriteActionText}" />
                                                            </Button>
                                                            <Button Style="{StaticResource LinkButtonStyle}"
                                                                    Click="OnProviderJumpClick"
                                                                    Tag="{Binding ProviderId}">
                                                                <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10.5" Text="Open" />
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                    <Grid Grid.Row="1">
                                                        <Border CornerRadius="3" Height="5"
                                                                Background="#12ffffff" />
                                                        <Border CornerRadius="3" Height="5"
                                                                Background="{Binding BarBrush}"
                                                                Opacity="0.8"
                                                                HorizontalAlignment="Left"
                                                                Width="{Binding Proportion, Converter={StaticResource PropToWidth}, ConverterParameter=310}" />
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- ── LIVE LIMITS ── -->
                        <Border Style="{StaticResource CardStyle}"
                                Visibility="{Binding HasLimitSection, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="LIVE LIMITS"
                                               Style="{StaticResource SectionHeaderStyle}"
                                               Margin="0" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding LimitSourceLabel}"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="10"
                                               Foreground="{StaticResource TertiaryTextBrush}" />
                                </Grid>

                                <TextBlock Text="{Binding LimitPlanLabel}"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="17"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryTextBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LimitPlanLabel}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding LimitPlanLabel}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <TextBlock Text="{Binding LimitAccountLabel}"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="11"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Margin="0,2,0,8">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LimitAccountLabel}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding LimitAccountLabel}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <ItemsControl ItemsSource="{Binding LimitWindows}"
                                              Visibility="{Binding HasLiveLimitData, Converter={StaticResource BoolToVis}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:ProviderLimitWindowViewModel}">
                                            <StackPanel Margin="0,0,0,10">
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Label}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource PrimaryTextBrush}" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding UsedPercentFormatted}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource SecondaryTextBrush}" />
                                                </Grid>

                                                <Grid Height="6" Margin="0,0,0,4">
                                                    <Border CornerRadius="3" Background="#12ffffff" />
                                                    <Border CornerRadius="3"
                                                            Background="{Binding BarBrush}"
                                                            Opacity="0.8"
                                                            HorizontalAlignment="Left"
                                                            Width="{Binding Proportion, Converter={StaticResource PropToWidth}, ConverterParameter=310}" />
                                                </Grid>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding ResetText}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="10"
                                                               Foreground="{StaticResource TertiaryTextBrush}" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Detail}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="10"
                                                               Foreground="{StaticResource SecondaryTextBrush}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasDetail}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="{Binding LimitSummary}"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="11"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,6"
                                           Visibility="{Binding HasLimitSummary, Converter={StaticResource BoolToVis}}" />

                                <TextBlock Text="{Binding LimitStatusMessage}"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="11"
                                           Foreground="{StaticResource TertiaryTextBrush}"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding HasLimitStatusMessage, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                        </Border>

                        <!-- ── 7-DAY + 30-DAY side-by-side ── -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0">
                                <StackPanel>
                                    <TextBlock Text="{Binding WeeklyLabel}" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Text="{Binding WeeklyTotalTokensFormatted}"
                                               Style="{StaticResource ValueTextStyle}" FontSize="18" />
                                    <TextBlock Text="tokens" Style="{StaticResource LabelTextStyle}" Margin="0,0,0,6" />
                                    <TextBlock Text="{Binding WeeklyAvgPerDayFormatted}"
                                               Style="{StaticResource StatValueStyle}" FontSize="12" />
                                    <TextBlock Style="{StaticResource LabelTextStyle}" Margin="0,0,0,4">
                                        <Run Text="{Binding WeeklyCostFormatted, Mode=OneWay}" />
                                        <Run Text=" cost" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="0">
                                <StackPanel>
                                    <TextBlock Text="{Binding MonthlyLabel}" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Text="{Binding MonthlyTotalTokensFormatted}"
                                               Style="{StaticResource ValueTextStyle}" FontSize="18" />
                                    <TextBlock Text="tokens" Style="{StaticResource LabelTextStyle}" Margin="0,0,0,6" />
                                    <TextBlock Text="{Binding MonthlyAvgPerDayFormatted}"
                                               Style="{StaticResource StatValueStyle}" FontSize="12" />
                                    <TextBlock Style="{StaticResource LabelTextStyle}" Margin="0,0,0,4">
                                        <Run Text="{Binding MonthlyCostFormatted, Mode=OneWay}" />
                                        <Run Text=" cost" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- ── DAILY ACTIVITY (7-day bars) ── -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="DAILY ACTIVITY" Style="{StaticResource SectionHeaderStyle}" />
                                <ItemsControl ItemsSource="{Binding DailyBars}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="7" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:DailyBarViewModel}">
                                            <StackPanel HorizontalAlignment="Center" Margin="2,0">
                                                <Grid Height="50" VerticalAlignment="Bottom">
                                                    <Border CornerRadius="3"
                                                            Background="#10ffffff"
                                                            VerticalAlignment="Stretch" />
                                                    <Border CornerRadius="3"
                                                            Background="{Binding BarBrush}"
                                                            Opacity="0.75"
                                                            VerticalAlignment="Bottom"
                                                            Height="{Binding BarHeight}" />
                                                </Grid>
                                                <TextBlock Text="{Binding DayLabel}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="9"
                                                           Foreground="{StaticResource TertiaryTextBrush}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,4,0,0" />
                                                <TextBlock Text="{Binding TokensFormatted}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="8"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- ── MODEL BREAKDOWN ── -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="MODELS" Style="{StaticResource SectionHeaderStyle}" />
                                <ItemsControl ItemsSource="{Binding ModelBreakdown}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:ModelUsageViewModel}">
                                            <Grid Margin="0,0,0,8">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid Grid.Row="0" Margin="0,0,0,3">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding ModelName}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="11"
                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding TotalTokensFormatted}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource SecondaryTextBrush}" />
                                                </Grid>
                                                <Grid Grid.Row="1">
                                                    <Border CornerRadius="3" Height="5"
                                                            Background="#12ffffff" />
                                                    <Border CornerRadius="3" Height="5"
                                                            Background="{Binding BarBrush}"
                                                            Opacity="0.7"
                                                            HorizontalAlignment="Left"
                                                            Width="{Binding Proportion, Converter={StaticResource PropToWidth}, ConverterParameter=310}" />
                                                </Grid>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="No model data"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="11"
                                           Foreground="{StaticResource TertiaryTextBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,4">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ModelBreakdown.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0">
                                <StackPanel>
                                    <TextBlock Text="SURFACES" Style="{StaticResource SectionHeaderStyle}" />
                                    <ItemsControl ItemsSource="{Binding SurfaceBreakdown}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:UsageBreakdownEntryViewModel}">
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid Grid.Row="0" Margin="0,0,0,3">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding Label}"
                                                                   FontFamily="{StaticResource AppFont}"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding ValueText}"
                                                                   FontFamily="{StaticResource AppFont}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource SecondaryTextBrush}" />
                                                    </Grid>
                                                    <Grid Grid.Row="1">
                                                        <Border CornerRadius="3" Height="5"
                                                                Background="#12ffffff" />
                                                        <Border CornerRadius="3" Height="5"
                                                                Background="{Binding BarBrush}"
                                                                Opacity="0.7"
                                                                HorizontalAlignment="Left"
                                                                Width="{Binding Proportion, Converter={StaticResource PropToWidth}, ConverterParameter=145}" />
                                                    </Grid>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="No surface data"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="11"
                                               Foreground="{StaticResource TertiaryTextBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,4"
                                               Visibility="{Binding HasSurfaceBreakdown, Converter={StaticResource InverseBoolToVis}}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="0">
                                <StackPanel>
                                    <TextBlock Text="ACCOUNTS" Style="{StaticResource SectionHeaderStyle}" />
                                    <ItemsControl ItemsSource="{Binding AccountBreakdown}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:UsageBreakdownEntryViewModel}">
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid Grid.Row="0" Margin="0,0,0,3">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding Label}"
                                                                   FontFamily="{StaticResource AppFont}"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding ValueText}"
                                                                   FontFamily="{StaticResource AppFont}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource SecondaryTextBrush}" />
                                                    </Grid>
                                                    <Grid Grid.Row="1">
                                                        <Border CornerRadius="3" Height="5"
                                                                Background="#12ffffff" />
                                                        <Border CornerRadius="3" Height="5"
                                                                Background="{Binding BarBrush}"
                                                                Opacity="0.7"
                                                                HorizontalAlignment="Left"
                                                                Width="{Binding Proportion, Converter={StaticResource PropToWidth}, ConverterParameter=145}" />
                                                    </Grid>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="No account data"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="11"
                                               Foreground="{StaticResource TertiaryTextBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,4"
                                               Visibility="{Binding HasAccountBreakdown, Converter={StaticResource InverseBoolToVis}}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="EVENTS" Style="{StaticResource SectionHeaderStyle}" Margin="0" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Style="{StaticResource LinkButtonStyle}"
                                                Command="{Binding CopySelectedEventJsonCommand}"
                                                Margin="0,0,6,0">
                                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10.5" Text="Copy JSON" />
                                        </Button>
                                        <Button Style="{StaticResource LinkButtonStyle}"
                                                Command="{Binding CopySelectedEventCommand}"
                                                Margin="0,0,6,0">
                                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10.5" Text="Copy row" />
                                        </Button>
                                        <WrapPanel>
                                        <ToggleButton Style="{StaticResource RangeChipStyle}"
                                                      IsChecked="{Binding IsMostRecentSortSelected, Mode=OneWay}"
                                                      Click="OnEventSortChipClick"
                                                      Tag="MostRecent">
                                            <TextBlock Text="Recent" />
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource RangeChipStyle}"
                                                      IsChecked="{Binding IsMostTokensSortSelected, Mode=OneWay}"
                                                      Click="OnEventSortChipClick"
                                                      Tag="MostTokens">
                                            <TextBlock Text="Tokens" />
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource RangeChipStyle}"
                                                      IsChecked="{Binding IsHighestCostSortSelected, Mode=OneWay}"
                                                      Click="OnEventSortChipClick"
                                                      Tag="HighestCost">
                                            <TextBlock Text="Cost" />
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource RangeChipStyle}"
                                                      IsChecked="{Binding IsModelSortSelected, Mode=OneWay}"
                                                      Click="OnEventSortChipClick"
                                                      Tag="Model"
                                                      Margin="0">
                                            <TextBlock Text="Model" />
                                        </ToggleButton>
                                        </WrapPanel>
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="76" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="94" />
                                        <ColumnDefinition Width="94" />
                                        <ColumnDefinition Width="68" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Time"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TertiaryTextBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Text="Model"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TertiaryTextBrush}" />
                                    <TextBlock Grid.Column="2"
                                               Text="Surface"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TertiaryTextBrush}" />
                                    <TextBlock Grid.Column="3"
                                               Text="Account"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TertiaryTextBrush}" />
                                    <TextBlock Grid.Column="4"
                                               Text="Tokens"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TertiaryTextBrush}"
                                               HorizontalAlignment="Right" />
                                    <TextBlock Grid.Column="5"
                                               Text="Cost"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TertiaryTextBrush}"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <ListBox ItemsSource="{Binding RecentActivity}"
                                         SelectedItem="{Binding SelectedEvent, Mode=TwoWay}"
                                         Style="{StaticResource EventTableListBoxStyle}"
                                         ItemContainerStyle="{StaticResource EventTableItemStyle}"
                                         BorderThickness="0"
                                         MaxHeight="220">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:RecentUsageItemViewModel}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="76" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="94" />
                                                    <ColumnDefinition Width="94" />
                                                    <ColumnDefinition Width="68" />
                                                    <ColumnDefinition Width="60" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding TimestampText}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource TertiaryTextBrush}"
                                                           Margin="0,0,8,0"
                                                           VerticalAlignment="Top" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Title}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource PrimaryTextBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,0,8,0" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding SurfaceText}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,0,8,0" />
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding AccountText}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,0,8,0" />
                                                <TextBlock Grid.Column="4"
                                                           Text="{Binding TokensText}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="10.5"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           HorizontalAlignment="Right"
                                                           Margin="0,0,8,0"
                                                           VerticalAlignment="Top" />
                                                <TextBlock Grid.Column="5"
                                                           Text="{Binding CostText}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="10.5"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Top" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock Text="No events in the selected range"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="11"
                                           Foreground="{StaticResource TertiaryTextBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,4"
                                           Visibility="{Binding HasRecentActivity, Converter={StaticResource InverseBoolToVis}}" />
                                <Border Background="#10ffffff"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12"
                                        Margin="0,8,0,0"
                                        Visibility="{Binding HasSelectedEvent, Converter={StaticResource BoolToVis}}">
                                    <StackPanel DataContext="{Binding SelectedEvent}">
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Selected Event"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="10"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource TertiaryTextBrush}" />
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Button Style="{StaticResource LinkButtonStyle}"
                                                        Command="{Binding DataContext.CopySelectedEventJsonCommand, RelativeSource={RelativeSource AncestorType=Border}}"
                                                        Margin="0,0,6,0">
                                                    <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10.5" Text="JSON" />
                                                </Button>
                                                <TextBlock Text="{Binding MetricText}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="10.5"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Text="{Binding ModelText}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryTextBrush}" />
                                        <TextBlock Text="{Binding TimestampLocalText}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   Margin="0,2,0,0" />
                                        <TextBlock Text="{Binding TimestampUtcText}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TertiaryTextBrush}"
                                                   Margin="0,1,0,0" />
                                        <WrapPanel Margin="0,10,0,0">
                                            <Button Style="{StaticResource LinkButtonStyle}"
                                                    Command="{Binding DataContext.FilterToSelectedModelCommand, RelativeSource={RelativeSource AncestorType=Border}}"
                                                    Margin="0,0,6,6">
                                                <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10.5" Text="Use Model" />
                                            </Button>
                                            <Button Style="{StaticResource LinkButtonStyle}"
                                                    Command="{Binding DataContext.FilterToSelectedSurfaceCommand, RelativeSource={RelativeSource AncestorType=Border}}"
                                                    Margin="0,0,6,6">
                                                <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10.5" Text="Use Surface" />
                                            </Button>
                                            <Button Style="{StaticResource LinkButtonStyle}"
                                                    Command="{Binding DataContext.FilterToSelectedAccountCommand, RelativeSource={RelativeSource AncestorType=Border}}"
                                                    Margin="0,0,0,6">
                                                <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10.5" Text="Use Account" />
                                            </Button>
                                        </WrapPanel>
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock Text="Surface"
                                                           Style="{StaticResource LabelTextStyle}" />
                                                <TextBlock Text="{Binding SurfaceText}"
                                                           Style="{StaticResource StatValueStyle}"
                                                           FontSize="12" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Account"
                                                           Style="{StaticResource LabelTextStyle}" />
                                                <TextBlock Text="{Binding AccountText}"
                                                           Style="{StaticResource StatValueStyle}"
                                                           FontSize="12" />
                                            </StackPanel>
                                        </Grid>
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                                                <TextBlock Text="Tokens" Style="{StaticResource LabelTextStyle}" />
                                                <TextBlock Text="{Binding TokensText}" Style="{StaticResource StatValueStyle}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                                                <TextBlock Text="Input" Style="{StaticResource LabelTextStyle}" />
                                                <TextBlock Text="{Binding InputText}" Style="{StaticResource StatValueStyle}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,8">
                                                <TextBlock Text="Output" Style="{StaticResource LabelTextStyle}" />
                                                <TextBlock Text="{Binding OutputText}" Style="{StaticResource StatValueStyle}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="0">
                                                <TextBlock Text="Cached" Style="{StaticResource LabelTextStyle}" />
                                                <TextBlock Text="{Binding CachedText}" Style="{StaticResource StatValueStyle}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="1">
                                                <TextBlock Text="Reasoning" Style="{StaticResource LabelTextStyle}" />
                                                <TextBlock Text="{Binding ReasoningText}" Style="{StaticResource StatValueStyle}" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="2">
                                                <TextBlock Text="Cost" Style="{StaticResource LabelTextStyle}" />
                                                <TextBlock Text="{Binding CostText}" Style="{StaticResource StatValueStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- ── GITHUB CONTENT (GitHub tab selected) ── -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              DataContext="{Binding GitHub}"
                              Visibility="{Binding DataContext.ShowGitHubContent, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                    <StackPanel Margin="16,12,16,8">

                        <!-- Loading state -->
                        <TextBlock Text="Loading GitHub data..."
                                   FontFamily="{StaticResource AppFont}"
                                   FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,20"
                                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

                        <!-- Username input + info when no token -->
                        <Border Background="{StaticResource CardBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="12" Padding="16"
                                Margin="0,0,0,10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowUsernameInput}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="GitHub Username"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Margin="0,0,0,6" />
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding UsernameInput, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="{StaticResource AppFont}"
                                             FontSize="12"
                                             Background="#15ffffff"
                                             Foreground="{StaticResource PrimaryTextBrush}"
                                             BorderBrush="{StaticResource BorderBrush}"
                                             BorderThickness="1"
                                             Padding="8,6"
                                             CaretBrush="{StaticResource PrimaryTextBrush}">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="IsEnabled" Value="True" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                                        <Setter Property="IsEnabled" Value="False" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                    <Button Grid.Column="1"
                                            Command="{Binding DataContext.RefreshGitHubCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Margin="6,0,0,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource RefreshButtonStyle}">
                                                <Setter Property="IsEnabled" Value="True" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                                        <Setter Property="IsEnabled" Value="False" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock FontFamily="{StaticResource AppFont}" FontSize="11" Text="Load" />
                                    </Button>
                                </Grid>
                                <TextBlock Text="{Binding UsernameHelpText}"
                                           TextWrapping="Wrap"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="10"
                                           Foreground="{StaticResource TertiaryTextBrush}" />
                            </StackPanel>
                        </Border>

                        <!-- GitHub data -->
                        <StackPanel Visibility="{Binding HasData, Converter={StaticResource BoolToVis}}">

                            <!-- User login -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="GITHUB PROFILE" Style="{StaticResource SectionHeaderStyle}" Margin="0" />
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       Text="{Binding Login}"
                                                       Margin="0,0,8,0" />
                                            <Button Style="{StaticResource LinkButtonStyle}"
                                                    Click="OnOpenUrlClick"
                                                    Tag="{Binding ProfileUrl}">
                                                <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10.5" Text="Open" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                    <Grid Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding OwnedRepositoriesFormatted}"
                                                       Style="{StaticResource StatValueStyle}" FontSize="16" />
                                            <TextBlock Text="Owned repos" Style="{StaticResource LabelTextStyle}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding TotalStarsFormatted}"
                                                       Style="{StaticResource StatValueStyle}" FontSize="16" />
                                            <TextBlock Text="Stars" Style="{StaticResource LabelTextStyle}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="{Binding TotalForksFormatted}"
                                                       Style="{StaticResource StatValueStyle}" FontSize="16" />
                                            <TextBlock Text="Forks" Style="{StaticResource LabelTextStyle}" />
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Text="{Binding OrganizationRepositoriesFormatted, StringFormat=Plus {0} org repos in the repo mix}"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="10"
                                               Foreground="{StaticResource TertiaryTextBrush}"
                                               Margin="0,8,0,0"
                                               Visibility="{Binding HasOrganizationRepositories, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </Border>

                            <!-- Contribution stats 2x2 grid -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="CONTRIBUTIONS" Style="{StaticResource SectionHeaderStyle}" />
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
                                            <TextBlock Text="{Binding TotalCommitsFormatted}"
                                                       Style="{StaticResource StatValueStyle}" FontSize="18" />
                                            <TextBlock Text="Commits" Style="{StaticResource LabelTextStyle}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                                            <TextBlock Text="{Binding TotalPRsFormatted}"
                                                       Style="{StaticResource StatValueStyle}" FontSize="18" />
                                            <TextBlock Text="Pull Requests" Style="{StaticResource LabelTextStyle}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="0">
                                            <TextBlock Text="{Binding TotalReviewsFormatted}"
                                                       Style="{StaticResource StatValueStyle}" FontSize="18" />
                                            <TextBlock Text="Reviews" Style="{StaticResource LabelTextStyle}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="1">
                                            <TextBlock Text="{Binding TotalIssuesFormatted}"
                                                       Style="{StaticResource StatValueStyle}" FontSize="18" />
                                            <TextBlock Text="Issues" Style="{StaticResource LabelTextStyle}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 30-day contribution bar chart -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="30-DAY CONTRIBUTIONS" Style="{StaticResource SectionHeaderStyle}" Margin="0" />
                                        <TextBlock HorizontalAlignment="Right"
                                                   FontFamily="{StaticResource AppFont}" FontSize="10"
                                                   Foreground="{StaticResource TertiaryTextBrush}"
                                                   Text="{Binding TotalContributionsFormatted}" />
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding ContribBars}" Margin="0,0,0,4">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="30" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:GitHubContribBarViewModel}">
                                                <Grid Height="42" VerticalAlignment="Bottom" Margin="0.5,0"
                                                      ToolTip="{Binding Count}">
                                                    <Border CornerRadius="2"
                                                            Background="#08ffffff"
                                                            VerticalAlignment="Stretch" />
                                                    <Border CornerRadius="2"
                                                            Background="{Binding BarBrush}"
                                                            Opacity="0.8"
                                                            VerticalAlignment="Bottom"
                                                            Height="{Binding BarHeight}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Top repos -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="TOP REPOS" Style="{StaticResource SectionHeaderStyle}" Margin="0" />
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10"
                                                       Foreground="{StaticResource TertiaryTextBrush}"
                                                       Text="{Binding OwnedRepositoriesFormatted, StringFormat={}{0} owned}" />
                                        </StackPanel>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding TopRepos}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:GitHubRepoViewModel}">
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse Grid.Column="0" Width="8" Height="8"
                                                             Fill="{Binding LanguageBrush}"
                                                             Margin="0,0,6,0" VerticalAlignment="Center" />
                                                    <Button Grid.Column="1"
                                                            Style="{StaticResource InlineLinkButtonStyle}"
                                                            Click="OnOpenUrlClick"
                                                            Tag="{Binding RepositoryUrl}"
                                                            HorizontalAlignment="Left">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontFamily="{StaticResource AppFont}"
                                                                   FontSize="11"
                                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   VerticalAlignment="Center" />
                                                    </Button>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                                Margin="8,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="&#x2605; "
                                                                   FontFamily="{StaticResource AppFont}"
                                                                   FontSize="10"
                                                                   Foreground="#f0c040" />
                                                        <TextBlock Text="{Binding StarsFormatted}"
                                                                   FontFamily="{StaticResource AppFont}"
                                                                   FontSize="10" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource SecondaryTextBrush}" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="3" Orientation="Horizontal"
                                                                Margin="10,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="&#x2442; "
                                                                   FontFamily="{StaticResource AppFont}"
                                                                   FontSize="10"
                                                                   Foreground="{StaticResource TertiaryTextBrush}" />
                                                        <TextBlock Text="{Binding ForksFormatted}"
                                                                   FontFamily="{StaticResource AppFont}"
                                                                   FontSize="10"
                                                                   Foreground="{StaticResource SecondaryTextBrush}" />
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ═══ FOOTER ═══ -->
            <Border Grid.Row="3"
                    Background="#0affffff"
                    Padding="16,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10"
                                   Foreground="{StaticResource TertiaryTextBrush}">
                            <Run Text="Updated " />
                        </TextBlock>
                        <TextBlock Text="{Binding LastRefreshedFormatted}"
                                   FontFamily="{StaticResource AppFont}" FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                        <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10"
                                   Foreground="{StaticResource TertiaryTextBrush}"
                                   Margin="8,0,0,0"
                                   Text="•" />
                        <TextBlock Text="{Binding RefreshModeLabel}"
                                   FontFamily="{StaticResource AppFont}" FontSize="10"
                                   Margin="8,0,0,0"
                                   Foreground="{StaticResource TertiaryTextBrush}" />
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Text="{Binding StatusText}"
                               FontFamily="{StaticResource AppFont}" FontSize="10"
                               Foreground="{StaticResource TertiaryTextBrush}"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="200" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
