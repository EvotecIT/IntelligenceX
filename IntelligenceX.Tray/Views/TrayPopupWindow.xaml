                                        <TextBlock Style="{StaticResource LabelTextStyle}" Text="Commits" />
                                        <TextBlock Text="{Binding CodeChurnCommitsText}"
                                                   Style="{StaticResource StatValueStyle}" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="{Binding CodeChurnSummaryText}"
