                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding CodeUsageCorrelationSummaryText}"
