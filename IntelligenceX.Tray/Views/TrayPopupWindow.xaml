                                </Grid>
                                <WrapPanel Margin="0,0,0,8">
                                    <Border Background="{StaticResource InsetPanelBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="6,2"
                                            Margin="0,0,6,6">
                                        <TextBlock Text="{Binding PositiveStarDeltaFormatted, StringFormat={}{0} stars}"
