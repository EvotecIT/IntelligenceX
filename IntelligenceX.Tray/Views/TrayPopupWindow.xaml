                                        <TextBlock Text="Model"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TertiaryTextBrush}"
                                                   Margin="0,0,0,4" />
                                        <ComboBox Style="{StaticResource FilterComboBoxStyle}"
                                                  ItemsSource="{Binding ModelFilterOptions}"
                                                  SelectedItem="{Binding SelectedModelFilter, Mode=TwoWay}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Surface"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TertiaryTextBrush}"
