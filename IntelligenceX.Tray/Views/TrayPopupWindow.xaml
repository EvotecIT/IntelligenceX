                                                <Setter Property="IsEnabled" Value="True" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                                        <Setter Property="IsEnabled" Value="False" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock FontFamily="{StaticResource AppFont}" FontSize="11" Text="Load" />
                                    </Button>
                                    <Button Grid.Column="2"
                                            Style="{StaticResource RefreshButtonStyle}"
                                            Click="OnHideGitHubAccountEditorClick"
                                            Margin="6,0,0,0"
                                            Visibility="{Binding HasData, Converter={StaticResource BoolToVis}}">
                                        <TextBlock FontFamily="{StaticResource AppFont}" FontSize="11" Text="Done" />
                                    </Button>
                                </Grid>
                                <TextBlock Text="{Binding UsernameHelpText}"
                                           TextWrapping="Wrap"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="10"
                                           Foreground="{StaticResource TertiaryTextBrush}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}"
                                Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
