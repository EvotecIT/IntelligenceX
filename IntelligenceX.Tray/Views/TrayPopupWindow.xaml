                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Button Style="{StaticResource InlineLinkButtonStyle}"
                                                                Click="OnOpenUrlClick"
                                                                Tag="{Binding RepositoryUrl}"
                                                                HorizontalAlignment="Left">
                                                            <TextBlock Text="{Binding FullName}"
                                                                       FontFamily="{StaticResource AppFont}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </Button>
                                                        <Border Grid.Column="1"
                                                                Background="{StaticResource SubtleSurfaceEmphasisBrush}"
                                                                BorderBrush="{StaticResource BorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="8"
                                                                Padding="6,1"
                                                                Margin="8,0,0,0">
                                                            <TextBlock Text="{Binding StatusText}"
                                                                       FontFamily="{StaticResource AppFont}"
                                                                       FontSize="9.5"
                                                                       Foreground="{StaticResource SecondaryTextBrush}" />
                                                        </Border>
                                                    </Grid>
                                                    <TextBlock Text="{Binding DeltaSummaryText}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="10"
                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                               Margin="0,6,0,0" />
                                                    <TextBlock Text="{Binding CurrentMetricsText}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="10"
                                                               Foreground="{StaticResource SecondaryTextBrush}"
                                                               Margin="0,2,0,0" />
                                                    <StackPanel Margin="0,6,0,0"
                                                                Visibility="{Binding HasTrendBars, Converter={StaticResource BoolToVis}}">
                                                        <Grid Height="24">
                                                            <ItemsControl ItemsSource="{Binding TrendBars}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <UniformGrid Columns="7" />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate DataType="{x:Type vm:GitHubRepoTrendBarViewModel}">
                                                                        <Grid ToolTip="{Binding ToolTipText}">
                                                                            <Border CornerRadius="2"
                                                                                    Background="{StaticResource SectionStripBrush}"
                                                                                    VerticalAlignment="Stretch"
                                                                                    Margin="1,0" />
                                                                            <Border CornerRadius="2"
                                                                                    Background="{Binding BarBrush}"
                                                                                    Opacity="0.85"
                                                                                    VerticalAlignment="Bottom"
                                                                                    Height="{Binding Height}"
                                                                                    Margin="1,0" />
                                                                        </Grid>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </Grid>
                                                        <TextBlock Text="{Binding TrendSummaryText}"
                                                                   FontFamily="{StaticResource AppFont}"
                                                                   FontSize="9.5"
                                                                   Foreground="{StaticResource TertiaryTextBrush}"
                                                                   Margin="0,4,0,0"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding CaptureText}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="9.5"
                                                               Foreground="{StaticResource TertiaryTextBrush}"
                                                               Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="{Binding ObservabilitySetupText}"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="10"
                                           Foreground="{StaticResource TertiaryTextBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <!-- GitHub data -->
                        <StackPanel Visibility="{Binding HasData, Converter={StaticResource BoolToVis}}">

                            <!-- User login -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="GITHUB PROFILE" Style="{StaticResource SectionHeaderStyle}" Margin="0" />
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       Text="{Binding Login}"
                                                       Margin="0,0,8,0" />
                                            <Button Style="{StaticResource LinkButtonStyle}"
                                                    Click="OnOpenUrlClick"
                                                    Tag="{Binding ProfileUrl}">
                                                <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10.5" Text="Open" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                    <StackPanel Margin="0,0,0,10">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   Visibility="{Binding HasDisplayName, Converter={StaticResource BoolToVis}}" />
                                        <TextBlock Text="{Binding Bio}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="10.5"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   Margin="0,4,0,0"
                                                   Visibility="{Binding HasBio, Converter={StaticResource BoolToVis}}" />
                                        <WrapPanel Margin="0,8,0,0">
                                            <Border Background="{StaticResource SubtleSurfaceEmphasisBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="6,2"
                                                    Margin="0,0,6,6">
                                                <TextBlock Text="{Binding FollowersFormatted, StringFormat={}{0} followers}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="9.5"
                                                           Foreground="{StaticResource SecondaryTextBrush}" />
                                            </Border>
                                            <Border Background="{StaticResource SubtleSurfaceEmphasisBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="6,2"
                                                    Margin="0,0,6,6">
                                                <TextBlock Text="{Binding FollowingFormatted, StringFormat={}{0} following}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="9.5"
                                                           Foreground="{StaticResource SecondaryTextBrush}" />
                                            </Border>
                                            <Border Background="{StaticResource SubtleSurfaceEmphasisBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="6,2"
                                                    Margin="0,0,6,6"
                                                    Visibility="{Binding HasCompany, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="{Binding Company}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="9.5"
                                                           Foreground="{StaticResource SecondaryTextBrush}" />
                                            </Border>
                                            <Border Background="{StaticResource SubtleSurfaceEmphasisBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="6,2"
                                                    Margin="0,0,6,6"
                                                    Visibility="{Binding HasLocation, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="{Binding Location}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="9.5"
                                                           Foreground="{StaticResource SecondaryTextBrush}" />
                                            </Border>
                                            <Button Style="{StaticResource InlineLinkButtonStyle}"
                                                    Click="OnOpenUrlClick"
                                                    Tag="{Binding WebsiteUrl}"
                                                    Margin="0,0,6,6"
                                                    Visibility="{Binding HasWebsiteUrl, Converter={StaticResource BoolToVis}}">
                                                <Border Background="{StaticResource SubtleSurfaceEmphasisBrush}"
                                                        BorderBrush="{StaticResource BorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Padding="6,2">
                                                    <TextBlock Text="Website"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="9.5"
                                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                                </Border>
                                            </Button>
                                        </WrapPanel>
                                    </StackPanel>
                                    <Grid Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding OwnedRepositoriesFormatted}"
                                                       Style="{StaticResource StatValueStyle}" FontSize="16" />
                                            <TextBlock Text="Owned repos" Style="{StaticResource LabelTextStyle}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding PublicRepositoriesFormatted}"
                                                       Style="{StaticResource StatValueStyle}" FontSize="16" />
                                            <TextBlock Text="Public repos" Style="{StaticResource LabelTextStyle}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,10,0,0">
                                            <TextBlock Text="{Binding OwnerCountFormatted}"
                                                       Style="{StaticResource StatValueStyle}" FontSize="16" />
                                            <TextBlock Text="Owners" Style="{StaticResource LabelTextStyle}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,10,0,0">
                                            <TextBlock Text="{Binding DominantLanguage}"
                                                       Style="{StaticResource StatValueStyle}" FontSize="16" />
                                            <TextBlock Text="Top language" Style="{StaticResource LabelTextStyle}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,10,0,0">
                                            <TextBlock Text="{Binding TotalStarsFormatted}"
                                                       Style="{StaticResource StatValueStyle}" FontSize="16" />
                                            <TextBlock Text="Stars" Style="{StaticResource LabelTextStyle}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,10,0,0">
                                            <TextBlock Text="{Binding TotalForksFormatted}"
                                                       Style="{StaticResource StatValueStyle}" FontSize="16" />
                                            <TextBlock Text="Forks" Style="{StaticResource LabelTextStyle}" />
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Text="{Binding OrganizationRepositoriesFormatted, StringFormat=Plus {0} org repos in the repo mix}"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="10"
                                               Foreground="{StaticResource TertiaryTextBrush}"
                                               Margin="0,8,0,0"
                                               Visibility="{Binding HasOrganizationRepositories, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}"
                                    Visibility="{Binding HasOwners, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="REPO OWNERS" Style="{StaticResource SectionHeaderStyle}" Margin="0" />
                                        <TextBlock HorizontalAlignment="Right"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TertiaryTextBrush}"
                                                   Text="{Binding OwnerCountFormatted, StringFormat={}{0} visible}" />
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding Owners}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:GitHubOwnerViewModel}">
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Button Style="{StaticResource InlineLinkButtonStyle}"
                                                                    Click="OnOpenUrlClick"
                                                                    Tag="{Binding ProfileUrl}"
                                                                    HorizontalAlignment="Left">
                                                                <TextBlock Text="{Binding Owner}"
                                                                           FontFamily="{StaticResource AppFont}"
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                                            </Button>
                                                            <Border Background="{StaticResource SubtleSurfaceEmphasisBrush}"
                                                                    BorderBrush="{StaticResource BorderBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8"
                                                                    Padding="6,1"
                                                                    Margin="6,0,0,0">
                                                                <TextBlock Text="{Binding KindText}"
                                                                           FontFamily="{StaticResource AppFont}"
                                                                           FontSize="9.5"
                                                                           Foreground="{StaticResource SecondaryTextBrush}" />
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding RepositoryCountFormatted, StringFormat={}{0} repos in the mix}"
                                                                   FontFamily="{StaticResource AppFont}"
                                                                   FontSize="10"
                                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                                   Margin="0,2,0,0" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1"
                                                                Orientation="Horizontal"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="★"
                                                                   FontFamily="{StaticResource AppFont}"
                                                                   FontSize="10"
                                                                   Foreground="{StaticResource FavoriteBadgeBrush}" />
                                                        <TextBlock Text="{Binding StarsFormatted}"
                                                                   FontFamily="{StaticResource AppFont}"
                                                                   FontSize="10"
                                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                                   Margin="2,0,8,0" />
                                                        <TextBlock Text="&#x2442;"
                                                                   FontFamily="{StaticResource AppFont}"
                                                                   FontSize="10"
                                                                   Foreground="{StaticResource TertiaryTextBrush}" />
                                                        <TextBlock Text="{Binding ForksFormatted}"
                                                                   FontFamily="{StaticResource AppFont}"
                                                                   FontSize="10"
                                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                                   Margin="2,0,0,0" />
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}"
                                Visibility="{Binding HasModelDaySummaries, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="LOCAL MODELS BY DAY" Style="{StaticResource SectionHeaderStyle}" />
                                <ItemsControl ItemsSource="{Binding ModelDaySummaries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:ModelDaySummaryViewModel}">
                                            <Border Margin="0,0,0,8"
                                                    Padding="10,8"
                                                    CornerRadius="8"
                                                    Background="{StaticResource InsetPanelBrush}">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding DayLabel}"
                                                                   FontFamily="{StaticResource AppFont}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource PrimaryTextBrush}" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding TotalTokensText}"
                                                                   FontFamily="{StaticResource AppFont}"
                                                                   FontSize="10"
                                                                   Foreground="{StaticResource SecondaryTextBrush}" />
                                                    </Grid>
                                                    <TextBlock Margin="0,4,0,0"
                                                               Text="{Binding ModelsText}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="10"
                                                               Foreground="{StaticResource SecondaryTextBrush}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                            <Border Style="{StaticResource CardStyle}"
                                    Visibility="{Binding HasLanguages, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="LANGUAGE MIX" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,10" />
                                    <ItemsControl ItemsSource="{Binding Languages}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:GitHubLanguageViewModel}">
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Language}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="10.5"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                               Margin="0,0,10,0"
                                                               VerticalAlignment="Center" />
                                                    <Grid Grid.Column="1" Height="6" VerticalAlignment="Center">
                                                        <Border CornerRadius="3" Background="{StaticResource SubtleSurfaceStrongBrush}" />
                                                        <Border CornerRadius="3"
                                                                Background="{Binding BarBrush}"
                                                                HorizontalAlignment="Left"
                                                                Width="{Binding Proportion, Converter={StaticResource PropToWidth}, ConverterParameter=200}" />
                                                    </Grid>
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding RepositoryCountFormatted}"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="10"
                                                               Foreground="{StaticResource SecondaryTextBrush}"
                                                               Margin="10,0,0,0"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Contribution stats 2x2 grid -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="CONTRIBUTIONS" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Text="{Binding ContributionAvailabilityText}"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="10"
                                               Foreground="{StaticResource TertiaryTextBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0"
                                               Visibility="{Binding ShowContributionFallbackMessage, Converter={StaticResource BoolToVis}}" />
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
                                            <TextBlock Text="{Binding TotalCommitsFormatted}"
                                                       Style="{StaticResource StatValueStyle}" FontSize="18" />
                                            <TextBlock Text="Commits" Style="{StaticResource LabelTextStyle}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                                            <TextBlock Text="{Binding TotalPRsFormatted}"
                                                       Style="{StaticResource StatValueStyle}" FontSize="18" />
                                            <TextBlock Text="Pull Requests" Style="{StaticResource LabelTextStyle}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="0">
                                            <TextBlock Text="{Binding TotalReviewsFormatted}"
                                                       Style="{StaticResource StatValueStyle}" FontSize="18" />
                                            <TextBlock Text="Reviews" Style="{StaticResource LabelTextStyle}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="1">
                                            <TextBlock Text="{Binding TotalIssuesFormatted}"
                                                       Style="{StaticResource StatValueStyle}" FontSize="18" />
                                            <TextBlock Text="Issues" Style="{StaticResource LabelTextStyle}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 30-day contribution bar chart -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="30-DAY CONTRIBUTIONS" Style="{StaticResource SectionHeaderStyle}" Margin="0" />
                                        <TextBlock HorizontalAlignment="Right"
                                                   FontFamily="{StaticResource AppFont}" FontSize="10"
                                                   Foreground="{StaticResource TertiaryTextBrush}"
                                                   Text="{Binding TotalContributionsFormatted}" />
                                    </Grid>
                                    <TextBlock Text="{Binding ContributionAvailabilityText}"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="10"
                                               Foreground="{StaticResource TertiaryTextBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,8"
                                               Visibility="{Binding ShowContributionFallbackMessage, Converter={StaticResource BoolToVis}}" />
                                    <ItemsControl ItemsSource="{Binding ContribBars}" Margin="0,0,0,4">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="30" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:GitHubContribBarViewModel}">
                                                <Grid Height="42" VerticalAlignment="Bottom" Margin="0.5,0"
                                                      ToolTip="{Binding Count}">
                                                    <Border CornerRadius="2"
                                                            Background="{StaticResource SectionStripBrush}"
                                                            VerticalAlignment="Stretch" />
                                                    <Border CornerRadius="2"
                                                            Background="{Binding BarBrush}"
                                                            Opacity="0.8"
                                                            VerticalAlignment="Bottom"
                                                            Height="{Binding BarHeight}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Top repos -->
                            <Border Style="{StaticResource CardStyle}"
                                    Visibility="{Binding HasTopRepos, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="REPOSITORY LENS" Style="{StaticResource SectionHeaderStyle}" Margin="0" />
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10"
                                                       Foreground="{StaticResource TertiaryTextBrush}"
                                                       Text="{Binding OwnedRepositoriesFormatted, StringFormat={}{0} owned}" />
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Text="{Binding RepoSortLabel}"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryTextBrush}" />
                                    <TextBlock Text="{Binding RepoSortHint}"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="10"
                                               Foreground="{StaticResource TertiaryTextBrush}"
                                               Margin="0,4,0,8"
                                               TextWrapping="Wrap" />
                                    <WrapPanel Margin="0,0,0,10">
                                        <ToggleButton Style="{StaticResource RangeChipStyle}"
                                                      IsChecked="{Binding IsRepoSortStarsSelected, Mode=OneWay}"
                                                      Click="OnGitHubRepoSortClick"
                                                      Tag="Stars">
                                            <TextBlock Text="Stars" />
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource RangeChipStyle}"
                                                      IsChecked="{Binding IsRepoSortForksSelected, Mode=OneWay}"
                                                      Click="OnGitHubRepoSortClick"
                                                      Tag="Forks">
                                            <TextBlock Text="Forks" />
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource RangeChipStyle}"
                                                      IsChecked="{Binding IsRepoSortHealthSelected, Mode=OneWay}"
                                                      Click="OnGitHubRepoSortClick"
                                                      Tag="Health">
                                            <TextBlock Text="Health" />
                                        </ToggleButton>
                                        <ToggleButton Style="{StaticResource RangeChipStyle}"
                                                      IsChecked="{Binding IsRepoSortRecentSelected, Mode=OneWay}"
                                                      Click="OnGitHubRepoSortClick"
                                                      Tag="Recent"
                                                      Margin="0">
                                            <TextBlock Text="Recent" />
                                        </ToggleButton>
                                    </WrapPanel>
                                    <ItemsControl ItemsSource="{Binding TopRepos}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:GitHubRepoViewModel}">
                                                <Border Background="{StaticResource SubtleSurfaceMutedBrush}"
                                                        BorderBrush="{StaticResource BorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Margin="0,0,0,8"
                                                        Padding="10">
                                                    <StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                                <Ellipse Width="8" Height="8"
                                                                         Fill="{Binding LanguageBrush}"
                                                                         Margin="0,0,6,0"
                                                                         VerticalAlignment="Center" />
                                                                <Button Style="{StaticResource InlineLinkButtonStyle}"
                                                                        Click="OnOpenUrlClick"
                                                                        Tag="{Binding RepositoryUrl}"
                                                                        HorizontalAlignment="Left">
                                                                    <TextBlock Text="{Binding Name}"
                                                                               FontFamily="{StaticResource AppFont}"
                                                                               FontSize="11"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               VerticalAlignment="Center" />
                                                                </Button>
                                                                <Border Background="{StaticResource SubtleSurfaceEmphasisBrush}"
                                                                        BorderBrush="{StaticResource BorderBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="8"
                                                                        Padding="6,1"
                                                                        Margin="6,0,0,0">
                                                                    <TextBlock Text="{Binding Owner}"
                                                                               FontFamily="{StaticResource AppFont}"
                                                                               FontSize="9.5"
                                                                               Foreground="{StaticResource SecondaryTextBrush}" />
                                                                </Border>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                                        VerticalAlignment="Center">
                                                                <TextBlock Text="★"
                                                                           FontFamily="{StaticResource AppFont}"
                                                                           FontSize="10"
                                                                           Foreground="{StaticResource FavoriteBadgeBrush}" />
                                                                <TextBlock Text="{Binding StarsFormatted}"
                                                                           FontFamily="{StaticResource AppFont}"
                                                                           FontSize="10"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                                           Margin="2,0,8,0" />
                                                                <TextBlock Text="&#x2442;"
                                                                           FontFamily="{StaticResource AppFont}"
                                                                           FontSize="10"
                                                                           Foreground="{StaticResource TertiaryTextBrush}" />
                                                                <TextBlock Text="{Binding ForksFormatted}"
                                                                           FontFamily="{StaticResource AppFont}"
                                                                           FontSize="10"
                                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                                           Margin="2,0,0,0" />
                                                            </StackPanel>
                                                        </Grid>
                                                        <TextBlock Text="{Binding Description}"
                                                                   FontFamily="{StaticResource AppFont}"
                                                                   FontSize="10"
                                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,6,0,0" />
                                                        <WrapPanel Margin="0,6,0,0">
                                                            <Border Background="{StaticResource InsetPanelBrush}"
                                                                    BorderBrush="{StaticResource BorderBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8"
                                                                    Padding="6,2"
                                                                    Margin="0,0,6,6">
                                                                <TextBlock Text="{Binding RankMetricText}"
                                                                           FontFamily="{StaticResource AppFont}"
                                                                           FontSize="9.5"
                                                                           Foreground="{StaticResource PrimaryTextBrush}" />
                                                            </Border>
                                                            <Border Background="{StaticResource SubtleSurfaceEmphasisBrush}"
                                                                    BorderBrush="{StaticResource BorderBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8"
                                                                    Padding="6,2"
                                                                    Margin="0,0,6,6">
                                                                <TextBlock Text="{Binding StatusText}"
                                                                           FontFamily="{StaticResource AppFont}"
                                                                           FontSize="9.5"
                                                                           Foreground="{StaticResource SecondaryTextBrush}" />
                                                            </Border>
                                                            <Border Background="{StaticResource SubtleSurfaceEmphasisBrush}"
                                                                    BorderBrush="{StaticResource BorderBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8"
                                                                    Padding="6,2"
                                                                    Margin="0,0,6,6"
                                                                    Visibility="{Binding HasRecentPush, Converter={StaticResource BoolToVis}}">
                                                                <TextBlock Text="{Binding PushedAtText}"
                                                                           FontFamily="{StaticResource AppFont}"
                                                                           FontSize="9.5"
                                                                           Foreground="{StaticResource SecondaryTextBrush}" />
                                                            </Border>
                                                            <Border Background="{StaticResource SubtleSurfaceEmphasisBrush}"
                                                                    BorderBrush="{StaticResource BorderBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8"
                                                                    Padding="6,2"
                                                                    Margin="0,0,6,6">
                                                                <TextBlock Text="{Binding WatchersFormatted, StringFormat={}{0} watchers}"
                                                                           FontFamily="{StaticResource AppFont}"
                                                                           FontSize="9.5"
                                                                           Foreground="{StaticResource SecondaryTextBrush}" />
                                                            </Border>
                                                            <Border Background="{StaticResource SubtleSurfaceEmphasisBrush}"
                                                                    BorderBrush="{StaticResource BorderBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8"
                                                                    Padding="6,2"
                                                                    Margin="0,0,6,6">
                                                                <TextBlock Text="{Binding OpenIssuesFormatted, StringFormat={}{0} open issues}"
                                                                           FontFamily="{StaticResource AppFont}"
                                                                           FontSize="9.5"
                                                                           Foreground="{StaticResource SecondaryTextBrush}" />
                                                            </Border>
                                                            <Border Background="{StaticResource SubtleSurfaceEmphasisBrush}"
                                                                    BorderBrush="{StaticResource BorderBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8"
                                                                    Padding="6,2"
                                                                    Margin="0,0,0,6"
                                                                    Visibility="{Binding IsArchived, Converter={StaticResource BoolToVis}}">
                                                                <TextBlock Text="Archived"
                                                                           FontFamily="{StaticResource AppFont}"
                                                                           FontSize="9.5"
                                                                           Foreground="{StaticResource TertiaryTextBrush}" />
                                                            </Border>
                                                        </WrapPanel>
                                                        <TextBlock Text="{Binding Language}"
                                                                   FontFamily="{StaticResource AppFont}"
                                                                   FontSize="10"
                                                                   Foreground="{StaticResource TertiaryTextBrush}"
                                                                   Margin="0,0,0,0" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- Loading overlay -->
                <Grid Panel.ZIndex="20"
                      Background="{StaticResource OverlayScrimBrush}"
                      Visibility="{Binding ShowLoadingOverlay, Converter={StaticResource BoolToVis}}">
                    <Border Background="{StaticResource OverlayGlowBrush}"
                            Opacity="0.08"
                            Margin="10,8" />
                    <Border Background="{StaticResource OverlayCardBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="20,18"
                            Margin="28,0"
                            MaxWidth="280"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel Width="240">
                            <ProgressBar Height="6"
                                         IsIndeterminate="{Binding LoadingProgressIsIndeterminate}"
                                         Maximum="{Binding LoadingProgressMaximum}"
                                         Value="{Binding LoadingProgressValue}"
                                         Foreground="{StaticResource AccentBrush}"
                                         Background="{StaticResource SubtleSurfaceEmphasisBrush}" />
                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="12.5"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,12,0,0" />
                            <TextBlock Text="{Binding LoadingDetailDisplayText}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="10.5"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- ═══ FOOTER ═══ -->
            <Border Grid.Row="3"
                    Background="{StaticResource FooterBrush}"
                    Padding="16,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="220" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,12,0">
                        <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10"
                                   Foreground="{StaticResource TertiaryTextBrush}">
                            <Run Text="Updated " />
                        </TextBlock>
                        <TextBlock Text="{Binding LastRefreshedFormatted}"
                                   FontFamily="{StaticResource AppFont}" FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                        <TextBlock FontFamily="{StaticResource AppFont}" FontSize="10"
                                   Foreground="{StaticResource TertiaryTextBrush}"
                                   Margin="8,0,0,0"
                                   Text="•" />
                        <TextBlock Text="{Binding RefreshModeLabel}"
                                   FontFamily="{StaticResource AppFont}" FontSize="10"
                                   Margin="8,0,0,0"
                                   Foreground="{StaticResource TertiaryTextBrush}" />
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Text="{Binding FooterStatusText}"
                               FontFamily="{StaticResource AppFont}" FontSize="10"
                               Foreground="{StaticResource TertiaryTextBrush}"
                               HorizontalAlignment="Right"
                               TextAlignment="Right"
                               TextTrimming="CharacterEllipsis"
                               Margin="12,0,0,0" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
