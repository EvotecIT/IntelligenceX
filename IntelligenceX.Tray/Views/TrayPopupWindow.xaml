                                                       FontSize="9.5"
                                                       Foreground="{StaticResource TertiaryTextBrush}" />
                                            <TextBlock Text="{Binding CodeUsageNegativeProviderText}"
                                                       Margin="0,4,0,0"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource WarningBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding CodeUsageNegativeSummaryText}"
                                                       Margin="0,4,0,0"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="9.5"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
