<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0-windows;net10.0-windows</TargetFrameworks>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <AssemblyName>IntelligenceX.Tools.TestimoX.Analytics</AssemblyName>
    <PackageId>IntelligenceX.Tools.TestimoX.Analytics</PackageId>
    <Authors>Przemyslaw Klys</Authors>
    <Company>Evotec</Company>
    <Description>TestimoX analytics, persisted history, and report artifact tools for IntelligenceX tool calling.</Description>
    <RepositoryUrl>https://github.com/EvotecIT/IntelligenceX.Tools</RepositoryUrl>
    <IsPackable>true</IsPackable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="$(IntelligenceXCoreProject)" Condition="'$(IntelligenceXCoreProject)'!='' AND Exists('$(IntelligenceXCoreProject)')" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\IntelligenceX.Tools.Common\IntelligenceX.Tools.Common.csproj" />
    <ProjectReference Include="..\IntelligenceX.Tools.TestimoX\IntelligenceX.Tools.TestimoX.csproj" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="$(TestimoXRoot)ADPlayground.Monitoring\ADPlayground.Monitoring.csproj" Condition="Exists('$(TestimoXRoot)ADPlayground.Monitoring\ADPlayground.Monitoring.csproj')" />
  </ItemGroup>
</Project>
