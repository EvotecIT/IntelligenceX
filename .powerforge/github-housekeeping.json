{
  "$schema": "https://raw.githubusercontent.com/EvotecIT/PSPublishModule/06fbc3f015c2da91bb1b49e1a1323c21aced7cdf/Schemas/github.housekeeping.schema.json",
  "repository": "EvotecIT/IntelligenceX",
  "tokenEnvName": "GITHUB_TOKEN",
  "artifacts": {
    "enabled": true,
    "keepLatestPerName": 10,
    "maxAgeDays": 7,
    "maxDelete": 200
  },
  "caches": {
    "enabled": true,
    "keepLatestPerKey": 3,
    "maxAgeDays": 14,
    "maxDelete": 200
  },
  "runner": {
    "enabled": false
  }
}
