{
  "$schema": "https://raw.githubusercontent.com/EvotecIT/PSPublishModule/97b0d38217ab995e611a12d162ae41505b7bfed1/Schemas/github.housekeeping.schema.json",
  "repository": "EvotecIT/IntelligenceX",
  "tokenEnvName": "GITHUB_TOKEN",
  "artifacts": {
    "enabled": false
  },
  "caches": {
    "enabled": false
  },
  "runner": {
    "enabled": true,
    "minFreeGb": 20,
    "diagnosticsRetentionDays": 14,
    "actionsRetentionDays": 7,
    "toolCacheRetentionDays": 30
  }
}
