<?xml version="1.0" encoding="utf-8" ?>
<Configuration>
  <ViewDefinitions>
    <View>
      <Name>IntelligenceX.ThreadInfo.Table</Name>
      <ViewSelectedBy>
        <TypeName>IntelligenceX.OpenAI.AppServer.Models.ThreadInfo</TypeName>
      </ViewSelectedBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader><Label>Id</Label></TableColumnHeader>
          <TableColumnHeader><Label>Preview</Label></TableColumnHeader>
          <TableColumnHeader><Label>Model</Label></TableColumnHeader>
          <TableColumnHeader><Label>Updated</Label></TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem><PropertyName>Id</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Preview</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>ModelProvider</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>UpdatedAt</PropertyName></TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>

    <View>
      <Name>IntelligenceX.ModelInfo.Table</Name>
      <ViewSelectedBy>
        <TypeName>IntelligenceX.OpenAI.AppServer.Models.ModelInfo</TypeName>
      </ViewSelectedBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader><Label>DisplayName</Label></TableColumnHeader>
          <TableColumnHeader><Label>Model</Label></TableColumnHeader>
          <TableColumnHeader><Label>Default</Label></TableColumnHeader>
          <TableColumnHeader><Label>Effort</Label></TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem><PropertyName>DisplayName</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Model</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>IsDefault</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>DefaultReasoningEffort</PropertyName></TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>

    <View>
      <Name>IntelligenceX.TurnInfo.Table</Name>
      <ViewSelectedBy>
        <TypeName>IntelligenceX.OpenAI.AppServer.Models.TurnInfo</TypeName>
      </ViewSelectedBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader><Label>Id</Label></TableColumnHeader>
          <TableColumnHeader><Label>Status</Label></TableColumnHeader>
          <TableColumnHeader><Label>Outputs</Label></TableColumnHeader>
          <TableColumnHeader><Label>Images</Label></TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem><PropertyName>Id</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Status</PropertyName></TableColumnItem>
              <TableColumnItem><ScriptBlock>$_.Outputs.Count</ScriptBlock></TableColumnItem>
              <TableColumnItem><ScriptBlock>$_.ImageOutputs.Count</ScriptBlock></TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>

    <View>
      <Name>IntelligenceX.TurnOutput.Table</Name>
      <ViewSelectedBy>
        <TypeName>IntelligenceX.OpenAI.AppServer.Models.TurnOutput</TypeName>
      </ViewSelectedBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader><Label>Type</Label></TableColumnHeader>
          <TableColumnHeader><Label>Content</Label></TableColumnHeader>
          <TableColumnHeader><Label>Mime</Label></TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem><PropertyName>Type</PropertyName></TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>
                  if ($_.Text) { if ($_.Text.Length -gt 80) { $_.Text.Substring(0,80) + '...' } else { $_.Text } }
                  elseif ($_.ImageUrl) { $_.ImageUrl }
                  elseif ($_.ImagePath) { $_.ImagePath }
                  else { '' }
                </ScriptBlock>
              </TableColumnItem>
              <TableColumnItem><PropertyName>MimeType</PropertyName></TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>

    <View>
      <Name>IntelligenceX.AccountInfo.Table</Name>
      <ViewSelectedBy>
        <TypeName>IntelligenceX.OpenAI.AppServer.Models.AccountInfo</TypeName>
      </ViewSelectedBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader><Label>Email</Label></TableColumnHeader>
          <TableColumnHeader><Label>Plan</Label></TableColumnHeader>
          <TableColumnHeader><Label>AccountId</Label></TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem><PropertyName>Email</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>PlanType</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>AccountId</PropertyName></TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>

    <View>
      <Name>IntelligenceX.McpServerStatus.Table</Name>
      <ViewSelectedBy>
        <TypeName>IntelligenceX.OpenAI.AppServer.Models.McpServerStatus</TypeName>
      </ViewSelectedBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader><Label>Name</Label></TableColumnHeader>
          <TableColumnHeader><Label>Auth</Label></TableColumnHeader>
          <TableColumnHeader><Label>Tools</Label></TableColumnHeader>
          <TableColumnHeader><Label>Resources</Label></TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem><PropertyName>Name</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>AuthStatus</PropertyName></TableColumnItem>
              <TableColumnItem><ScriptBlock>$_.Tools.Count</ScriptBlock></TableColumnItem>
              <TableColumnItem><ScriptBlock>$_.Resources.Count</ScriptBlock></TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>
  </ViewDefinitions>
</Configuration>
