{
  "$schema": "https://raw.githubusercontent.com/EvotecIT/PSPublishModule/main/schemas/powerforge.web.pipelinespec.schema.json",
  "cache": true,
  "cachePath": "./_temp/pipeline-cache.json",
  "profile": true,
  "profilePath": "./_temp/pipeline-profile.json",
  "steps": [
    {
      "task": "dotnet-build",
      "id": "build-library",
      "project": "../IntelligenceX/IntelligenceX.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "release-hub",
      "id": "build-release-hub",
      "dependsOn": "build-library",
      "source": "github",
      "repo": "EvotecIT/IntelligenceX",
      "tokenEnv": "GITHUB_TOKEN",
      "out": "./data/release-hub.json",
      "title": "IntelligenceX Releases",
      "maxReleases": 300,
      "pageSize": 100,
      "maxPages": 4,
      "includePrerelease": true,
      "products": [
        { "id": "intelligencex.chat", "name": "IX Chat", "order": 10 },
        { "id": "intelligencex.tools", "name": "IX Tools", "order": 20 },
        { "id": "intelligencex.powershell", "name": "PowerShell Module", "order": 30 },
        { "id": "intelligencex.library", "name": ".NET Library", "order": 40 }
      ],
      "assetRules": [
        {
          "product": "intelligencex.chat",
          "label": "IX Chat",
          "match": ["*IntelligenceX.Chat*.zip", "*IX.Chat*.zip", "*IntelligenceX.Chat*.msix*", "*IntelligenceX.Chat*.exe"]
        },
        {
          "product": "intelligencex.tools",
          "label": "IX Tools",
          "match": ["*IntelligenceX.Tools*.zip", "*IX.Tools*.zip"]
        },
        {
          "product": "intelligencex.powershell",
          "label": "PowerShell Module",
          "match": ["*IntelligenceX.PowerShell*.zip", "*IntelligenceX.PowerShell*.nupkg"],
          "kind": "nupkg"
        },
        {
          "product": "unknown",
          "label": "Reviewer",
          "match": ["*IntelligenceX.Reviewer*.zip"],
          "channel": "internal",
          "kind": "zip"
        },
        {
          "product": "intelligencex.library",
          "label": ".NET Library",
          "match": ["*IntelligenceX*.nupkg", "*IntelligenceX*.zip"],
          "kind": "nupkg"
        }
      ]
    },
    {
      "task": "build",
      "id": "build-site",
      "dependsOn": ["build-library", "build-release-hub"],
      "config": "./site.json",
      "out": "./_site",
      "clean": true
    },
    {
      "task": "verify",
      "id": "verify-site",
      "dependsOn": "build-site",
      "skipModes": ["ci"],
      "config": "./site.json"
    },
    {
      "task": "apidocs",
      "id": "build-apidocs",
      "dependsOn": ["build-library", "build-site"],
      "config": "./site.json",
      "xml": "../IntelligenceX/bin/Release/net8.0/IntelligenceX.xml",
      "assembly": "../IntelligenceX/bin/Release/net8.0/IntelligenceX.dll",
      "out": "./_site/api",
      "title": "IntelligenceX API Reference",
      "baseUrl": "/api",
      "format": "both",
      "legacyAliasMode": "omit",
      "template": "docs",
      "nav": "./site.json",
      "navContextPath": "/",
      "css": "/css/main.css,/css/api.css",
      "sourceRoot": "../IntelligenceX",
      "sourceUrl": "https://github.com/EvotecIT/IntelligenceX/blob/master/IntelligenceX/{root}/{pathNoRoot}#L{line}",
      "injectCriticalCss": true
    },
    {
      "task": "apidocs",
      "id": "build-apidocs-powershell",
      "dependsOn": ["build-library", "build-site"],
      "config": "./site.json",
      "type": "PowerShell",
      "helpPath": "./data/apidocs/powershell/IntelligenceX.PowerShell.dll-Help.xml",
      "psExamplesPath": "./data/apidocs/powershell/examples",
      "out": "./_site/api/powershell",
      "title": "IntelligenceX PowerShell Cmdlet Reference",
      "baseUrl": "/api/powershell",
      "format": "both",
      "legacyAliasMode": "omit",
      "template": "docs",
      "docsHome": "/docs/powershell/overview/",
      "nav": "./site.json",
      "navContextPath": "/",
      "css": "/css/main.css,/css/api.css",
      "injectCriticalCss": true
    },
    {
      "task": "xref-merge",
      "id": "merge-xref",
      "dependsOn": ["build-apidocs", "build-apidocs-powershell"],
      "out": "./data/xrefmap.json",
      "mapFiles": ["./_site/api/xrefmap.json", "./_site/api/powershell/xrefmap.json"],
      "preferLast": true,
      "maxReferences": 5000,
      "maxDuplicates": 25,
      "maxReferenceGrowthCount": 1000,
      "maxReferenceGrowthPercent": 50
    },
    {
      "task": "build",
      "id": "build-site-xref-refresh",
      "dependsOn": "merge-xref",
      "config": "./site.json",
      "out": "./_site",
      "clean": false
    },
    {
      "task": "verify",
      "id": "verify-ci",
      "dependsOn": "build-site-xref-refresh",
      "modes": ["ci"],
      "config": "./site.json",
      "baseline": "./.powerforge/verify-baseline.json",
      "failOnNewWarnings": true,
      "failOnNavLint": true,
      "failOnThemeContract": true,
      "warningPreviewCount": 10,
      "errorPreviewCount": 10
    },
    {
      "task": "llms",
      "id": "build-llms",
      "dependsOn": "verify-ci",
      "siteRoot": "./_site",
      "project": "../IntelligenceX/IntelligenceX.csproj",
      "apiIndex": "./_site/api/index.json",
      "apiBase": "/api",
      "apiLevel": "Full",
      "name": "IntelligenceX",
      "license": "MIT",
      "targets": ".NET 8+, .NET 10+, .NET Standard 2.0, .NET Framework 4.7.2"
    },
    {
      "task": "sitemap",
      "id": "build-sitemap",
      "dependsOn": "build-llms",
      "siteRoot": "./_site",
      "baseUrl": "https://intelligencex.dev",
      "apiSitemap": "./_site/api/sitemap.xml",
      "entriesJson": "./data/sitemap.entries.json",
      "includeNoIndexHtml": false,
      "noDefaultExclude": false,
      "excludePatterns": ["**/api-fragments/**", "**/*.scripts.html", "**/*.head.html"],
      "includeGeneratedHtmlRouteInXml": false,
      "json": true,
      "jsonOut": "./_site/sitemap/index.json",
      "html": true,
      "htmlOutput": "./_site/sitemap/index.html",
      "htmlTitle": "IntelligenceX Sitemap"
    },
    {
      "task": "indexnow",
      "id": "submit-indexnow",
      "dependsOn": "build-sitemap",
      "modes": ["ci"],
      "baseUrl": "https://intelligencex.dev",
      "siteRoot": "./_site",
      "scopeFromBuildUpdated": true,
      "keyEnv": "INDEXNOW_KEY",
      "optionalKey": true,
      "continueOnError": true,
      "reportPath": "./_reports/indexnow.json",
      "summaryPath": "./_reports/indexnow.md"
    },
    {
      "task": "optimize",
      "id": "optimize-site",
      "dependsOn": "submit-indexnow",
      "skipModes": ["dev"],
      "siteRoot": "./_site",
      "config": "./site.json",
      "criticalCss": "./themes/intelligencex/critical.css",
      "minifyHtml": true,
      "minifyCss": true,
      "minifyJs": true,
      "optimizeImages": true,
      "imageExtensions": [".png", ".jpg", ".jpeg", ".webp"],
      "imageExclude": ["assets/social/generated/**"],
      "imageQuality": 82,
      "imageStripMetadata": true,
      "imageGenerateWebp": true,
      "imagePreferNextGen": true,
      "imageEnhanceTags": true,
      "hashAssets": true,
      "hashExtensions": [".css", ".js"],
      "hashExclude": ["**/assets/prism/components/**", "**/css/prism-theme.css"],
      "reportPath": "./_reports/optimize-report.json",
      "cacheHeaders": true,
      "cacheHeadersOut": "_headers"
    },
    {
      "task": "doctor",
      "id": "doctor-site",
      "dependsOn": "optimize-site",
      "skipModes": ["dev"],
      "config": "./site.json",
      "siteRoot": "./_site",
      "noBuild": true,
      "noVerify": true,
      "baseline": "./.powerforge/audit-baseline.json",
      "failOnNewIssues": true,
      "maxTotalFiles": 2000,
      "ignoreNav": "sitemap/**,search/**",
      "noDefaultIgnoreNav": true,
      "navSelector": "header nav.ix-nav",
      "navCanonicalPath": "index.html",
      "navCanonicalSelector": "header nav.ix-nav",
      "navCanonicalRequired": true,
      "navRequiredLinks": "/,/docs/,/api/,/api/powershell/,/showcase/,/blog/",
      "minNavCoveragePercent": 99,
      "requiredRoutes": "/,/docs/,/404.html,/api/,/api/powershell/,/blog/,/search/,/sitemap/,/showcase/",
      "failOnCategories": "budget,nav,link,asset,rendered-console-error,rendered-request-failure",
      "failOnIssueCodes": "media-img-dimensions,heading-order,head-render-blocking",
      "maxHeadBlockingResources": 2,
      "rendered": true,
      "renderedEnsureInstalled": true,
      "renderedMaxPages": 8,
      "renderedCheckContrast": true,
      "renderedContrastMinRatio": 4.5,
      "renderedContrastMaxFindings": 12,
      "mediaProfiles": "./.powerforge/media-profiles.json",
      "renderedInclude": "index.html,docs/**,faq/**,changelog/**,blog/**,api/index.html,api/powershell/index.html,showcase/**",
      "renderedExclude": "docs/api/**,api-docs/**",
      "summary": true,
      "summaryPath": "./_reports/doctor-summary.json",
      "summaryMaxIssues": 50,
      "checkUtf8": true,
      "checkMetaCharset": true,
      "checkUnicodeReplacementChars": true,
      "checkSeoMeta": false
    }
  ]
}
