{
  "$schema": "https://raw.githubusercontent.com/EvotecIT/PSPublishModule/main/schemas/powerforge.web.pipelinespec.schema.json",
  "cache": true,
  "cachePath": "./_temp/pipeline-cache.json",
  "profile": true,
  "profilePath": "./_temp/pipeline-profile.json",
  "steps": [
    {
      "task": "dotnet-build",
      "id": "build-library",
      "project": "../IntelligenceX/IntelligenceX.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "build",
      "id": "build-site",
      "dependsOn": "build-library",
      "config": "./site.json",
      "out": "./_site",
      "clean": true
    },
    {
      "task": "verify",
      "id": "verify-site",
      "dependsOn": "build-site",
      "config": "./site.json"
    },
    {
      "task": "verify",
      "id": "verify-ci",
      "dependsOn": "build-site",
      "modes": ["ci"],
      "config": "./site.json",
      "baseline": "./.powerforge/verify-baseline.json",
      "failOnNewWarnings": true,
      "failOnNavLint": true,
      "failOnThemeContract": true,
      "warningPreviewCount": 10,
      "errorPreviewCount": 10
    },
    {
      "task": "apidocs",
      "id": "build-apidocs",
      "dependsOn": ["build-library", "build-site"],
      "config": "./site.json",
      "xml": "../IntelligenceX/bin/Release/net8.0/IntelligenceX.xml",
      "assembly": "../IntelligenceX/bin/Release/net8.0/IntelligenceX.dll",
      "out": "./_site/api",
      "title": "IntelligenceX API Reference",
      "baseUrl": "/api",
      "format": "both",
      "template": "docs",
      "nav": "./site.json",
      "navContextPath": "/",
      "css": "/css/main.css,/css/api.css",
      "sourceRoot": "..",
      "sourceUrl": "https://github.com/EvotecIT/IntelligenceX/blob/master/{path}#L{line}",
      "injectCriticalCss": true
    },
    {
      "task": "xref-merge",
      "id": "merge-xref",
      "dependsOn": "build-apidocs",
      "out": "./data/xrefmap.json",
      "mapFiles": ["./_site/api/xrefmap.json"],
      "preferLast": true,
      "maxReferences": 5000,
      "maxDuplicates": 25,
      "maxReferenceGrowthCount": 1000,
      "maxReferenceGrowthPercent": 50
    },
    {
      "task": "build",
      "id": "build-site-xref-refresh",
      "dependsOn": "merge-xref",
      "config": "./site.json",
      "out": "./_site",
      "clean": false
    },
    {
      "task": "verify",
      "id": "verify-ci-final",
      "dependsOn": "build-site-xref-refresh",
      "modes": ["ci"],
      "config": "./site.json",
      "baseline": "./.powerforge/verify-baseline.json",
      "failOnNewWarnings": true,
      "failOnNavLint": true,
      "failOnThemeContract": true,
      "warningPreviewCount": 10,
      "errorPreviewCount": 10
    },
    {
      "task": "llms",
      "id": "build-llms",
      "dependsOn": "verify-ci-final",
      "siteRoot": "./_site",
      "project": "../IntelligenceX/IntelligenceX.csproj",
      "apiIndex": "./_site/api/index.json",
      "apiBase": "/api",
      "apiLevel": "Full",
      "name": "IntelligenceX",
      "license": "MIT",
      "targets": ".NET 8+, .NET 10+, .NET Standard 2.0, .NET Framework 4.7.2"
    },
    {
      "task": "sitemap",
      "id": "build-sitemap",
      "dependsOn": "build-llms",
      "siteRoot": "./_site",
      "baseUrl": "https://intelligencex.dev",
      "entriesJson": "./data/sitemap.entries.json",
      "json": true,
      "jsonOut": "./_site/sitemap/index.json",
      "html": true,
      "htmlOutput": "./_site/sitemap/index.html",
      "htmlTitle": "IntelligenceX Sitemap"
    },
    {
      "task": "optimize",
      "id": "optimize-site",
      "dependsOn": "build-sitemap",
      "skipModes": ["dev"],
      "siteRoot": "./_site",
      "config": "./site.json",
      "criticalCss": "./themes/intelligencex/critical.css",
      "minifyHtml": true,
      "minifyCss": true,
      "minifyJs": true,
      "optimizeImages": true,
      "imageExtensions": [".png", ".jpg", ".jpeg", ".webp"],
      "imageQuality": 82,
      "imageStripMetadata": true,
      "imageGenerateWebp": true,
      "imagePreferNextGen": true,
      "imageEnhanceTags": true,
      "hashAssets": true,
      "hashExtensions": [".css", ".js"],
      "hashExclude": ["**/assets/prism/components/**"],
      "reportPath": "./_reports/optimize-report.json",
      "cacheHeaders": true,
      "cacheHeadersOut": "_headers"
    },
    {
      "task": "doctor",
      "id": "doctor-site",
      "dependsOn": "optimize-site",
      "skipModes": ["dev"],
      "config": "./site.json",
      "siteRoot": "./_site",
      "noBuild": true,
      "noVerify": true,
      "baseline": "./.powerforge/audit-baseline.json",
      "failOnNewIssues": true,
      "maxTotalFiles": 800,
      "ignoreNav": "sitemap/**",
      "noDefaultIgnoreNav": true,
      "navSelector": "header nav.ix-nav",
      "navCanonicalPath": "index.html",
      "navCanonicalSelector": "header nav.ix-nav",
      "navCanonicalRequired": true,
      "navRequiredLinks": "/,/docs/,/api/,/showcase/",
      "minNavCoveragePercent": 99,
      "requiredRoutes": "/,/docs/,/404.html,/api/,/search/,/sitemap/,/showcase/",
      "failOnCategories": "budget,nav,link,asset,rendered-console-error,rendered-request-failure",
      "rendered": true,
      "renderedEnsureInstalled": false,
      "renderedMaxPages": 8,
      "renderedInclude": "index.html,docs/**,faq/**,changelog/**,api/index.html,showcase/**",
      "renderedExclude": "docs/api/**,api-docs/**",
      "summary": true,
      "summaryPath": "./_reports/doctor-summary.json",
      "summaryMaxIssues": 50,
      "checkUtf8": true,
      "checkMetaCharset": true,
      "checkUnicodeReplacementChars": true
    }
  ]
}
