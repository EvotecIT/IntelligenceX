{
  "$schema": "https://raw.githubusercontent.com/EvotecIT/PSPublishModule/main/schemas/powerforge.web.sitespec.schema.json",
  "SchemaVersion": 1,
  "Name": "IntelligenceX",
  "BaseUrl": "https://intelligencex.dev",
  "DefaultTheme": "intelligencex",
  "Features": ["docs", "apiDocs", "blog", "search", "notFound"],
  "TrailingSlash": "always",
  "ContentRoot": "content",
  "ThemesRoot": "themes",
  "DataRoot": "data",
  "StaticAssets": [
    { "Source": "static" }
  ],
  "Collections": [
    {
      "Name": "pages",
      "Input": "content/pages",
      "Output": "/",
      "DefaultLayout": "home",
      "UseToc": false,
      "Include": ["*.md", "**/*.md"]
    },
    {
      "Name": "blog",
      "Preset": "blog",
      "Input": "content/blog",
      "Output": "/blog",
      "DefaultLayout": "page",
      "ListLayout": "page",
      "UseToc": false,
      "EditorialCards": {
        "ImageAspect": "16/9",
        "ImageFit": "cover",
        "ImagePosition": "center",
        "GridClass": "ix-editorial-list ix-editorial-list-blog",
        "CardClass": "ix-editorial-card ix-editorial-card-blog"
      },
      "Include": ["*.md", "**/*.md"]
    },
    {
      "Name": "docs",
      "Input": "../Docs",
      "Output": "/docs",
      "DefaultLayout": "docs",
      "UseToc": true,
      "TocFile": "../Docs/toc.json",
      "Include": ["*.md", "**/*.md"],
      "Exclude": [
        "cli/commands/**",
        "screenshots/**",
        "reviewer/review-smoke.md",
        "reviewer/onboarding-unification-tracker.md",
        "agent-superpowers-backlog.md",
        "cli/todo.md",
        "library/build-publish.md",
        "library/plugin-rollout-draft.md"
      ]
    }
  ],
  "Taxonomies": [
    {
      "Name": "tags",
      "BasePath": "/tags",
      "ListLayout": "page",
      "TermLayout": "page"
    },
    {
      "Name": "categories",
      "BasePath": "/categories",
      "ListLayout": "page",
      "TermLayout": "page"
    }
  ],
  "Head": {
    "Links": [
      { "Rel": "icon", "Href": "/favicon.svg", "Type": "image/svg+xml" }
    ],
    "Meta": [
      { "Name": "robots", "Content": "index,follow,max-snippet:-1,max-image-preview:large,max-video-preview:-1" }
    ]
  },
  "Social": {
    "Enabled": true,
    "SiteName": "IntelligenceX",
    "Image": "/assets/screenshots/chat-flow/ChatAD_1_1.png",
    "TwitterCard": "summary_large_image",
    "AutoGenerateCards": true,
    "GeneratedCardsPath": "/assets/social/generated",
    "GeneratedCardWidth": 1200,
    "GeneratedCardHeight": 630,
    "GeneratedCardStyle": "default",
    "GeneratedCardVariant": "standard",
    "GeneratedCardStylesByCollection": {
      "pages": "default",
      "docs": "docs",
      "blog": "editorial"
    },
    "GeneratedCardVariantsByCollection": {
      "pages": "hero",
      "docs": "compact",
      "blog": "compact"
    }
  },
  "StructuredData": {
    "Enabled": true,
    "Breadcrumbs": true,
    "OrganizationLegalName": "Evotec Services sp. z o.o.",
    "OrganizationDescription": "Zero-trust AI platform for code review, chat, and developer tooling.",
    "OrganizationLogo": "https://evotec.xyz/favicon.svg",
    "OrganizationSameAs": [
      "https://github.com/EvotecIT/IntelligenceX",
      "https://evotec.xyz",
      "https://evo.yt/discord"
    ],
    "OrganizationEmail": "support@evotec.xyz",
    "OrganizationContactUrl": "https://evotec.xyz/docs/getting-started/"
  },
  "AgentReadiness": {
    "Enabled": true,
    "HeadersPath": "_headers",
    "LinkHeaders": true,
    "Robots": true,
    "SecurityHeaders": {
      "Enabled": true,
      "ContentSecurityPolicyValue": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
    },
    "ContentSignals": {
      "Enabled": true,
      "Search": true,
      "AiInput": true,
      "AiTrain": false
    },
    "BotRules": [
      { "UserAgent": "GPTBot", "Allow": "/" },
      { "UserAgent": "ChatGPT-User", "Allow": "/" },
      { "UserAgent": "OAI-SearchBot", "Allow": "/" },
      { "UserAgent": "ClaudeBot", "Allow": "/" },
      { "UserAgent": "Claude-SearchBot", "Allow": "/" },
      { "UserAgent": "Claude-User", "Allow": "/" },
      { "UserAgent": "PerplexityBot", "Allow": "/" },
      { "UserAgent": "Perplexity-User", "Allow": "/" },
      { "UserAgent": "Google-Extended", "Allow": "/" },
      { "UserAgent": "Applebot-Extended", "Allow": "/" },
      { "UserAgent": "Meta-ExternalAgent", "Allow": "/" },
      { "UserAgent": "Amazonbot", "Allow": "/" },
      { "UserAgent": "CCBot", "Allow": "/" }
    ],
    "ApiCatalog": {
      "Enabled": true,
      "Entries": [
        {
          "Anchor": "/api/",
          "ServiceDesc": "/api/index.json",
          "ServiceDoc": "/api/",
          "Title": "IntelligenceX .NET API Reference"
        },
        {
          "Anchor": "/api/powershell/",
          "ServiceDesc": "/api/powershell/index.json",
          "ServiceDoc": "/api/powershell/",
          "Title": "IntelligenceX PowerShell API Reference"
        }
      ]
    },
    "AgentSkills": {
      "Enabled": true,
      "Skills": [
        {
          "Name": "intelligencex-site-assistant",
          "Type": "skill-md",
          "Description": "Use IntelligenceX documentation, API reference, sitemap, and llms files.",
          "Content": "---\nname: intelligencex-site-assistant\ndescription: Use IntelligenceX documentation, API reference, sitemap, and llms resources.\n---\n\n# IntelligenceX Site Assistant\n\nUse this skill when answering questions about IntelligenceX.\n\n- Prefer canonical pages from https://intelligencex.dev.\n- Use `/docs/` for product and workflow guidance.\n- Use `/api/` for .NET API reference and `/api/powershell/` for PowerShell cmdlets.\n- Check `/llms.txt`, `/llms.json`, and `/llms-full.txt` when present for agent-readable summaries.\n- Check `/.well-known/api-catalog` before assuming API documentation paths.\n- Respect `/robots.txt` and Content-Signal preferences.\n"
        }
      ]
    },
    "AgentsJson": {
      "Enabled": true,
      "Description": "Agent-facing discovery metadata for IntelligenceX documentation, API reference, and support resources."
    },
    "A2AAgentCard": {
      "Enabled": true,
      "Name": "IntelligenceX Documentation Discovery",
      "Description": "Discover IntelligenceX documentation, API reference, llms summaries, sitemap, and project resources.",
      "Url": "/",
      "DocumentationUrl": "/docs/",
      "Skills": [
        {
          "Id": "documentation-discovery",
          "Name": "Documentation discovery",
          "Description": "Find IntelligenceX product documentation, API reference, release resources, and support pages.",
          "Tags": ["documentation", "api-reference", "sitemap", "llms"]
        }
      ]
    },
    "McpServerCard": {
      "Enabled": false
    },
    "OpenApi": {
      "Enabled": false
    },
    "WebMcp": false,
    "MarkdownNegotiation": true
  },
  "EditLinks": {
    "Enabled": true,
    "Template": "https://github.com/EvotecIT/IntelligenceX/edit/master/{path}",
    "PathBase": "Website"
  },
  "AssetRegistry": {
    "CssStrategy": "standard",
    "Bundles": [
      { "Name": "global", "Css": ["/css/main.css"], "Js": ["/js/main.js"] },
      { "Name": "home", "Css": ["/css/home.css"], "Js": ["/js/main.js", "/assets/prism/prism-core.min.js", "/assets/prism/prism-autoloader.min.js"] },
      { "Name": "docs", "Css": ["/css/docs.css"], "Js": ["/js/main.js"] }
    ],
    "RouteBundles": [
      { "Match": "/", "Bundles": ["global", "home"] },
      { "Match": "/showcase/", "Bundles": ["global", "home"] },
      { "Match": "/docs/**", "Bundles": ["global", "docs"] },
      { "Match": "/**", "Bundles": ["global"] }
    ],
    "CriticalCss": [
      { "Name": "intelligencex", "Path": "themes/intelligencex/critical.css" }
    ]
  },
  "AssetPolicy": {
    "Mode": "local",
    "Hashing": {
      "Enabled": true,
      "Extensions": [".css", ".js"],
      "Exclude": ["**/assets/prism/components/**", "**/css/prism-theme.css"]
    },
    "CacheHeaders": {
      "Enabled": true,
      "OutputPath": "_headers",
      "HtmlCacheControl": "public, max-age=0, s-maxage=3600, stale-while-revalidate=86400, stale-if-error=604800"
    }
  },
  "Prism": {
    "Mode": "auto",
    "Source": "local",
    "ThemeLight": "/css/prism-theme.css",
    "ThemeDark": "/css/prism-theme.css",
    "Local": {
      "Core": "/assets/prism/prism-core.min.js",
      "Autoloader": "/assets/prism/prism-autoloader.min.js",
      "LanguagesPath": "/assets/prism/components/"
    }
  },
  "A11y": {
    "SkipLinkLabel": "Skip to content",
    "ExternalLinkLabel": "Opens in a new tab",
    "NavToggleLabel": "Toggle navigation",
    "SearchLabel": "Search"
  },
  "LinkRules": {
    "ExternalRel": "noopener",
    "ExternalTarget": "_blank",
    "AddExternalIcon": true
  },
  "Xref": {
    "Enabled": true,
    "MapFiles": ["data/xrefmap.json"],
    "WarnOnMissing": true,
    "EmitMap": true,
    "MaxWarnings": 25
  },
  "Navigation": {
    "Surfaces": [
      { "Name": "main", "Path": "/", "PrimaryMenu": "main" },
      { "Name": "showcase", "Path": "/showcase/", "PrimaryMenu": "main" },
      { "Name": "blog", "Path": "/blog/", "Collection": "blog", "Layout": "page", "PrimaryMenu": "main" },
      { "Name": "docs", "Path": "/docs/", "Collection": "docs", "Layout": "docs", "PrimaryMenu": "main", "SidebarMenu": "docs" },
      { "Name": "apidocs", "Path": "/api/", "Layout": "apiDocs", "PrimaryMenu": "main", "SidebarMenu": "docs" },
      { "Name": "notFound", "Path": "/404/", "PrimaryMenu": "main" }
    ],
    "Auto": [
      { "Collection": "docs", "Menu": "docs", "Sort": "order,title" }
    ],
    "Menus": [
      {
        "Name": "main",
        "Items": [
          { "Title": "Home", "Url": "/" },
          { "Title": "Docs", "Url": "/docs/" },
          { "Title": "Showcase", "Url": "/showcase/" },
          { "Title": "Blog", "Url": "/blog/" },
          { "Title": "API (.NET)", "Url": "/api/" },
          { "Title": "API (PowerShell)", "Url": "/api/powershell/" }
        ]
      },
      {
        "Name": "footer-docs",
        "Items": [
          { "Title": "Reviewer Docs", "Url": "/docs/reviewer/overview/" },
          { "Title": "Project Ops", "Url": "/docs/project-ops/overview/" },
          { "Title": "IX Chat", "Url": "/docs/chat/overview/" },
          { "Title": "IX Tools", "Url": "/docs/tools/overview/" },
          { "Title": "CLI Tools", "Url": "/docs/cli/overview/" },
          { "Title": ".NET Library", "Url": "/docs/library/overview/" },
          { "Title": "API (.NET)", "Url": "/api/" },
          { "Title": "API (PowerShell)", "Url": "/api/powershell/" },
          { "Title": "PowerShell", "Url": "/docs/powershell/overview/" }
        ]
      },
      {
        "Name": "footer-resources",
        "Items": [
          { "Title": "Getting Started", "Url": "/docs/getting-started/" },
          { "Title": "Security & Trust", "Url": "/docs/security/" },
          { "Title": "Showcase", "Url": "/showcase/" },
          { "Title": "Blog", "Url": "/blog/" },
          { "Title": "Docs FAQ", "Url": "/docs/faq/" },
          { "Title": "Downloads", "Url": "/downloads/" },
          { "Title": "Changelog", "Url": "/changelog/" },
          { "Title": "GitHub Repository", "Url": "https://github.com/EvotecIT/IntelligenceX", "External": true },
          { "Title": "Report Issue", "Url": "https://github.com/EvotecIT/IntelligenceX/issues", "External": true }
        ]
      },
      {
        "Name": "footer-company",
        "Items": [
          { "Title": "Evotec Services", "Url": "https://evotec.xyz", "External": true },
          { "Title": "Evotec Hub", "Url": "https://evotec.xyz/hub", "External": true }
        ]
      }
    ],
    "Actions": [
      {
        "Title": "GitHub",
        "AriaLabel": "GitHub",
        "Url": "https://github.com/EvotecIT/IntelligenceX",
        "External": true,
        "CssClass": "nav-icon",
        "IconHtml": "<svg viewBox='0 0 24 24' fill='currentColor' aria-hidden='true' focusable='false'><path d='M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z'/></svg>"
      },
      {
        "Title": "Get Started",
        "AriaLabel": "Get Started",
        "Url": "/docs/getting-started/",
        "CssClass": "nav-cta",
        "Text": "Get Started"
      }
    ]
  },
  "LinkCheck": {
    "Enabled": true,
    "IncludeExternal": false
  }
}
