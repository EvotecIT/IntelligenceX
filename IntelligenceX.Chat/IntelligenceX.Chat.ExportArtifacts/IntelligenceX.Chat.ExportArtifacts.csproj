<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <PropertyGroup>
    <OfficeImoExcelProjectOverride>$(OfficeImoRepoRoot)\OfficeIMO.Excel\OfficeIMO.Excel.csproj</OfficeImoExcelProjectOverride>
    <OfficeImoExcelProjectCandidate1>$(OfficeImoRepoRootCandidate1)OfficeIMO.Excel\OfficeIMO.Excel.csproj</OfficeImoExcelProjectCandidate1>
    <OfficeImoExcelProjectCandidate2>$(OfficeImoRepoRootCandidate2)OfficeIMO.Excel\OfficeIMO.Excel.csproj</OfficeImoExcelProjectCandidate2>
    <OfficeImoExcelProject Condition="Exists('$(OfficeImoExcelProjectOverride)')">$(OfficeImoExcelProjectOverride)</OfficeImoExcelProject>
    <OfficeImoExcelProject Condition="'$(OfficeImoExcelProject)' == '' and Exists('$(OfficeImoExcelProjectCandidate1)')">$(OfficeImoExcelProjectCandidate1)</OfficeImoExcelProject>
    <OfficeImoExcelProject Condition="'$(OfficeImoExcelProject)' == '' and Exists('$(OfficeImoExcelProjectCandidate2)')">$(OfficeImoExcelProjectCandidate2)</OfficeImoExcelProject>

    <OfficeImoWordMarkdownProjectOverride>$(OfficeImoRepoRoot)\OfficeIMO.Word.Markdown\OfficeIMO.Word.Markdown.csproj</OfficeImoWordMarkdownProjectOverride>
    <OfficeImoWordMarkdownProjectCandidate1>$(OfficeImoRepoRootCandidate1)OfficeIMO.Word.Markdown\OfficeIMO.Word.Markdown.csproj</OfficeImoWordMarkdownProjectCandidate1>
    <OfficeImoWordMarkdownProjectCandidate2>$(OfficeImoRepoRootCandidate2)OfficeIMO.Word.Markdown\OfficeIMO.Word.Markdown.csproj</OfficeImoWordMarkdownProjectCandidate2>
    <OfficeImoWordMarkdownProject Condition="Exists('$(OfficeImoWordMarkdownProjectOverride)')">$(OfficeImoWordMarkdownProjectOverride)</OfficeImoWordMarkdownProject>
    <OfficeImoWordMarkdownProject Condition="'$(OfficeImoWordMarkdownProject)' == '' and Exists('$(OfficeImoWordMarkdownProjectCandidate1)')">$(OfficeImoWordMarkdownProjectCandidate1)</OfficeImoWordMarkdownProject>
    <OfficeImoWordMarkdownProject Condition="'$(OfficeImoWordMarkdownProject)' == '' and Exists('$(OfficeImoWordMarkdownProjectCandidate2)')">$(OfficeImoWordMarkdownProjectCandidate2)</OfficeImoWordMarkdownProject>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="$(OfficeImoExcelProject)"
                      Condition="'$(UseLocalOfficeImoCheckout)' == 'true' and Exists('$(OfficeImoExcelProject)')" />
    <ProjectReference Include="$(OfficeImoWordMarkdownProject)"
                      Condition="'$(UseLocalOfficeImoCheckout)' == 'true' and Exists('$(OfficeImoWordMarkdownProject)')" />

    <PackageReference Include="OfficeIMO.Excel" Version="$(OfficeImoExcelNuGetVersion)"
                      Condition="'$(UseLocalOfficeImoCheckout)' != 'true' or !Exists('$(OfficeImoExcelProject)')" />
    <PackageReference Include="OfficeIMO.Word.Markdown" Version="$(OfficeImoWordMarkdownNuGetVersion)"
                      Condition="'$(UseLocalOfficeImoCheckout)' != 'true' or !Exists('$(OfficeImoWordMarkdownProject)')" />
  </ItemGroup>

</Project>
