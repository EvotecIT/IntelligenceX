{
  "$schema": "https://raw.githubusercontent.com/EvotecIT/PSPublishModule/main/Schemas/powerforge.release.schema.json",
  "SchemaVersion": 1,
  "WorkspaceValidation": {
    "ConfigPath": "workspace.validation.json",
    "Profile": "full-private"
  },
  "Outputs": {
    "Staging": {
      "RootPath": "../Artifacts/UploadReady",
      "PackagesPath": "NuGet",
      "PortablePath": "GitHub",
      "InstallerPath": "GitHub",
      "ToolsPath": "GitHub",
      "MetadataPath": "Metadata",
      "PackagesNameTemplate": "{PackageId}.{Version}{Extension}"
    }
  },
  "Packages": {
    "RootPath": "..",
    "ExpectedVersion": "0.1.X",
    "IncludeProjects": [
      "IntelligenceX"
    ],
    "ExcludeDirectories": [
      ".worktrees",
      ".claude",
      "Artifacts",
      "Website",
      "WebsiteArtifacts"
    ],
    "Configuration": "Release",
    "StagingPath": "Artifacts/ProjectBuild",
    "CleanStaging": true,
    "PlanOutputPath": "Artifacts/ProjectBuild/project.build.plan.json",
    "UpdateVersions": true,
    "Build": true,
    "PublishNuget": false,
    "PublishGitHub": false,
    "CreateReleaseZip": true,
    "PublishSource": "https://api.nuget.org/v3/index.json",
    "PublishApiKeyFilePath": "C:\\Support\\Important\\NugetOrgEvotec.txt",
    "SkipDuplicate": true,
    "PublishFailFast": true,
    "GitHubAccessTokenFilePath": "C:\\Support\\Important\\GithubAPI.txt",
    "GitHubUsername": "EvotecIT",
    "GitHubRepositoryName": "IntelligenceX",
    "GitHubReleaseMode": "Single",
    "GitHubPrimaryProject": "IntelligenceX",
    "GitHubTagTemplate": "{Repo}-packages-v{PrimaryVersion}",
    "GitHubTagConflictPolicy": "Reuse",
    "GitHubIsPreRelease": false,
    "GitHubIncludeProjectNameInTag": false,
    "GitHubGenerateReleaseNotes": true,
    "GitHubReleaseName": "{Repo} packages {PrimaryVersion}"
  },
  "Tools": {
    "DotNetPublishConfigPath": "powerforge.dotnetpublish.json",
    "GitHub": {
      "Publish": false,
      "Owner": "EvotecIT",
      "Repository": "IntelligenceX",
      "TokenFilePath": "C:\\Support\\Important\\GithubAPI.txt",
      "GenerateReleaseNotes": true,
      "IsPreRelease": false,
      "TagTemplate": "{Target}-v{Version}",
      "ReleaseNameTemplate": "{Target} {Version}"
    }
  },
  "GitHub": {
    "Publish": false,
    "Owner": "EvotecIT",
    "Repository": "IntelligenceX",
    "TokenFilePath": "C:\\Support\\Important\\GithubAPI.txt",
    "GenerateReleaseNotes": true,
    "IsPreRelease": false,
    "TagTemplate": "v{Version}",
    "ReleaseNameTemplate": "{Repository} {Version}"
  },
  "Winget": {
    "Enabled": true,
    "OutputPath": "Winget",
    "InstallerUrlTemplate": "https://github.com/EvotecIT/IntelligenceX/releases/download/v{PackageVersion}/{FileName}",
    "Packages": [
      {
        "PackageIdentifier": "EvotecIT.IntelligenceX.Tray",
        "Publisher": "Evotec",
        "PackageName": "IntelligenceX Tray",
        "License": "MIT",
        "ShortDescription": "Windows tray app for IntelligenceX local chat and workflows.",
        "Tags": [
          "intelligencex",
          "tray",
          "chat"
        ],
        "Installers": [
          {
            "Category": "Portable",
            "Target": "IntelligenceX.Tray",
            "Runtime": "win-x64",
            "InstallerType": "zip",
            "NestedInstallerType": "portable",
            "RelativeFilePath": "IntelligenceX.Tray.exe"
          },
          {
            "Category": "Portable",
            "Target": "IntelligenceX.Tray",
            "Runtime": "win-arm64",
            "InstallerType": "zip",
            "NestedInstallerType": "portable",
            "RelativeFilePath": "IntelligenceX.Tray.exe"
          }
        ]
      },
      {
        "PackageIdentifier": "EvotecIT.IntelligenceX.Chat",
        "Publisher": "Evotec",
        "PackageName": "IntelligenceX Chat",
        "License": "MIT",
        "ShortDescription": "Portable Windows chat app for IntelligenceX local workflows.",
        "Tags": [
          "intelligencex",
          "chat",
          "portable"
        ],
        "Installers": [
          {
            "Category": "Portable",
            "Target": "IntelligenceX.Chat.App",
            "Runtime": "win-x64",
            "InstallerType": "zip",
            "NestedInstallerType": "portable",
            "RelativeFilePath": "IntelligenceX.Chat.App.exe"
          }
        ]
      }
    ]
  }
}
