{
  "SchemaVersion": 1,
  "ProjectRoot": "..",
  "DefaultFeatures": [
    "tests",
    "harness",
    "public-tools"
  ],
  "Profiles": [
    {
      "Name": "oss",
      "Description": "Public CI-style baseline with optional public tools and chat build."
    },
    {
      "Name": "full-private",
      "Description": "Internal validation with private TestimoX-backed packs available.",
      "Features": [
        "private-tools"
      ]
    }
  ],
  "Steps": [
    {
      "Id": "ci-build",
      "Name": "CI baseline build",
      "Kind": "DotNet",
      "Arguments": [
        "build",
        "IntelligenceX.CI.slnf",
        "-c",
        "{configuration}"
      ],
      "FailureContext": "CI baseline build failed.",
      "FailureHint": "Run the same dotnet build directly if you want compiler output first."
    },
    {
      "Id": "ci-test",
      "Name": "CI baseline tests",
      "Kind": "DotNet",
      "RequiredFeatures": [
        "tests"
      ],
      "Arguments": [
        "test",
        "IntelligenceX.CI.slnf",
        "-c",
        "{configuration}",
        "--no-build"
      ],
      "FailureContext": "CI baseline tests failed.",
      "FailureHint": "Use -SkipTests when you only want a publish preflight."
    },
    {
      "Id": "harness",
      "Name": "Executable harness ({framework})",
      "Kind": "DotNet",
      "RequiredFeatures": [
        "harness"
      ],
      "Frameworks": [
        "net8.0",
        "net10.0"
      ],
      "RequiredPath": "IntelligenceX.Tests/bin/{configuration}/{framework}/IntelligenceX.Tests.dll",
      "ContinueOnMissingRequiredPath": true,
      "Arguments": [
        "IntelligenceX.Tests/bin/{configuration}/{framework}/IntelligenceX.Tests.dll"
      ],
      "FailureContext": "Executable harness failed.",
      "FailureHint": "Use -SkipHarness when you only want packaging/publish preflight."
    },
    {
      "Id": "public-tools",
      "Name": "Build public tool {item}",
      "Kind": "DotNet",
      "RequiredFeatures": [
        "public-tools"
      ],
      "Items": [
        "IntelligenceX.Tools/IntelligenceX.Tools.Common/IntelligenceX.Tools.Common.csproj",
        "IntelligenceX.Tools/IntelligenceX.Tools.FileSystem/IntelligenceX.Tools.FileSystem.csproj",
        "IntelligenceX.Tools/IntelligenceX.Tools.Email/IntelligenceX.Tools.Email.csproj",
        "IntelligenceX.Tools/IntelligenceX.Tools.EventLog/IntelligenceX.Tools.EventLog.csproj",
        "IntelligenceX.Tools/IntelligenceX.Tools.PowerShell/IntelligenceX.Tools.PowerShell.csproj",
        "IntelligenceX.Tools/IntelligenceX.Tools.ReviewerSetup/IntelligenceX.Tools.ReviewerSetup.csproj"
      ],
      "Arguments": [
        "build",
        "{item}",
        "-c",
        "{configuration}"
      ],
      "FailureContext": "Public tool build failed."
    },
    {
      "Id": "private-tools",
      "Name": "Build private tool {item}",
      "Kind": "DotNet",
      "RequiredFeatures": [
        "private-tools"
      ],
      "Items": [
        "IntelligenceX.Tools/IntelligenceX.Tools.System/IntelligenceX.Tools.System.csproj",
        "IntelligenceX.Tools/IntelligenceX.Tools.ADPlayground/IntelligenceX.Tools.ADPlayground.csproj",
        "IntelligenceX.Tools/IntelligenceX.Tools.TestimoX/IntelligenceX.Tools.TestimoX.csproj"
      ],
      "Arguments": [
        "build",
        "{item}",
        "-c",
        "{configuration}"
      ],
      "FailureContext": "Private tool build failed."
    },
    {
      "Id": "private-tools-tests",
      "Name": "Run IntelligenceX.Tools.Tests",
      "Kind": "DotNet",
      "RequiredFeatures": [
        "private-tools",
        "tests"
      ],
      "Arguments": [
        "test",
        "IntelligenceX.Tools/IntelligenceX.Tools.Tests/IntelligenceX.Tools.Tests.csproj",
        "-c",
        "{configuration}",
        "--no-build"
      ],
      "FailureContext": "Private tool-pack tests failed.",
      "FailureHint": "Use -SkipTests when you only want packaging/publish preflight."
    },
    {
      "Id": "chat-build-oss",
      "Name": "Chat build",
      "Kind": "DotNet",
      "Profiles": [
        "oss"
      ],
      "RequiredFeatures": [
        "chat"
      ],
      "Arguments": [
        "build",
        "IntelligenceX.Chat/IntelligenceX.Chat.sln",
        "-c",
        "{configuration}"
      ],
      "FailureContext": "Chat solution build failed."
    },
    {
      "Id": "chat-build-private",
      "Name": "Chat build (private packs)",
      "Kind": "DotNet",
      "Profiles": [
        "full-private"
      ],
      "RequiredFeatures": [
        "chat"
      ],
      "Arguments": [
        "build",
        "IntelligenceX.Chat/IntelligenceX.Chat.sln",
        "-c",
        "{configuration}",
        "/p:IncludePrivateToolPacks=true"
      ],
      "FailureContext": "Chat solution build failed."
    }
  ]
}
